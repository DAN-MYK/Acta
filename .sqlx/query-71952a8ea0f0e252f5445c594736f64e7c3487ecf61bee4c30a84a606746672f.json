  "query": "\n        UPDATE acts\n        SET number          = $2,\n            counterparty_id = $3,\n            contract_id     = $4,\n            date            = $5,\n            notes           = $6,\n            updated_at      = NOW()\n        WHERE id = $1\n        RETURNING id, number, counterparty_id, contract_id, date, total_amount,\n                  status AS \"status: ActStatus\", notes, bas_id, created_at, updated_at\n        ",
