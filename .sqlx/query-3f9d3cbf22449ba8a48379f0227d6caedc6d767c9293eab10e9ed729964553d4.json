{
  "db_name": "PostgreSQL",
  "query": "\n                SELECT a.id, a.number, a.date,\n                       c.name AS counterparty_name,\n                       a.total_amount,\n                       a.status AS \"status: ActStatus\"\n                FROM acts a\n                JOIN counterparties c ON c.id = a.counterparty_id\n                WHERE a.status = $1\n                ORDER BY a.date DESC, a.number\n                ",
