  "db_name": "PostgreSQL",
  "query": "\n        SELECT id, name, edrpou, iban, address, phone, email, notes,\n               is_archived, bas_id, created_at, updated_at\n        FROM counterparties\n        WHERE is_archived = FALSE\n          AND (name ILIKE $1 OR edrpou ILIKE $1)\n        ORDER BY name\n        LIMIT 100\n        ",
