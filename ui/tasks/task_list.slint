// Компонент: список задач
//
// Патерн аналогічний іншим спискам у проєкті:
//   - Topbar з кнопкою створення
//   - Пошук по заголовку/опису
//   - Таблиця з рядками
//   - Панель дій для вибраної задачі

import { Theme } from "../theme.slint";
import { ProgressIndicator, ListView } from "std-widgets.slint";
import { TaskRow } from "../structs.slint";

export component TaskList {

    // ── Вхідні дані (Rust → Slint) ─────────────────────────────────────────
    in property <[TaskRow]> rows;
    in property <bool>                     loading: false;

    // ── Колбеки (Slint → Rust) ──────────────────────────────────────────────
    callback search-changed(string);
    callback row-selected(string);
    callback create-clicked();
    callback toggle-status-clicked(string);
    callback delete-clicked(string);
    callback edit-clicked(string);

    // ── Внутрішній стан ─────────────────────────────────────────────────────
    private property <int>    selected-row: -1;
    private property <string> selected-id: "";
    private property <string> selected-status: "";
    private property <string> selected-title: "";
    private property <string> selected-priority: "";
    private property <bool>   delete-confirm-armed: false;

    min-width: 600px;
    min-height: 400px;

    VerticalLayout {
        spacing: 0;
        padding: 0;

        Rectangle {
            height: 64px;
            background: Theme.bg-card;

            HorizontalLayout {
                padding-left: 32px;
                padding-right: 32px;
                spacing: 16px;

                Text {
                    text: "Завдання";
                    font-size: 18px;
                    font-weight: 600;
                    color: Theme.text-primary;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                if root.rows.length > 0 : Text {
                    text: root.rows.length + " записів";
                    color: Theme.text-muted;
                    font-size: 12px;
                    vertical-alignment: center;
                }

                new-btn := Rectangle {
                    background: Theme.primary;
                    border-radius: 8px;
                    height: 36px;
                    width: 144px;
                    y: (parent.height - self.height) / 2;

                    Text {
                        text: "+ Нова задача";
                        color: Theme.text-white;
                        font-size: 13px;
                        font-weight: 500;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.create-clicked(); }
                    }
                }
            }

            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: Theme.border;
            }
        }

        Rectangle {
            background: Theme.bg-page;
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: 24px;
                padding-left: 32px;
                padding-right: 32px;
                padding-bottom: 24px;
                spacing: 16px;

                HorizontalLayout {
                    height: 40px;
                    spacing: 12px;
                    vertical-stretch: 0;

                    search-rect := Rectangle {
                        background: Theme.bg-card;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.border;
                        horizontal-stretch: 1;
                        clip: true;

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;

                            search-input := TextInput {
                                vertical-alignment: center;
                                font-size: 13px;
                                color: Theme.text-primary;
                                edited => { root.search-changed(search-input.text); }
                            }
                        }

                        if search-input.text == "" : Text {
                            x: 12px;
                            height: parent.height;
                            width: parent.width - 24px;
                            text: "🔎  Пошук за назвою або описом...";
                            color: Theme.text-muted;
                            font-size: 13px;
                            vertical-alignment: center;
                        }
                    }
                }

                if root.loading : ProgressIndicator {
                    indeterminate: true;
                    vertical-stretch: 0;
                }

                Rectangle {
                    vertical-stretch: 1;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: Theme.border;
                    clip: true;

                    VerticalLayout {
                        spacing: 0;

                        Rectangle {
                            height: 40px;
                            background: Theme.table-header;

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;

                                Text { text: "Задача";      color: Theme.text-second; font-size: 12px; font-weight: 500; horizontal-stretch: 3; vertical-alignment: center; }
                                Text { text: "Пріоритет";   color: Theme.text-second; font-size: 12px; font-weight: 500; width: 110px; vertical-alignment: center; }
                                Text { text: "Дедлайн";     color: Theme.text-second; font-size: 12px; font-weight: 500; width: 160px; vertical-alignment: center; }
                                Text { text: "Нагадування"; color: Theme.text-second; font-size: 12px; font-weight: 500; width: 160px; vertical-alignment: center; }
                                Text { text: "Статус";      color: Theme.text-second; font-size: 12px; font-weight: 500; width: 100px; vertical-alignment: center; }
                            }
                        }

                        if !root.loading && root.rows.length == 0 : Rectangle {
                            vertical-stretch: 1;
                            background: Theme.bg-card;

                            VerticalLayout {
                                alignment: center;
                                spacing: 8px;

                                Text {
                                    text: "📝";
                                    font-size: 32px;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: "Завдань ще немає";
                                    font-size: 15px;
                                    font-weight: 500;
                                    color: Theme.text-second;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: "Натисніть «+ Нова задача» щоб створити першу";
                                    font-size: 13px;
                                    color: Theme.text-muted;
                                    horizontal-alignment: center;
                                }
                            }
                        }

                        ListView {
                            vertical-stretch: 1;

                            for row[i] in root.rows : Rectangle {
                                property <string> raw-status: row.status;
                                property <string> raw-priority: row.priority;
                                property <color> status-color:
                                    raw-status == "done"       ? Theme.success :
                                    raw-status == "in_progress"? Theme.primary :
                                    raw-status == "cancelled"  ? Theme.text-muted :
                                    Theme.warning;
                                property <color> status-bg:
                                    raw-status == "done"       ? #1EB16E1F :
                                    raw-status == "in_progress"? #3D75F41A :
                                    raw-status == "cancelled"  ? #ABABB71F :
                                    #F4A31E1F;
                                property <color> priority-color:
                                    raw-priority == "critical" ? Theme.priority-critical :
                                    raw-priority == "high"     ? Theme.priority-high :
                                    raw-priority == "normal"   ? Theme.primary :
                                    Theme.text-muted;
                                property <color> priority-bg:
                                    raw-priority == "critical" ? #DC26261A :
                                    raw-priority == "high"     ? #F973161A :
                                    raw-priority == "normal"   ? #3D75F41A :
                                    #ABABB71A;

                                height: 52px;
                                background: root.selected-row == i
                                    ? Theme.row-selected
                                    : (row-touch.has-hover
                                        ? Theme.row-hover
                                        : (Math.mod(i, 2) == 0 ? Theme.bg-card : Theme.row-stripe));
                                border-width: 1px;
                                border-color: Theme.border;
                                animate background { duration: 80ms; easing: ease; }

                                HorizontalLayout {
                                    padding-left: 15px;
                                    padding-right: 15px;

                                    Text {
                                        text: row.title;
                                        color: Theme.text-primary;
                                        font-size: 13px;
                                        font-weight: 500;
                                        horizontal-stretch: 3;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }

                                    Rectangle {
                                        width: 110px;
                                        Rectangle {
                                            width: 90px;
                                            height: 24px;
                                            y: (parent.height - self.height) / 2;
                                            border-radius: 12px;
                                            background: priority-bg;
                                            Text {
                                                text: row.priority-label;
                                                color: priority-color;
                                                font-size: 11px;
                                                font-weight: 500;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    Text {
                                        text: row.due-date;
                                        color: Theme.text-second;
                                        font-size: 13px;
                                        width: 160px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }

                                    Text {
                                        text: row.reminder;
                                        color: Theme.text-second;
                                        font-size: 13px;
                                        width: 160px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }

                                    Rectangle {
                                        width: 100px;
                                        Rectangle {
                                            width: 84px;
                                            height: 24px;
                                            y: (parent.height - self.height) / 2;
                                            border-radius: 12px;
                                            background: status-bg;
                                            Text {
                                                text: row.status-label;
                                                color: status-color;
                                                font-size: 11px;
                                                font-weight: 500;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }

                                row-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        root.selected-row      = i;
                                        root.delete-confirm-armed = false;
                                        root.selected-id       = row.id;
                                        root.selected-status   = row.status;
                                        root.selected-title    = row.title;
                                        root.selected-priority = row.priority-label;
                                        root.row-selected(row.id);
                                    }
                                }
                            }
                        }
                    }
                }

                if root.selected-row >= 0 : HorizontalLayout {
                    height: 48px;
                    spacing: 8px;
                    vertical-stretch: 0;

                    Text {
                        text: root.selected-title + " • " + root.selected-priority;
                        color: Theme.text-second;
                        font-size: 13px;
                        font-weight: 500;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        overflow: elide;
                    }

                    Rectangle {
                        background: Theme.bg-card;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.border;
                        height: 36px;
                        width: 120px;
                        y: (parent.height - self.height) / 2;

                        Text {
                            text: "✎  Редагувати";
                            color: Theme.text-primary;
                            font-size: 13px;
                            font-weight: 500;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                if root.selected-id != "" {
                                    root.edit-clicked(root.selected-id);
                                }
                            }
                        }
                    }

                    Rectangle {
                        background: Theme.primary;
                        border-radius: 8px;
                        height: 36px;
                        width: 170px;
                        y: (parent.height - self.height) / 2;

                        Text {
                            text: root.selected-status == "done" ? "✓  Завершено" : "✓  Завершити";
                                                    color: Theme.text-white;
                            font-size: 13px;
                            font-weight: 500;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        TouchArea {
                            mouse-cursor: root.selected-status != "done" ? pointer : default;
                            clicked => {
                                if root.selected-id != "" && root.selected-status != "done" {
                                    root.delete-confirm-armed = false;
                                    root.toggle-status-clicked(root.selected-id);
                                }
                            }
                        }
                    }

                    Rectangle {
                        background: Theme.bg-danger;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.danger-border;
                        height: 36px;
                        width: root.delete-confirm-armed ? 150px : 110px;
                        y: (parent.height - self.height) / 2;

                        Text {
                            text: root.delete-confirm-armed ? "Підтвердити" : "🗑  Видалити";
                            color: Theme.danger;
                            font-size: 13px;
                            font-weight: 500;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                if root.selected-id != "" {
                                    if root.delete-confirm-armed {
                                        root.delete-confirm-armed = false;
                                        root.delete-clicked(root.selected-id);
                                    } else {
                                        root.delete-confirm-armed = true;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
