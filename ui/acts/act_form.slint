// Форма створення/редагування акту виконаних робіт
//
// Архітектура:
//   - Уся бізнес-логіка (розрахунок сум, валідація) — тільки в Rust
//   - UI-стан (введені значення, поточний вибір) — тут, у Slint
//   - При збереженні колбек передає текстові значення полів до Rust
//   - Позиції: Rust керує списком, Slint лише відображає та сигналізує про зміни
//
// Layout (Figma-spec):
//   ┌─ Topbar 64px: breadcrumb | [Скасувати] [Зберегти] ─────────────┐
//   │  ScrollView (flex)            │  Right panel 392px              │
//   │  ┌── FormCard ─────────────┐  │  ┌── StatusCard ──────────────┐ │
//   │  │  Основна інформація     │  │  │  radio: Черн/Вист/Підп/Опл │ │
//   │  │  Послуги / Роботи       │  │  └───────────────────────────┘ │
//   │  │  Разом / До сплати      │  │  ┌── HintCard ───────────────┐ │
//   │  │  Примітки               │  │  │  ℹ Підказка               │ │
//   │  └─────────────────────────┘  │  └───────────────────────────┘ │
//   │  ── Задачі по акту ────────── │                                 │
//   └─────────────────────────────────────────────────────────────────┘

import { Theme } from "../theme.slint";
import { LineEdit, TextEdit, ComboBox, ScrollView, ProgressIndicator, ListView } from "std-widgets.slint";
import { StatusOption } from "../components/status_option.slint";
import { TaskRow, FormItemRow } from "../structs.slint";

// ── Головний компонент форми ───────────────────────────────────────────────
component FieldLabel {
    in property <string> text;
    in property <bool> required: false;

    Text {
        text: root.required ? root.text + " *" : root.text;
        font-size: 12px;
        font-weight: 600;
        color: Theme.text-sub;
    }
}

component FieldBox inherits Rectangle {
    height: 40px;
    background: Theme.surface;
    border-width: 1px;
    border-color: Theme.border;
    border-radius: 8px;
    @children
}

component SectionDivider inherits Rectangle {
    height: 1px;
    background: Theme.border;
}

component TopbarButton inherits Rectangle {
    in property <string> text;
    in property <bool> primary: false;
    callback clicked();

    width: primary ? 112px : 120px;
    height: 36px;
    border-radius: 8px;
    border-width: primary ? 0px : 1px;
    border-color: Theme.border;
    background: primary
        ? Theme.primary
        : (btn-touch.has-hover ? Theme.hover-bg : Theme.bg);
    animate background { duration: 80ms; }

    Text {
        text: root.text;
        font-size: 14px;
        font-weight: primary ? 600 : 400;
        color: primary ? Theme.text-white : Theme.text-sub;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    btn-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

export component ActForm inherits Rectangle {

    // ── Вхідні дані (Rust → Slint) ────────────────────────────────────────
    in property <[string]> counterparty-names;
    in property <[string]> counterparty-ids;
    in property <string>   act-number: "";
    in property <string>   act-date: "";
    in property <string>   act-notes: "";
    in property <int>      act-cp-index: 0;
    in property <string>   total-amount: "0.00";
    in property <bool>     is-edit-mode: false;
    in property <string>   act-edit-id: "";

    // Статус: 0=Чернетка 1=Виставлений 2=Підписаний 3=Оплачений
    // in-out — щоб Rust міг встановити статус при редагуванні,
    // а Slint міг змінити через статус-пікер.
    in-out property <int>  act-status: 0;

    // ── Позиції акту ─────────────────────────────────────────────────────
    in property <[FormItemRow]> items;

    // ── Задачі, прив'язані до акту ────────────────────────────────────────
    in property <[TaskRow]> act-task-rows;
    in property <bool>                     act-tasks-loading: false;

    // ── Категорії та договори (необов'язково) ─────────────────────────────
    in property <[string]> category-names: [];
    in property <[string]> category-ids:   [];
    in property <int>      act-category-index: 0;   // 0 = "— без категорії —"

    in property <[string]> contract-names: [];
    in property <[string]> contract-ids:   [];
    in property <int>      act-contract-index: 0;   // 0 = "— без договору —"

    // ── Очікувана дата оплати (необов'язково) ─────────────────────────────
    in property <string>   act-expected-payment-date: "";

    // ── Колбеки (Slint → Rust) ────────────────────────────────────────────
    // Зберегти / Чернетка / Оновити — передають текстові значення полів
    // Параметри: number, date, cp_id, notes, category_id, contract_id, expected_payment_date
    callback save(      /* number */ string,
                        /* date   */ string,
                        /* cp_id  */ string,
                        /* notes  */ string,
                        /* cat_id */ string,
                        /* con_id */ string,
                        /* exp_dt */ string);
    callback save-draft(/* number */ string,
                        /* date   */ string,
                        /* cp_id  */ string,
                        /* notes  */ string,
                        /* cat_id */ string,
                        /* con_id */ string,
                        /* exp_dt */ string);
    callback update(    /* number */ string,
                        /* date   */ string,
                        /* cp_id  */ string,
                        /* notes  */ string,
                        /* cat_id */ string,
                        /* con_id */ string,
                        /* exp_dt */ string);
    callback cancel();
    callback add-item();
    callback remove-item(/* index */ int);
    // field: "desc" | "qty" | "unit" | "price"
    callback item-changed(/* index */ int, /* field */ string, /* value */ string);

    // Задачі
    callback act-task-create-clicked();
    callback act-task-edit-clicked(string);
    callback act-task-toggle-status-clicked(string);
    callback act-task-delete-clicked(string);

    min-width: 900px;
    min-height: 600px;
    background: Theme.bg;

    focus-scope := FocusScope {
        forward-focus: number-field;
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                root.cancel();
                return accept;
            }
            return reject;
        }

        VerticalLayout {
            spacing: 0;

            // ══════════════════════════════════════════════════════════════
            //  TOPBAR  64px
            // ══════════════════════════════════════════════════════════════
            Rectangle {
                height: 64px;
                background: Theme.surface;

                Rectangle {
                    y: 63px;
                    height: 1px;
                    background: Theme.border;
                }

                HorizontalLayout {
                    padding-left: 32px;
                    padding-right: 32px;
                    spacing: 8px;

                    // Breadcrumb (займає увесь вільний простір)
                    HorizontalLayout {
                        spacing: 6px;
                        horizontal-stretch: 1;
                        alignment: start;

                        // "← Акти" — клікабельний
                        Text {
                            text: "← Акти";
                            font-size: 14px;
                            color: Theme.primary;
                            vertical-alignment: center;
                            TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.cancel(); }
                            }
                        }
                        Text {
                            text: "/";
                            font-size: 14px;
                            color: Theme.text-muted;
                            vertical-alignment: center;
                        }
                        Text {
                            text: root.is-edit-mode ? "Редагування акту" : "Новий акт";
                            font-size: 14px;
                            font-weight: 600;
                            color: Theme.text-main;
                            vertical-alignment: center;
                        }
                    }

                    // Кнопка «Скасувати»
                    TopbarButton {
                        y: (parent.height - self.height) / 2;
                        text: "Скасувати";
                        clicked => { root.cancel(); }
                    }

                    // Кнопка «Зберегти»
                    // Логіка: edit → update; draft-статус → save-draft; інакше → save
                    TopbarButton {
                        y: (parent.height - self.height) / 2;
                        text: "Зберегти";
                        primary: true;
                        clicked => {
                            // category-ids[0] = "" (без категорії), [1..] = реальні ID
                            // Захист від порожніх масивів: ComboBox завжди має валідний
                            // current-index, але масиви IDs мають рівну довжину з names.
                            // Rust гарантує це, але додаємо guard на випадок race condition.
                            if root.counterparty-ids.length == 0 { return; }
                            if (root.is-edit-mode) {
                                root.update(
                                    number-field.text,
                                    date-field.text,
                                    root.counterparty-ids[cp-combo.current-index],
                                    notes-field.text,
                                    cat-combo.current-index < root.category-ids.length ? root.category-ids[cat-combo.current-index] : "",
                                    con-combo.current-index < root.contract-ids.length ? root.contract-ids[con-combo.current-index] : "",
                                    exp-date-field.text
                                );
                            } else if (root.act-status == 0) {
                                root.save-draft(
                                    number-field.text,
                                    date-field.text,
                                    root.counterparty-ids[cp-combo.current-index],
                                    notes-field.text,
                                    cat-combo.current-index < root.category-ids.length ? root.category-ids[cat-combo.current-index] : "",
                                    con-combo.current-index < root.contract-ids.length ? root.contract-ids[con-combo.current-index] : "",
                                    exp-date-field.text
                                );
                            } else {
                                root.save(
                                    number-field.text,
                                    date-field.text,
                                    root.counterparty-ids[cp-combo.current-index],
                                    notes-field.text,
                                    cat-combo.current-index < root.category-ids.length ? root.category-ids[cat-combo.current-index] : "",
                                    con-combo.current-index < root.contract-ids.length ? root.contract-ids[con-combo.current-index] : "",
                                    exp-date-field.text
                                );
                            }
                        }
                    }
                }
            }

            // ══════════════════════════════════════════════════════════════
            //  ОСНОВНИЙ КОНТЕНТ: форма зліва + панелі справа
            // ══════════════════════════════════════════════════════════════
            HorizontalLayout {
                vertical-stretch: 1;
                spacing: 0;

                // ──────────────────────────────────────────────────────────
                //  ЛІВИЙ СТОВПЕЦЬ: прокручувана форма
                // ──────────────────────────────────────────────────────────
                ScrollView {
                    horizontal-stretch: 1;

                    VerticalLayout {
                        padding: 32px;
                        spacing: 20px;

                        // ── Картка основної інформації + позицій ──────────
                        Rectangle {
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: Theme.border;
                            background: Theme.surface;
                            drop-shadow-color: #0000000D;
                            drop-shadow-blur: 8px;
                            drop-shadow-offset-y: 2px;

                            VerticalLayout {
                                padding: 24px;
                                spacing: 16px;

                                // Заголовок секції
                                VerticalLayout {
                                    spacing: 3px;
                                    Text {
                                        text: "Основна інформація";
                                        font-size: 16px;
                                        font-weight: 600;
                                        color: Theme.text-main;
                                    }
                                    Text {
                                        text: "* — обов'язкові поля";
                                        font-size: 12px;
                                        color: Theme.text-muted;
                                    }
                                }

                                SectionDivider { }

                                // Поле «Контрагент» (повна ширина)
                                VerticalLayout {
                                    spacing: 4px;
                                    FieldLabel {
                                        text: "Контрагент";
                                        required: true;
                                    }
                                    FieldBox {
                                        cp-combo := ComboBox {
                                            model: root.counterparty-names;
                                            current-index: root.act-cp-index;
                                        }
                                    }
                                }

                                // «Дата акту» + «Номер акту» поряд у два стовпці
                                HorizontalLayout {
                                    spacing: 16px;

                                    // Дата (ліво)
                                    VerticalLayout {
                                        spacing: 4px;
                                        horizontal-stretch: 1;
                                        FieldLabel {
                                            text: "Дата акту";
                                            required: true;
                                        }
                                        FieldBox {
                                            date-field := LineEdit {
                                                text: root.act-date;
                                                placeholder-text: "ДД.ММ.РРРР";
                                            }
                                        }
                                    }

                                    // Номер (право)
                                    VerticalLayout {
                                        spacing: 4px;
                                        horizontal-stretch: 1;
                                        FieldLabel {
                                            text: "Номер акту";
                                            required: true;
                                        }
                                        FieldBox {
                                            number-field := LineEdit {
                                                text: root.act-number;
                                                placeholder-text: "АКТ-001";
                                            }
                                        }
                                    }
                                }

                                // «Категорія» + «Договір» поряд у два стовпці
                                HorizontalLayout {
                                    spacing: 16px;

                                    // Категорія (ліво)
                                    VerticalLayout {
                                        spacing: 4px;
                                        horizontal-stretch: 1;
                                        FieldLabel {
                                            text: "Категорія";
                                        }
                                        FieldBox {
                                            cat-combo := ComboBox {
                                                model: root.category-names;
                                                current-index: root.act-category-index;
                                            }
                                        }
                                    }

                                    // Договір (право)
                                    VerticalLayout {
                                        spacing: 4px;
                                        horizontal-stretch: 1;
                                        FieldLabel {
                                            text: "Договір";
                                        }
                                        FieldBox {
                                            con-combo := ComboBox {
                                                model: root.contract-names;
                                                current-index: root.act-contract-index;
                                            }
                                        }
                                    }
                                }

                                // «Очікувана дата оплати» (необов'язкове)
                                VerticalLayout {
                                    spacing: 4px;
                                    FieldLabel {
                                        text: "Очікувана дата оплати";
                                    }
                                    FieldBox {
                                        exp-date-field := LineEdit {
                                            text: root.act-expected-payment-date;
                                            placeholder-text: "ДД.ММ.РРРР (необов'язково)";
                                        }
                                    }
                                }

                                SectionDivider { }

                                // Заголовок секції позицій + кнопка «+ Додати»
                                HorizontalLayout {
                                    alignment: space-between;

                                    Text {
                                        text: "Послуги / Роботи";
                                        font-size: 14px;
                                        font-weight: 600;
                                        color: Theme.text-main;
                                        vertical-alignment: center;
                                    }

                                    Rectangle {
                                        width: 160px;
                                        height: 32px;
                                        border-radius: 8px;
                                        background: Theme.primary-light;

                                        Text {
                                            text: "+ Додати позицію";
                                            font-size: 12px;
                                            font-weight: 600;
                                            color: Theme.primary;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                        TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { root.add-item(); }
                                        }
                                    }
                                }

                                // Шапка таблиці позицій
                                //
                                // Ширини стовпців мають точно збігатися з рядками нижче:
                                //   Найменування — horizontal-stretch: 3
                                //   К-сть        — 72px
                                //   Од.вим.      — 70px
                                //   Ціна         — 100px
                                //   Сума         — 100px
                                //   Кнопка ×     — 36px (placeholder)
                                Rectangle {
                                    height: 32px;
                                    border-radius: 6px;
                                    background: Theme.table-header;

                                    HorizontalLayout {
                                        padding-left: 12px;
                                        padding-right: 8px;
                                        spacing: 8px;
                                        Text { text: "Найменування"; font-size: 11px; font-weight: 600; color: Theme.text-sub; vertical-alignment: center; horizontal-stretch: 3; }
                                        Text { text: "К-сть";   font-size: 11px; font-weight: 600; color: Theme.text-sub; vertical-alignment: center; horizontal-alignment: right;  width: 72px;  }
                                        Text { text: "Од.вим."; font-size: 11px; font-weight: 600; color: Theme.text-sub; vertical-alignment: center; horizontal-alignment: center; width: 70px;  }
                                        Text { text: "Ціна";    font-size: 11px; font-weight: 600; color: Theme.text-sub; vertical-alignment: center; horizontal-alignment: right;  width: 100px; }
                                        Text { text: "Сума";    font-size: 11px; font-weight: 600; color: Theme.text-sub; vertical-alignment: center; horizontal-alignment: right;  width: 100px; }
                                        Rectangle { width: 36px; }
                                    }
                                }

                                // RUST-SIDE: items керується через Rc<VecModel<FormItemRow>>
                                // НЕ мутуй items напряму з UI — тільки через callbacks:
                                //   add-item()            → Rust додає рядок, оновлює model
                                //   remove-item(i)        → Rust видаляє за індексом
                                //   item-changed(i,f,v)   → Rust оновлює поле, перераховує amount
                                // Список позицій
                                //
                                // `for desc[i] in root.item-descriptions` — for-loop з індексом:
                                //   desc = поточний елемент, i = числовий індекс
                                VerticalLayout {
                                    spacing: 0;
                                    min-height: 80px;

                                    for item[i] in root.items : VerticalLayout {
                                        spacing: 0;

                                        Rectangle {
                                            height: 44px;
                                            background: Math.mod(i, 2) == 0 ? Theme.surface : Theme.row-alt;

                                            HorizontalLayout {
                                                padding-left: 12px;
                                                padding-right: 4px;
                                                padding-top: 4px;
                                                padding-bottom: 4px;
                                                spacing: 8px;

                                                LineEdit {
                                                    text: item.description;
                                                    font-size: 13px;
                                                    horizontal-stretch: 3;
                                                    edited(v) => { root.item-changed(i, "desc", v); }
                                                }
                                                LineEdit {
                                                    text: item.quantity;
                                                    font-size: 13px;
                                                    width: 72px;
                                                    edited(v) => { root.item-changed(i, "qty", v); }
                                                }
                                                LineEdit {
                                                    text: item.unit;
                                                    font-size: 13px;
                                                    width: 70px;
                                                    edited(v) => { root.item-changed(i, "unit", v); }
                                                }
                                                LineEdit {
                                                    text: item.price;
                                                    font-size: 13px;
                                                    width: 100px;
                                                    edited(v) => { root.item-changed(i, "price", v); }
                                                }
                                                // amount — read-only, обчислюється в Rust
                                                Text {
                                                    text: item.amount;
                                                    font-size: 13px;
                                                    font-weight: 600;
                                                    color: Theme.text-main;
                                                    vertical-alignment: center;
                                                    horizontal-alignment: right;
                                                    width: 100px;
                                                }

                                                // Кнопка видалення рядка
                                                del-rect := Rectangle {
                                                    width: 36px;
                                                    height: 36px;
                                                    y: (parent.height - self.height) / 2;
                                                    border-radius: 4px;
                                                    background: del-touch.has-hover ? Theme.danger-border : transparent;
                                                    animate background { duration: 100ms; easing: ease; }

                                                    Text {
                                                        text: "×";
                                                        font-size: 18px;
                                                        color: del-touch.has-hover ? Theme.danger : Theme.text-muted;
                                                        horizontal-alignment: center;
                                                        vertical-alignment: center;
                                                        animate color { duration: 100ms; easing: ease; }
                                                    }

                                                    del-touch := TouchArea {
                                                        mouse-cursor: pointer;
                                                        clicked => { root.remove-item(i); }
                                                    }
                                                }
                                            }
                                        }

                                        SectionDivider { }
                                    }

                                    // Empty state позицій
                                    if root.items.length == 0 : Rectangle {
                                        height: 80px;
                                        Text {
                                            text: "Позиції відсутні. Натисніть \"+ Додати позицію\".";
                                            color: Theme.text-muted;
                                            font-size: 13px;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }

                                SectionDivider { }

                                // Разом + До сплати (вирівняно праворуч)
                                VerticalLayout {
                                    spacing: 8px;

                                    HorizontalLayout {
                                        alignment: end;
                                        spacing: 32px;
                                        Text {
                                            text: "Разом:";
                                            font-size: 13px;
                                            color: Theme.text-sub;
                                            vertical-alignment: center;
                                        }
                                        Text {
                                            text: root.total-amount + " ₴";
                                            font-size: 15px;
                                            font-weight: 600;
                                            color: Theme.text-main;
                                            vertical-alignment: center;
                                            min-width: 140px;
                                            horizontal-alignment: right;
                                        }
                                    }

                                    SectionDivider { }

                                    HorizontalLayout {
                                        alignment: end;
                                        spacing: 32px;
                                        Text {
                                            text: "До сплати:";
                                            font-size: 15px;
                                            font-weight: 600;
                                            color: Theme.text-main;
                                            vertical-alignment: center;
                                        }
                                        Text {
                                            text: root.total-amount + " ₴";
                                            font-size: 20px;
                                            font-weight: 700;
                                            color: Theme.primary;
                                            vertical-alignment: center;
                                            min-width: 140px;
                                            horizontal-alignment: right;
                                        }
                                    }
                                }

                                SectionDivider { }

                                // Примітки
                                VerticalLayout {
                                    spacing: 4px;
                                    FieldLabel {
                                        text: "Примітки";
                                    }
                                    Rectangle {
                                        height: 80px;
                                        background: Theme.surface;
                                        border-width: 1px;
                                        border-color: Theme.border;
                                        border-radius: 8px;
                                        notes-field := TextEdit {
                                            text: root.act-notes;
                                            wrap: word-wrap;
                                        }
                                    }
                                }
                            }
                        }

                        // ── Секція задач ───────────────────────────────────
                        VerticalLayout {
                            spacing: 12px;

                            HorizontalLayout {
                                alignment: space-between;

                                Text {
                                    text: "Задачі по акту";
                                    font-size: 16px;
                                    font-weight: 600;
                                    color: Theme.text-main;
                                    vertical-alignment: center;
                                }

                                Rectangle {
                                    width: 140px;
                                    height: 32px;
                                    border-radius: 8px;
                                    background: Theme.primary-light;

                                    Text {
                                        text: "+ Додати задачу";
                                        font-size: 12px;
                                        font-weight: 600;
                                        color: Theme.primary;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                    TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => { root.act-task-create-clicked(); }
                                    }
                                }
                            }

                            if root.act-tasks-loading : ProgressIndicator {
                                indeterminate: true;
                            }

                            Rectangle {
                                min-height: 120px;
                                border-radius: 8px;
                                border-width: 1px;
                                border-color: Theme.border;
                                background: Theme.surface;
                                clip: true;

                                VerticalLayout {
                                    spacing: 0;

                                    Rectangle {
                                        height: 36px;
                                        background: Theme.table-header;

                                        HorizontalLayout {
                                            padding-left: 12px;
                                            padding-right: 12px;
                                            Text { text: "Назва";      color: Theme.text-sub; font-size: 12px; font-weight: 500; horizontal-stretch: 3; vertical-alignment: center; }
                                            Text { text: "Пріоритет";  color: Theme.text-sub; font-size: 12px; font-weight: 500; width: 110px; vertical-alignment: center; }
                                            Text { text: "Дедлайн";    color: Theme.text-sub; font-size: 12px; font-weight: 500; width: 120px; vertical-alignment: center; }
                                            Text { text: "Нагад.";     color: Theme.text-sub; font-size: 12px; font-weight: 500; width: 120px; vertical-alignment: center; }
                                            Text { text: "Статус";     color: Theme.text-sub; font-size: 12px; font-weight: 500; width: 100px; vertical-alignment: center; }
                                            Text { text: "Дії";        color: Theme.text-sub; font-size: 12px; font-weight: 500; width: 180px; vertical-alignment: center; }
                                        }
                                    }

                                    ListView {
                                        vertical-stretch: 1;

                                        for row[i] in root.act-task-rows : Rectangle {
                                            property <string> raw-status: row.status;
                                            property <string> raw-priority: row.priority;
                                            property <color> status-color:
                                                raw-status == "done"        ? Theme.success :
                                                raw-status == "in_progress" ? Theme.primary :
                                                raw-status == "cancelled"   ? Theme.text-muted :
                                                Theme.warning;
                                            property <color> status-bg:
                                                raw-status == "done"        ? Theme.success.with-alpha(0.12) :
                                                raw-status == "in_progress" ? Theme.primary.with-alpha(0.10) :
                                                raw-status == "cancelled"   ? Theme.text-muted.with-alpha(0.12) :
                                                Theme.warning.with-alpha(0.12);
                                            property <color> priority-color:
                                                raw-priority == "critical" ? Theme.priority-critical :
                                                raw-priority == "high"     ? Theme.priority-high :
                                                raw-priority == "normal"   ? Theme.primary :
                                                Theme.text-muted;
                                            property <color> priority-bg:
                                                raw-priority == "critical" ? Theme.priority-critical.with-alpha(0.10) :
                                                raw-priority == "high"     ? Theme.priority-high.with-alpha(0.10) :
                                                raw-priority == "normal"   ? Theme.primary.with-alpha(0.10) :
                                                Theme.text-muted.with-alpha(0.10);

                                            height: 48px;
                                            background: row-touch.has-hover ? Theme.row-hover : Theme.surface;

                                            HorizontalLayout {
                                                padding-left: 12px;
                                                padding-right: 12px;

                                                Text {
                                                    text: row.title;
                                                    color: Theme.text-main;
                                                    font-size: 13px;
                                                    font-weight: 500;
                                                    horizontal-stretch: 3;
                                                    vertical-alignment: center;
                                                    overflow: elide;
                                                }

                                                Rectangle {
                                                    width: 110px;
                                                    Rectangle {
                                                        width: 90px;
                                                        height: 22px;
                                                        y: (parent.height - self.height) / 2;
                                                        border-radius: 11px;
                                                        background: priority-bg;
                                                        Text {
                                                            text: row.priority-label;
                                                            color: priority-color;
                                                            font-size: 11px;
                                                            font-weight: 500;
                                                            horizontal-alignment: center;
                                                            vertical-alignment: center;
                                                        }
                                                    }
                                                }

                                                Text { text: row.due-date; color: Theme.text-sub; font-size: 13px; width: 120px; vertical-alignment: center; overflow: elide; }
                                                Text { text: row.reminder; color: Theme.text-sub; font-size: 13px; width: 120px; vertical-alignment: center; overflow: elide; }

                                                Rectangle {
                                                    width: 100px;
                                                    Rectangle {
                                                        width: 84px;
                                                        height: 22px;
                                                        y: (parent.height - self.height) / 2;
                                                        border-radius: 11px;
                                                        background: status-bg;
                                                        Text {
                                                            text: row.status-label;
                                                            color: status-color;
                                                            font-size: 11px;
                                                            font-weight: 500;
                                                            horizontal-alignment: center;
                                                            vertical-alignment: center;
                                                        }
                                                    }
                                                }

                                                HorizontalLayout {
                                                    width: 180px;
                                                    spacing: 8px;

                                                    Rectangle {
                                                        background: Theme.surface;
                                                        border-width: 1px;
                                                        border-color: Theme.border;
                                                        border-radius: 6px;
                                                        height: 28px;
                                                        width: 60px;
                                                        Text { text: "✎"; color: Theme.text-main; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
                                                        TouchArea {
                                                            mouse-cursor: pointer;
                                                            clicked => {
                                                                root.act-task-edit-clicked(row.id);
                                                            }
                                                        }
                                                    }

                                                    Rectangle {
                                                        background: Theme.primary;
                                                        border-radius: 6px;
                                                        height: 28px;
                                                        width: 56px;
                                                        Text { text: "✓"; color: Theme.text-white; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
                                                        TouchArea {
                                                            mouse-cursor: pointer;
                                                            clicked => {
                                                                root.act-task-toggle-status-clicked(row.id);
                                                            }
                                                        }
                                                    }

                                                    Rectangle {
                                                        background: Theme.danger-light;
                                                        border-radius: 6px;
                                                        border-width: 1px;
                                                        border-color: Theme.danger-border;
                                                        height: 28px;
                                                        width: 48px;
                                                        Text { text: "×"; color: Theme.danger; font-size: 14px; horizontal-alignment: center; vertical-alignment: center; }
                                                        TouchArea {
                                                            mouse-cursor: pointer;
                                                            clicked => {
                                                                root.act-task-delete-clicked(row.id);
                                                            }
                                                        }
                                                    }
                                                }
                                            }

                                            row-touch := TouchArea { }
                                        }
                                    }

                                    if !root.act-tasks-loading && root.act-task-rows.length == 0 : Rectangle {
                                        height: 72px;
                                        background: Theme.surface;
                                        Text {
                                            text: "У цьому акті ще немає задач";
                                            color: Theme.text-muted;
                                            font-size: 13px;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                // ──────────────────────────────────────────────────────────
                //  ПРАВИЙ СТОВПЕЦЬ: статус + підказка (фіксована ширина)
                // ──────────────────────────────────────────────────────────
                Rectangle {
                    width: 392px;
                    background: Theme.bg;

                    VerticalLayout {
                        padding-top: 32px;
                        padding-bottom: 32px;
                        padding-left: 0px;
                        padding-right: 32px;
                        spacing: 16px;
                        alignment: start;

                        // ── Картка статусу ─────────────────────────────────
                        //
                        // act-status: 0=Чернетка, 1=Виставлений, 2=Підписаний, 3=Оплачений
                        // При натисканні StatusOption → оновлює act-status.
                        // Кнопка "Зберегти" читає act-status і викликає відповідний callback.
                        Rectangle {
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: Theme.border;
                            background: Theme.surface;
                            drop-shadow-color: #0000000D;
                            drop-shadow-blur: 8px;
                            drop-shadow-offset-y: 2px;

                            VerticalLayout {
                                padding: 24px;
                                spacing: 10px;

                                Text {
                                    text: "Статус акту";
                                    font-size: 15px;
                                    font-weight: 600;
                                    color: Theme.text-main;
                                }

                                StatusOption {
                                    title: "Чернетка";
                                    subtitle: "Не відправлений";
                                    selected: root.act-status == 0;
                                    accent: Theme.text-sub;
                                    clicked => { root.act-status = 0; }
                                }
                                StatusOption {
                                    title: "Виставлений";
                                    subtitle: "Очікує підпису";
                                    selected: root.act-status == 1;
                                    accent: Theme.warning;
                                    clicked => { root.act-status = 1; }
                                }
                                StatusOption {
                                    title: "Підписаний";
                                    subtitle: "Підписаний сторонами";
                                    selected: root.act-status == 2;
                                    accent: Theme.primary;
                                    clicked => { root.act-status = 2; }
                                }
                                StatusOption {
                                    title: "Оплачений";
                                    subtitle: "Кошти отримані";
                                    selected: root.act-status == 3;
                                    accent: Theme.success;
                                    clicked => { root.act-status = 3; }
                                }
                            }
                        }

                        // ── Картка підказки ────────────────────────────────
                        Rectangle {
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: Theme.border;
                            background: Theme.surface;
                            drop-shadow-color: #0000000D;
                            drop-shadow-blur: 8px;
                            drop-shadow-offset-y: 2px;

                            VerticalLayout {
                                spacing: 0;

                                // Шапка підказки
                                Rectangle {
                                    height: 44px;
                                    border-radius: 12px;
                                    background: Theme.primary-light;

                                    Text {
                                        x: 20px;
                                        y: (parent.height - self.height) / 2;
                                        text: "ℹ Підказка";
                                        font-size: 13px;
                                        font-weight: 600;
                                        color: Theme.primary;
                                    }
                                }

                                // Пункти підказки
                                VerticalLayout {
                                    padding: 16px;
                                    spacing: 12px;

                                    HorizontalLayout {
                                        spacing: 10px;
                                        alignment: start;
                                        Rectangle { width: 6px; height: 6px; y: 4px; border-radius: 3px; background: Theme.primary; }
                                        Text { text: "Контрагент та сума є обов'язковими"; font-size: 12px; color: Theme.text-main; wrap: word-wrap; horizontal-stretch: 1; }
                                    }
                                    HorizontalLayout {
                                        spacing: 10px;
                                        alignment: start;
                                        Rectangle { width: 6px; height: 6px; y: 4px; border-radius: 3px; background: Theme.primary; }
                                        Text { text: "«Виставлений» — надішліть PDF клієнту"; font-size: 12px; color: Theme.text-main; wrap: word-wrap; horizontal-stretch: 1; }
                                    }
                                    HorizontalLayout {
                                        spacing: 10px;
                                        alignment: start;
                                        Rectangle { width: 6px; height: 6px; y: 4px; border-radius: 3px; background: Theme.primary; }
                                        Text { text: "«Підписаний» — документ підтверджено"; font-size: 12px; color: Theme.text-main; wrap: word-wrap; horizontal-stretch: 1; }
                                    }
                                    HorizontalLayout {
                                        spacing: 10px;
                                        alignment: start;
                                        Rectangle { width: 6px; height: 6px; y: 4px; border-radius: 3px; background: Theme.primary; }
                                        Text { text: "«Оплачений» — кошти отримано"; font-size: 12px; color: Theme.text-main; wrap: word-wrap; horizontal-stretch: 1; }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
