// Компонент: список актів виконаних робіт
//
// Структура аналогічна CounterpartyList:
//   - Topbar 64px (заголовок + кнопка створення)
//   - Рядок фільтру за статусом
//   - Таблиця 40px header + 52px рядки + hover
//   - Status badge з кольором за статусом
//   - Панель дій з'являється при виборі рядка

import { Theme } from "../theme.slint";
import { ProgressIndicator, ListView } from "std-widgets.slint";
import { StatCard } from "../components/stat_card.slint";
import { StatusBadge } from "../components/status_badge.slint";

export component ActList {

    // ── Вхідні дані (Rust → Slint) ─────────────────────────────────────────
    in property <[[StandardListViewItem]]> rows;
    in property <[string]>                 row-ids;
    // "draft" | "issued" | "signed" | "paid" — для badge-кольорів
    in property <[string]>                 row-statuses;
    in property <bool>                     loading: false;
    in property <[int]>                    status-counts: [0, 0, 0, 0, 0];

    // ── KPI дані (Rust → Slint) ──────────────────────────────────────────────
    in property <int>    kpi-acts-month: 0;
    in property <string> kpi-revenue: "0 ₴";
    in property <string> kpi-unpaid: "0 ₴";
    in property <int>    kpi-overdue: 0;

    // ── Колбеки (Slint → Rust) ──────────────────────────────────────────────
    // 0=Усі, 1=Чернетка, 2=Виставлено, 3=Підписано, 4=Оплачено
    callback status-filter-changed(int);
    callback search-changed(string);
    callback row-selected(string);
    callback create-clicked();
    callback advance-status-clicked(string);
    callback edit-clicked(string);
    callback pdf-clicked(string);

    // ── Внутрішній стан ─────────────────────────────────────────────────────
    private property <int>    selected-row: -1;
    private property <string> selected-id: "";
    private property <string> selected-status: "";
    private property <string> selected-number: "";
    private property <int>    active-tab: 0;

    min-width: 600px;
    min-height: 400px;

    VerticalLayout {
        spacing: 0;
        padding: 0;

        // ── Topbar (64px, білий, з нижньою межею) ───────────────────────────
        Rectangle {
            height: 64px;
            background: Theme.surface;

            HorizontalLayout {
                padding-left: 32px;
                padding-right: 32px;
                spacing: 16px;

                Text {
                    text: "Акти";
                    font-size: 18px;
                    font-weight: 600;
                    color: Theme.text-main;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                new-btn := Rectangle {
                    background: Theme.primary;
                    border-radius: 8px;
                    height: 36px;
                    width: 140px;
                    y: (parent.height - self.height) / 2;

                    Text {
                        text: "+ Новий акт";
                        color: Theme.text-white;
                        font-size: 13px;
                        font-weight: 500;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.create-clicked(); }
                    }
                }
            }

            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: Theme.border;
            }
        }

        // ── Вкладки статусів (44px) ──────────────────────────────────────────
        Rectangle {
            height: 44px;
            background: Theme.surface;

            property <[string]> _tab-names: ["Всі", "Чернетка", "Виставлені", "Підписані", "Оплачені"];

            HorizontalLayout {
                alignment: start;
                padding-left: 32px;
                spacing: 0;

                for tab-name[ti] in _tab-names : Rectangle {
                    property <bool> is-active: root.active-tab == ti;
                    property <int>  tab-count: ti < root.status-counts.length
                        ? root.status-counts[ti] : 0;

                    if is-active : Rectangle {
                        y: parent.height - 2px;
                        height: 2px;
                        background: Theme.primary;
                    }

                    HorizontalLayout {
                        alignment: center;
                        spacing: 4px;
                        padding-left: 12px;
                        padding-right: 12px;

                        Text {
                            text: tab-count > 0
                                ? tab-name + " (" + tab-count + ")"
                                : tab-name;
                            font-size: 13px;
                            font-weight: is-active ? 600 : 400;
                            color: is-active ? Theme.primary : Theme.text-sub;
                            vertical-alignment: center;
                        }
                    }

                    TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.active-tab = ti;
                            root.status-filter-changed(ti);
                        }
                    }
                }
            }

            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: Theme.border;
            }
        }

        // ── Основний контент ─────────────────────────────────────────────────
        Rectangle {
            background: Theme.bg;
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: 24px;
                padding-left: 32px;
                padding-right: 32px;
                padding-bottom: 24px;
                spacing: 16px;

                // ── KPI картки ───────────────────────────────────────────────
                HorizontalLayout {
                    height: 84px;
                    spacing: 12px;
                    vertical-stretch: 0;

                    StatCard {
                        accent: Theme.primary;
                        value: root.kpi-acts-month + "";
                        label: "Актів за місяць";
                        secondary: "поточний місяць";
                    }

                    StatCard {
                        accent: Theme.success;
                        value: root.kpi-revenue;
                        label: "Виручка";
                        secondary: "оплачені цього місяця";
                    }

                    StatCard {
                        accent: Theme.warning;
                        value: root.kpi-unpaid;
                        label: "Неоплачено";
                        secondary: "виставлені та підписані";
                    }

                    StatCard {
                        accent: root.kpi-overdue > 0 ? Theme.danger : Theme.text-muted;
                        value: root.kpi-overdue + "";
                        label: "Прострочено";
                        secondary: "більше 30 днів";
                    }
                }

                // ── Пошук ────────────────────────────────────────────────────
                HorizontalLayout {
                    height: 40px;
                    vertical-stretch: 0;

                    search-rect := Rectangle {
                        background: Theme.surface;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.border;
                        horizontal-stretch: 1;
                        clip: true;

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;

                            search-input := TextInput {
                                vertical-alignment: center;
                                font-size: 13px;
                                color: Theme.text-main;
                                edited => { root.search-changed(search-input.text); }
                            }
                        }

                        if search-input.text == "" : Text {
                            x: 12px;
                            height: parent.height;
                            width: parent.width - 24px;
                            text: "🔎  Пошук за номером або контрагентом...";
                            color: Theme.text-muted;
                            font-size: 13px;
                            vertical-alignment: center;
                        }
                    }
                }

                if root.loading : ProgressIndicator {
                    indeterminate: true;
                    vertical-stretch: 0;
                }

                // ── Таблиця ──────────────────────────────────────────────────
                Rectangle {
                    vertical-stretch: 1;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: Theme.border;
                    clip: true;

                    VerticalLayout {
                        spacing: 0;

                        // Заголовок таблиці
                        Rectangle {
                            height: 40px;
                            background: Theme.table-header;

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;

                                Text { text: "Номер";      color: Theme.text-sub; font-size: 12px; font-weight: 500; horizontal-stretch: 2; vertical-alignment: center; }
                                Text { text: "Дата";       color: Theme.text-sub; font-size: 12px; font-weight: 500; horizontal-stretch: 1; vertical-alignment: center; }
                                Text { text: "Контрагент"; color: Theme.text-sub; font-size: 12px; font-weight: 500; horizontal-stretch: 3; vertical-alignment: center; }
                                Text { text: "Сума, ₴";    color: Theme.text-sub; font-size: 12px; font-weight: 500; horizontal-stretch: 1; vertical-alignment: center; }
                                Text { text: "Статус";     color: Theme.text-sub; font-size: 12px; font-weight: 500; width: 100px; vertical-alignment: center; }
                                Text { text: "Дії";        color: Theme.text-sub; font-size: 12px; font-weight: 500; width: 120px; vertical-alignment: center; }
                            }
                        }

                        // Порожній стан — коли немає актів і не завантажується
                        if !root.loading && root.rows.length == 0 : Rectangle {
                            vertical-stretch: 1;
                            background: Theme.surface;

                            VerticalLayout {
                                alignment: center;
                                spacing: 8px;

                                Text {
                                    text: "📄";
                                    font-size: 32px;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: "Актів ще немає";
                                    font-size: 15px;
                                    font-weight: 500;
                                    color: Theme.text-sub;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: "Натисніть «+ Новий акт» щоб створити перший";
                                    font-size: 13px;
                                    color: Theme.text-muted;
                                    horizontal-alignment: center;
                                }
                            }
                        }

                        // Рядки даних
                        ListView {
                            vertical-stretch: 1;

                            for row[i] in root.rows : Rectangle {
                                // Визначаємо raw-статус для badge-кольору
                                property <string> raw-status: i < root.row-statuses.length
                                    ? root.row-statuses[i] : "draft";
                                // Колір тексту badge
                                property <color> badge-color:
                                    raw-status == "paid"   ? Theme.success  :
                                    raw-status == "signed" ? Theme.primary  :
                                    raw-status == "issued" ? Theme.warning  :
                                    Theme.text-muted;
                                // Фон badge (12% прозорість відповідного кольору)
                                property <color> badge-bg:
                                    raw-status == "paid"   ? Theme.success.with-alpha(0.12) :
                                    raw-status == "signed" ? Theme.primary.with-alpha(0.10) :
                                    raw-status == "issued" ? Theme.warning.with-alpha(0.12) :
                                    Theme.text-muted.with-alpha(0.12);

                                height: 52px;
                                background: root.selected-row == i
                                    ? Theme.row-selected
                                    : (row-touch.has-hover
                                        ? Theme.row-hover
                                        : (Math.mod(i, 2) == 0 ? Theme.surface : Theme.row-stripe));
                                border-width: 1px;
                                border-color: Theme.border;
                                animate background { duration: 80ms; easing: ease; }

                                HorizontalLayout {
                                    padding-left: 15px;
                                    padding-right: 15px;

                                    // Номер акту
                                    Text {
                                        text: row[0].text;
                                        color: Theme.text-main;
                                        font-size: 13px;
                                        font-weight: 500;
                                        horizontal-stretch: 2;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                    // Дата
                                    Text {
                                        text: row[1].text;
                                        color: Theme.text-sub;
                                        font-size: 13px;
                                        horizontal-stretch: 1;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                    // Контрагент
                                    Text {
                                        text: row[2].text;
                                        color: Theme.text-sub;
                                        font-size: 13px;
                                        horizontal-stretch: 3;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                    // Сума — виділена жирним
                                    Text {
                                        text: row[3].text;
                                        color: Theme.text-main;
                                        font-size: 13px;
                                        font-weight: 600;
                                        horizontal-stretch: 1;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                    // Status badge
                                    Rectangle {
                                        width: 100px;
                                        StatusBadge {
                                            y: (parent.height - self.height) / 2;
                                            label: row[4].text;
                                            badge-color: badge-color;
                                            badge-bg: badge-bg;
                                        }
                                    }

                                    // Дії — PDF кнопка
                                    Rectangle {
                                        width: 120px;

                                        HorizontalLayout {
                                            alignment: start;
                                            padding-left: 4px;
                                            spacing: 0;

                                            pdf-btn := Rectangle {
                                                width: 46px;
                                                height: 26px;
                                                y: (parent.height - self.height) / 2;
                                                border-radius: 6px;
                                                background: pdf-btn-touch.has-hover
                                                    ? Theme.primary-light : Theme.btn-action-bg;
                                                animate background { duration: 80ms; }

                                                Text {
                                                    text: "PDF";
                                                    color: Theme.primary;
                                                    font-size: 11px;
                                                    font-weight: 600;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }

                                                pdf-btn-touch := TouchArea {
                                                    mouse-cursor: pointer;
                                                    clicked => {
                                                        if i < root.row-ids.length {
                                                            root.pdf-clicked(root.row-ids[i]);
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }

                                row-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        root.selected-row = i;
                                        if i < root.row-ids.length {
                                            root.selected-id     = root.row-ids[i];
                                            root.selected-status = root.row-statuses[i];
                                            root.selected-number = row[0].text;
                                            root.row-selected(root.row-ids[i]);
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                // ── Панель дій (з'являється при виборі рядка) ───────────────
                if root.selected-row >= 0 : HorizontalLayout {
                    height: 48px;
                    spacing: 8px;
                    vertical-stretch: 0;

                    // Назва вибраного акту
                    Text {
                        text: root.selected-number;
                        color: Theme.text-sub;
                        font-size: 13px;
                        font-weight: 500;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        overflow: elide;
                    }

                    // Кнопка "Редагувати" — вторинний стиль
                    Rectangle {
                        background: Theme.surface;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.border;
                        height: 36px;
                        width: 130px;
                        y: (parent.height - self.height) / 2;

                        Text {
                            text: "✎  Редагувати";
                            color: Theme.text-main;
                            font-size: 13px;
                            font-weight: 500;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                if root.selected-id != "" {
                                    root.edit-clicked(root.selected-id);
                                }
                            }
                        }
                    }

                    // Кнопка "Наступний статус" — синя або сіра (paid = фінал)
                    Rectangle {
                        background: root.selected-status != "paid"
                            ? Theme.primary : Theme.border;
                        border-radius: 8px;
                        height: 36px;
                        width: 180px;
                        y: (parent.height - self.height) / 2;

                        Text {
                            text: "Наступний статус ▶";
                            color: root.selected-status != "paid" ? Theme.text-white : Theme.text-muted;
                            font-size: 13px;
                            font-weight: 500;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        TouchArea {
                            mouse-cursor: root.selected-status != "paid" ? pointer : default;
                            clicked => {
                                if root.selected-id != "" && root.selected-status != "paid" {
                                    root.advance-status-clicked(root.selected-id);
                                    root.selected-row    = -1;
                                    root.selected-id     = "";
                                    root.selected-status = "";
                                    root.selected-number = "";
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
