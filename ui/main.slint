// Головне вікно програми Acta
//
// Архітектура:
//   MainWindow — кореневий компонент, який Rust інстанціює через MainWindow::new()
//   NavItem    — приватний компонент навігаційного елементу (не экспортується)
//
// Навігація: ліва панель з основними розділами, права — контент поточного розділу.
// Перемикання через in-out property <int> current-page.
// Нумерація сторінок: 0=Контрагенти | 1=Документи (акти+накладні) | 3=Платежі | 4=Звіти (заглушка)
// 5=To-Do | 6=Компанії | 7=Календар (заглушка) | 8=Dashboard
// Сторінка 2 не використовується

import { Button, ListView } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { ActRow, InvoiceRow, TaskRow, PaymentRow, FormItemRow, ActStatus } from "structs.slint";
import { DashboardPage, DashboardActRow, DashboardPaymentRow } from "dashboard/dashboard.slint";
import { CounterpartyList } from "counterparties/counterparty_list.slint";
import { CounterpartyForm } from "counterparties/counterparty_form.slint";
import { ActList }          from "acts/act_list.slint";
import { ActForm }          from "acts/act_form.slint";
import { TaskList }         from "tasks/task_list.slint";
import { TaskForm }         from "tasks/task_form.slint";
import { InvoiceList }      from "invoices/invoice_list.slint";
import { InvoiceForm }      from "invoices/invoice_form.slint";
import { CompanyList, CompanyItem } from "companies/company_list.slint";
import { CompanyForm }      from "companies/company_form.slint";
import { PaymentList }      from "payments/payment_list.slint";
import { PaymentForm }      from "payments/payment_form.slint";
import { DocumentList, DocRow } from "documents/document_list.slint";
import { CounterpartyCard, CounterpartyDocSummary, CounterpartyPaymentSummary, CounterpartyContractSummary, CounterpartyTaskSummary } from "counterparties/counterparty_card.slint";
import { ActCard, ActCardItemRow, ActCardTaskRow } from "acts/act_card.slint";
import { SettingsPage, SettingsCategoryRow } from "settings/settings.slint";

global MenuIcons {
    out property <image> dashboard:      @image-url("assets/icons/Home.svg");
    out property <image> acts:           @image-url("assets/icons/Documents.svg");
    out property <image> invoices:       @image-url("assets/icons/Outgoing.svg");
    out property <image> counterparties: @image-url("assets/icons/Counterparties.svg");
    out property <image> payments:       @image-url("assets/icons/Payments.svg");
    out property <image> reports:        @image-url("assets/icons/Chart-Bar.svg");
    out property <image> todo:           @image-url("assets/icons/To-Do.svg");
    out property <image> calendar:       @image-url("assets/icons/Calendar.svg");
    out property <image> settings:       @image-url("assets/icons/Settings.svg");
}

// ── NavItem — елемент бічної навігації ──────────────────────────────────────
//
// active: bool — підсвічує активний розділ синім фоном + білою лівою смужкою.
// label: string — включає emoji, наприклад "📄  Акти"
component NavItem {
    in property <string> label;
    in property <image>  icon;
    in property <bool>   active: false;
    in property <bool>   disabled: false;
    callback clicked;

    height: 36px;
    min-width: 0;

    rect := Rectangle {
        border-radius: Theme.radius-md;
        background: root.active
            ? Theme.sidebar-active
            : ((nav-touch.has-hover && !root.disabled) ? Theme.sidebar-hover : transparent);
        animate background { duration: 120ms; easing: ease; }

        // Ліва акцентна смужка — біла, 3px × 24px, видно лише для активного
        // Позиціонована x=-3 щоб виходити за лівий край rect (sidebar не кліпає)
        if root.active : Rectangle {
            x: -3px;
            y: (parent.height - 22px) / 2;
            width: 3px;
            height: 22px;
            border-radius: 2px;
            background: Theme.sidebar-active-bar;
        }

        HorizontalLayout {
            padding-left: 10px;
            padding-right: 12px;
            spacing: 8px;
            alignment: start;

            Rectangle {
                width: 18px;
                height: 18px;
                y: (parent.height - self.height) / 2;
                background: transparent;
                opacity: root.disabled ? 0.45 : 1.0;

                Image {
                    width: parent.width;
                    height: parent.height;
                    source: root.icon;
                    image-fit: contain;
                    colorize: root.active ? Theme.sidebar-active-icon : Theme.sidebar-icon;
                }
            }

            Text {
                text: root.label;
                font-size: Theme.font-md;
                font-weight: root.active ? 600 : 400;
                color: root.active ? Theme.text-white
                    : (root.disabled ? Theme.sidebar-label : Theme.sidebar-text);
                vertical-alignment: center;
                horizontal-stretch: 1;
                animate color { duration: 150ms; easing: ease; }
            }
        }

        nav-touch := TouchArea {
            enabled: !root.disabled;
            mouse-cursor: root.disabled ? default : pointer;
            clicked => { root.clicked(); }
        }
    }
}

