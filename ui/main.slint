// Головне вікно програми Acta
//
// Архітектура:
//   MainWindow — кореневий компонент, який Rust інстанціює через MainWindow::new()
//   NavItem    — приватний компонент навігаційного елементу (не экспортується)
//
// Навігація: ліва панель з основними розділами, права — контент поточного розділу.
// Перемикання через in-out property <int> current-page.
// Нумерація сторінок: 0=Контрагенти, 1=Акти, 2=Накладні, 3=Платежі, 4=Звіти, 5=To-Do, 6=Компанії, 7=Календар платежів

import { Button, ListView } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { CounterpartyList } from "counterparties/counterparty_list.slint";
import { CounterpartyForm } from "counterparties/counterparty_form.slint";
import { ActList }          from "acts/act_list.slint";
import { ActForm }          from "acts/act_form.slint";
import { TaskList }         from "tasks/task_list.slint";
import { TaskForm }         from "tasks/task_form.slint";
import { InvoiceList }      from "invoices/invoice_list.slint";
import { InvoiceForm }      from "invoices/invoice_form.slint";
import { CompanyList, CompanyItem } from "companies/company_list.slint";
import { CompanyForm }      from "companies/company_form.slint";

// ── NavItem — елемент бічної навігації ──────────────────────────────────────
//
// active: bool — підсвічує активний розділ синім фоном + білою лівою смужкою.
// label: string — включає emoji, наприклад "📄  Акти"
component NavItem {
    in property <string> label;
    in property <bool>   active: false;
    callback clicked;

    height: 36px;
    min-width: 0;

    rect := Rectangle {
        border-radius: 8px;
        background: root.active ? Theme.primary
            : (nav-touch.has-hover ? Theme.sidebar-hover : transparent);
        animate background { duration: 120ms; easing: ease; }

        // Ліва акцентна смужка — біла, 3px × 24px, видно лише для активного
        // Позиціонована x=-3 щоб виходити за лівий край rect (sidebar не кліпає)
        if root.active : Rectangle {
            x: -3px;
            y: (parent.height - 24px) / 2;
            width: 3px;
            height: 24px;
            border-radius: 2px;
            background: #ffffff;
        }

        HorizontalLayout {
            padding-left: 12px;
            padding-right: 12px;

            Text {
                text: root.label;
                font-size: 13px;
                font-weight: root.active ? 500 : 400;
                color: root.active ? #ffffff : Theme.sidebar-text;
                vertical-alignment: center;
                animate color { duration: 150ms; easing: ease; }
            }
        }

        nav-touch := TouchArea {
            mouse-cursor: pointer;
            clicked => { root.clicked(); }
        }
    }
}

// ── MainWindow — головне вікно ───────────────────────────────────────────────
export component MainWindow inherits Window {
    title: "Acta — Управлінський облік";
    min-width:  1100px;
    min-height: 680px;
    preferred-width:  1440px;
    preferred-height: 900px;

    // ── Стан навігації ───────────────────────────────────────────────────────
    // 0=Контрагенти | 1=Акти | 2=Накладні | 3=Платежі | 4=Звіти | 5=To-Do | 6=Компанії | 7=Календар платежів
    in-out property <int> current-page: 0;

    // ── Дані контрагентів ────────────────────────────────────────────────────
    in property <[[StandardListViewItem]]> counterparty-rows;
    in property <[string]>                 counterparty-ids;
    in property <[bool]>                   counterparty-archived;
    in property <bool>                     counterparties-loading: false;
    in property <int>                      counterparty-total-count: 0;
    in property <int>                      counterparty-active-count: 0;
    in property <int>                      counterparty-archived-count: 0;
    in property <string>                   counterparty-pagination-text: "";
    in property <bool>                     counterparty-show-archived: false;
    in property <int>                      counterparty-current-page: 1;
    in property <int>                      counterparty-total-pages: 1;

    // ── Стан форми контрагента ───────────────────────────────────────────────
    in property <bool>   show-cp-form: false;
    in property <bool>   cp-form-is-edit: false;
    in property <string> cp-form-edit-id: "";
    in property <string> cp-form-name: "";
    in property <string> cp-form-edrpou: "";
    in property <string> cp-form-ipn: "";
    in property <string> cp-form-iban: "";
    in property <string> cp-form-phone: "";
    in property <string> cp-form-email: "";
    in property <string> cp-form-address: "";
    in property <string> cp-form-notes: "";

    // ── Дані актів ───────────────────────────────────────────────────────────
    in property <[[StandardListViewItem]]> act-rows;
    in property <[string]>                 act-row-ids;
    in property <[string]>                 act-row-statuses;
    in property <bool>                     acts-loading: false;

    // ── Стан форми акту ──────────────────────────────────────────────────────
    in property <bool>     show-act-form: false;
    in property <bool>     act-form-is-edit: false;
    in property <string>   act-form-number: "";
    in property <string>   act-form-date: "";
    in property <string>   act-form-notes: "";
    in property <int>      act-form-cp-index: 0;
    in property <string>   act-form-edit-id: "";
    in property <string>   act-form-total: "0.00";
    in property <[string]> act-form-cp-names;
    in property <[string]> act-form-cp-ids;
    in property <[string]> act-form-item-descriptions;
    in property <[string]> act-form-item-quantities;
    in property <[string]> act-form-item-units;
    in property <[string]> act-form-item-prices;
    in property <[string]> act-form-item-amounts;
    in property <[[StandardListViewItem]]> act-task-rows;
    in property <[string]>                 act-task-row-ids;
    in property <[string]>                 act-task-row-statuses;
    in property <[string]>                 act-task-row-priorities;
    in property <bool>                     act-tasks-loading: false;

    // ── Дані накладних ──────────────────────────────────────────────────────
    in property <[[StandardListViewItem]]> invoice-rows;
    in property <[string]>                 invoice-row-ids;
    in property <[string]>                 invoice-row-statuses;
    in property <bool>                     invoices-loading: false;

    // ── Стан форми накладної ─────────────────────────────────────────────────
    in property <bool>     show-invoice-form: false;
    in property <bool>     invoice-form-is-edit: false;
    in property <string>   invoice-form-number: "";
    in property <string>   invoice-form-date: "";
    in property <string>   invoice-form-notes: "";
    in property <int>      invoice-form-cp-index: 0;
    in property <string>   invoice-form-edit-id: "";
    in property <string>   invoice-form-total: "0.00";
    in property <[string]> invoice-form-cp-names;
    in property <[string]> invoice-form-cp-ids;
    in property <[string]> invoice-form-item-descriptions;
    in property <[string]> invoice-form-item-quantities;
    in property <[string]> invoice-form-item-units;
    in property <[string]> invoice-form-item-prices;
    in property <[string]> invoice-form-item-amounts;

    // ── Дані задач ─────────────────────────────────────────────────────────
    in property <[[StandardListViewItem]]> task-rows;
    in property <[string]>                 task-row-ids;
    in property <[string]>                 task-row-statuses;
    in property <[string]>                 task-row-priorities;
    in property <bool>                     tasks-loading: false;

    // ── Стан форми задачі ──────────────────────────────────────────────────
    in property <bool>   show-task-form: false;
    in property <bool>   task-form-is-edit: false;
    in property <string> task-form-edit-id: "";
    in property <string> task-form-title: "";
    in property <string> task-form-description: "";
    in property <int>    task-form-priority-index: 1;
    in property <string> task-form-due-date: "";
    in property <string> task-form-reminder-at: "";
    in property <string> task-form-act-id: "";
    in property <int>    task-form-return-page: 5;

    // ── Колбеки контрагентів ─────────────────────────────────────────────────
    callback counterparty-search-changed(string);
    callback counterparty-selected(string);
    callback counterparty-edit-clicked(string);
    callback counterparty-create-clicked();
    callback counterparty-archive-clicked(string);
    callback counterparty-filter-clicked();
    callback counterparty-prev-page-clicked();
    callback counterparty-next-page-clicked();

    // ── Колбеки форми контрагента ────────────────────────────────────────────
    // Параметри: назва, ЄДРПОУ, IBAN, телефон, email, адреса, примітки
    callback cp-form-save(   string, string, string, string, string, string, string, string);
    callback cp-form-update( string, string, string, string, string, string, string, string);
    callback cp-form-cancel();

    // ── Колбеки актів ────────────────────────────────────────────────────────
    callback act-status-filter-changed(int);
    callback act-search-changed(string);
    callback act-selected(string);
    callback act-create-clicked();
    callback act-advance-status-clicked(string);
    callback act-edit-clicked(string);

    // ── Колбеки форми акту ───────────────────────────────────────────────────
    callback act-form-save(string, string, string, string);
    callback act-form-save-draft(string, string, string, string);
    callback act-form-update(string, string, string, string);
    callback act-form-cancel();
    callback act-form-add-item();
    callback act-form-remove-item(int);
    callback act-form-item-changed(int, string, string);
    callback act-task-create-clicked();
    callback act-task-edit-clicked(string);
    callback act-task-toggle-status-clicked(string);
    callback act-task-delete-clicked(string);

    // ── Колбеки накладних ───────────────────────────────────────────────────
    callback invoice-status-filter-changed(int);
    callback invoice-search-changed(string);
    callback invoice-selected(string);
    callback invoice-create-clicked();
    callback invoice-advance-status-clicked(string);
    callback invoice-edit-clicked(string);

    // ── Колбеки форми накладної ──────────────────────────────────────────────
    callback invoice-form-save(string, string, string, string);
    callback invoice-form-update(string, string, string, string);
    callback invoice-form-cancel();
    callback invoice-form-add-item();
    callback invoice-form-remove-item(int);
    callback invoice-form-item-changed(int, string, string);

    // ── Колбеки задач ──────────────────────────────────────────────────────
    callback task-search-changed(string);
    callback task-selected(string);
    callback task-create-clicked();
    callback task-toggle-status-clicked(string);
    callback task-delete-clicked(string);
    callback task-edit-clicked(string);

    // ── Колбеки форми задачі ────────────────────────────────────────────────
    callback task-form-save(string, string, int, string, string);
    callback task-form-update(string, string, int, string, string);
    callback task-form-cancel();

    // ── Активна компанія ─────────────────────────────────────────────────────
    in property <string>          active-company-name: "Оберіть компанію";
    in property <string>          active-company-id: "";
    in property <string>          active-company-subtitle: "Оберіть компанію для роботи";
    in-out property <bool>        show-company-picker: false;
    callback switch-company();

    // ── Дані сторінки компаній ───────────────────────────────────────────────
    in property <[CompanyItem]>   company-rows;
    in property <bool>            companies-loading: false;

    // ── Стан форми компанії ──────────────────────────────────────────────────
    in property <bool>   show-company-form: false;
    in property <bool>   company-form-is-edit: false;
    in property <string> company-form-edit-id: "";
    in property <string> company-form-name: "";
    in property <string> company-form-edrpou: "";
    in property <string> company-form-iban: "";
    in property <string> company-form-legal-address: "";
    in property <string> company-form-director: "";
    in property <string> company-form-accountant: "";
    in property <bool>   company-form-is-vat: false;

    // ── Колбеки компаній ─────────────────────────────────────────────────────
    callback company-add-clicked();
    callback company-edit-clicked(string);
    callback company-archive-clicked(string);
    callback company-select-clicked(string);
    // Параметри: назва, ЄДРПОУ, IBAN, адреса, директор, бухгалтер, ПДВ
    callback company-form-save(string, string, string, string, string, string, bool);
    callback company-form-update(string, string, string, string, string, string, bool);
    callback company-form-cancel();

    // ── Toast-сповіщення ─────────────────────────────────────────────────────
    // Rust встановлює message → toast з'являється, через 3с Rust очищає.
    // in-out: Slint може прибрати кнопкою ×, Rust може теж.
    in-out property <string> toast-message: "";
    in property <bool>       toast-is-error: false;

    // ── Розмітка ─────────────────────────────────────────────────────────────
    // Rectangle-обгортка потрібна щоб накладати toast overlay поверх layout.
    Rectangle {

    HorizontalLayout {


        // ══ Бічна панель навігації (220px) ══════════════════════════════════
        Rectangle {
            width: 220px;
            background: Theme.sidebar-bg;
            border-width: 1px;
            border-color: Theme.sidebar-border;

            VerticalLayout {
                spacing: 0;
                padding: 0;

                // ── Логотип + switcher блок ────────────────────────────────
                Rectangle {
                    height: 76px;

                    Text {
                        x: 20px;
                        y: 16px;
                        text: "Acta";
                        font-size: 20px;
                        font-weight: 600;
                        color: #ffffff;
                    }

                    Text {
                        x: 20px;
                        y: 40px;
                        text: "Управлінський облік";
                        font-size: 11px;
                        color: Theme.sidebar-text-muted;
                    }
                }

                // ── Перемикач активної компанії ────────────────────────────
                Rectangle {
                    height: 64px;
                    vertical-stretch: 0;

                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        alignment: center;

                        company-btn := Rectangle {
                            height: 52px;
                            border-radius: 8px;
                            background: company-touch.has-hover ? Theme.sidebar-switcher-hover : Theme.sidebar-switcher-bg;
                            horizontal-stretch: 1;
                            animate background { duration: 100ms; }

                            company-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.switch-company(); }

                                HorizontalLayout {
                                    padding-left: 8px;
                                    padding-right: 8px;
                                    spacing: 8px;
                                    alignment: center;

                                    Rectangle {
                                        width: 32px;
                                        height: 32px;
                                        border-radius: 16px;
                                        background: Theme.primary;

                                        Text {
                                            text: "ФІ";
                                            color: #ffffff;
                                            font-size: 11px;
                                            font-weight: 600;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }

                                    VerticalLayout {
                                        horizontal-stretch: 1;
                                        spacing: 1px;
                                        alignment: center;

                                        Text {
                                            text: root.active-company-name;
                                            font-size: 12px;
                                            color: #F6F8FC;
                                            overflow: elide;
                                        }
                                        Text {
                                            text: root.active-company-subtitle;
                                            font-size: 10px;
                                            color: Theme.sidebar-text-muted;
                                            overflow: elide;
                                        }
                                    }

                                    Text {
                                        text: "▾";
                                        font-size: 10px;
                                        color: Theme.sidebar-text-muted;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }

                Rectangle {
                    height: 1px;
                    x: 20px;
                    width: 180px;
                    background: Theme.sidebar-border;
                    vertical-stretch: 0;
                }

                // ── Навігаційні пункти (з відступами 12px з боків, 8px між) ──
                VerticalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    padding-top: 12px;
                    spacing: 8px;
                    vertical-stretch: 0;

                    NavItem {
                        label: "📄  Акти";
                        active: root.current-page == 1;
                        clicked => { root.current-page = 1; }
                    }
                    NavItem {
                        label: "📦  Накладні";
                        active: root.current-page == 2;
                        clicked => { root.current-page = 2; }
                    }
                    NavItem {
                        label: "👥  Контрагенти";
                        active: root.current-page == 0;
                        clicked => { root.current-page = 0; }
                    }
                    NavItem {
                        label: "💳  Платежі";
                        active: root.current-page == 3;
                        clicked => { root.current-page = 3; }
                    }
                    NavItem {
                        label: "✅  To-Do";
                        active: root.current-page == 5;
                        clicked => { root.current-page = 5; }
                    }
                    NavItem {
                        label: "📊  Звіти";
                        active: root.current-page == 4;
                        clicked => { root.current-page = 4; }
                    }
                    NavItem {
                        label: "📅  Календар платежів";
                        active: root.current-page == 7;
                        clicked => { root.current-page = 7; }
                    }
                }

                // Розпірка — штовхає нижній блок до дна
                Rectangle { vertical-stretch: 1; }

                // ── Нижня секція: розділювач + Налаштування ──────────────────
                // HorizontalLayout для вирівняного розділювача (x=20, ширина 180px)
                HorizontalLayout {
                    height: 1px;
                    padding-left: 20px;
                    padding-right: 20px;
                    vertical-stretch: 0;

                    Rectangle {
                        background: Theme.border;
                    }
                }

                Rectangle {
                    height: 34px;
                    vertical-stretch: 0;

                    Text {
                        x: 20px;
                        height: parent.height;
                        text: "⚙️  Налаштування";
                        font-size: 13px;
                        color: Theme.sidebar-text-muted;
                        vertical-alignment: center;
                    }
                }

                Rectangle { height: 12px; vertical-stretch: 0; }
            }
        }

        // ══ Область контенту ════════════════════════════════════════════════
        Rectangle {
            background: Theme.bg;

            // ── Сторінка 0: Контрагенти — список ────────────────────────────
            if root.current-page == 0 && !root.show-cp-form : CounterpartyList {
                rows:             root.counterparty-rows;
                row-ids:          root.counterparty-ids;
                row-archived:     root.counterparty-archived;
                loading:          root.counterparties-loading;
                total-count:      root.counterparty-total-count;
                active-count:     root.counterparty-active-count;
                archived-count:   root.counterparty-archived-count;
                pagination-text:  root.counterparty-pagination-text;
                show-archived:    root.counterparty-show-archived;
                current-page:     root.counterparty-current-page;
                total-pages:      root.counterparty-total-pages;

                search-changed(q)   => { root.counterparty-search-changed(q); }
                row-selected(id)    => { root.counterparty-selected(id); }
                edit-clicked(id)    => { root.counterparty-edit-clicked(id); }
                create-clicked      => { root.counterparty-create-clicked(); }
                archive-clicked(id) => { root.counterparty-archive-clicked(id); }
                filter-clicked      => { root.counterparty-filter-clicked(); }
                prev-page-clicked   => { root.counterparty-prev-page-clicked(); }
                next-page-clicked   => { root.counterparty-next-page-clicked(); }
            }

            // ── Сторінка 0: Контрагенти — форма ─────────────────────────────
            if root.current-page == 0 && root.show-cp-form : CounterpartyForm {
                is-edit-mode: root.cp-form-is-edit;
                cp-edit-id:   root.cp-form-edit-id;
                cp-name:      root.cp-form-name;
                cp-edrpou:    root.cp-form-edrpou;
                cp-ipn:       root.cp-form-ipn;
                cp-iban:      root.cp-form-iban;
                cp-phone:     root.cp-form-phone;
                cp-email:     root.cp-form-email;
                cp-address:   root.cp-form-address;
                cp-notes:     root.cp-form-notes;

                save(nm, ed, ip, ib, ph, em, ad, nt)    => { root.cp-form-save(nm, ed, ip, ib, ph, em, ad, nt); }
                update(nm, ed, ip, ib, ph, em, ad, nt)  => { root.cp-form-update(nm, ed, ip, ib, ph, em, ad, nt); }
                cancel                              => { root.cp-form-cancel(); }
            }

            // ── Сторінка 1: Акти — список ────────────────────────────────────
            if root.current-page == 1 && !root.show-act-form : ActList {
                rows:             root.act-rows;
                row-ids:          root.act-row-ids;
                row-statuses:     root.act-row-statuses;
                loading:          root.acts-loading;

                status-filter-changed(i)    => { root.act-status-filter-changed(i); }
                search-changed(q)           => { root.act-search-changed(q); }
                row-selected(id)            => { root.act-selected(id); }
                create-clicked              => { root.act-create-clicked(); }
                advance-status-clicked(id)  => { root.act-advance-status-clicked(id); }
                edit-clicked(id)            => { root.act-edit-clicked(id); }
            }

            // ── Сторінка 1: Акти — форма ─────────────────────────────────────
            if root.current-page == 1 && root.show-act-form : ActForm {
                act-number:           root.act-form-number;
                act-date:             root.act-form-date;
                act-notes:            root.act-form-notes;
                act-cp-index:         root.act-form-cp-index;
                act-edit-id:          root.act-form-edit-id;
                total-amount:         root.act-form-total;
                is-edit-mode:         root.act-form-is-edit;
                counterparty-names:   root.act-form-cp-names;
                counterparty-ids:     root.act-form-cp-ids;
                item-descriptions:    root.act-form-item-descriptions;
                item-quantities:      root.act-form-item-quantities;
                item-units:           root.act-form-item-units;
                item-prices:          root.act-form-item-prices;
                item-amounts:         root.act-form-item-amounts;
                act-task-rows:        root.act-task-rows;
                act-task-row-ids:     root.act-task-row-ids;
                act-task-row-statuses: root.act-task-row-statuses;
                act-task-row-priorities: root.act-task-row-priorities;
                act-tasks-loading:    root.act-tasks-loading;

                save(n, d, c, notes)       => { root.act-form-save(n, d, c, notes); }
                save-draft(n, d, c, notes) => { root.act-form-save-draft(n, d, c, notes); }
                update(n, d, c, notes)     => { root.act-form-update(n, d, c, notes); }
                cancel                     => { root.act-form-cancel(); }
                add-item                   => { root.act-form-add-item(); }
                remove-item(i)             => { root.act-form-remove-item(i); }
                item-changed(idx, fld, val) => { root.act-form-item-changed(idx, fld, val); }
                act-task-create-clicked    => { root.act-task-create-clicked(); }
                act-task-edit-clicked(id)  => { root.act-task-edit-clicked(id); }
                act-task-toggle-status-clicked(id) => { root.act-task-toggle-status-clicked(id); }
                act-task-delete-clicked(id) => { root.act-task-delete-clicked(id); }
            }

            // ── Сторінка 5: To-Do — список ────────────────────────────────
            if root.current-page == 5 && !root.show-task-form : TaskList {
                rows:             root.task-rows;
                row-ids:          root.task-row-ids;
                row-statuses:     root.task-row-statuses;
                row-priorities:   root.task-row-priorities;
                loading:          root.tasks-loading;

                search-changed(q)         => { root.task-search-changed(q); }
                row-selected(id)          => { root.task-selected(id); }
                create-clicked            => { root.task-create-clicked(); }
                toggle-status-clicked(id) => { root.task-toggle-status-clicked(id); }
                delete-clicked(id)        => { root.task-delete-clicked(id); }
                edit-clicked(id)          => { root.task-edit-clicked(id); }
            }

            // ── Сторінка 5: To-Do — форма ─────────────────────────────────
            if root.current-page == 5 && root.show-task-form : TaskForm {
                is-edit-mode:           root.task-form-is-edit;
                task-edit-id:           root.task-form-edit-id;
                task-title:             root.task-form-title;
                task-description:       root.task-form-description;
                task-priority-index:    root.task-form-priority-index;
                task-due-date:          root.task-form-due-date;
                task-reminder-at:       root.task-form-reminder-at;
                task-act-id:            root.task-form-act-id;

                save(t, d, p, due, rem)   => { root.task-form-save(t, d, p, due, rem); }
                update(t, d, p, due, rem) => { root.task-form-update(t, d, p, due, rem); }
                cancel                    => { root.task-form-cancel(); }
            }

            // ── Сторінка 6: Компанії — список ────────────────────────────
            if root.current-page == 6 && !root.show-company-form : CompanyList {
                companies:   root.company-rows;
                loading:     root.companies-loading;

                add          => { root.company-add-clicked(); }
                edit(id)     => { root.company-edit-clicked(id); }
                archive(id)  => { root.company-archive-clicked(id); }
                select(id)   => { root.company-select-clicked(id); }
            }

            // ── Сторінка 6: Компанії — форма ─────────────────────────────
            if root.current-page == 6 && root.show-company-form : CompanyForm {
                is-edit:           root.company-form-is-edit;
                edit-id:           root.company-form-edit-id;
                form-name:         root.company-form-name;
                form-edrpou:       root.company-form-edrpou;
                form-iban:         root.company-form-iban;
                form-legal-address: root.company-form-legal-address;
                form-director-name: root.company-form-director;
                form-accountant-name: root.company-form-accountant;
                form-is-vat-payer: root.company-form-is-vat;

                save(nm, ed, ib, ad, dr, ac, vt)   => { root.company-form-save(nm, ed, ib, ad, dr, ac, vt); }
                update(nm, ed, ib, ad, dr, ac, vt) => { root.company-form-update(nm, ed, ib, ad, dr, ac, vt); }
                cancel                              => { root.company-form-cancel(); }
            }

            // ── Заглушки для майбутніх сторінок ──────────────────────────

            // ── Сторінка 2: Накладні — список ───────────────────────────────
            if root.current-page == 2 && !root.show-invoice-form : InvoiceList {
                rows:             root.invoice-rows;
                row-ids:          root.invoice-row-ids;
                row-statuses:     root.invoice-row-statuses;
                loading:          root.invoices-loading;

                status-filter-changed(i)    => { root.invoice-status-filter-changed(i); }
                search-changed(q)           => { root.invoice-search-changed(q); }
                row-selected(id)            => { root.invoice-selected(id); }
                create-clicked              => { root.invoice-create-clicked(); }
                advance-status-clicked(id)  => { root.invoice-advance-status-clicked(id); }
                edit-clicked(id)            => { root.invoice-edit-clicked(id); }
            }

            // ── Сторінка 2: Накладні — форма ─────────────────────────────────
            if root.current-page == 2 && root.show-invoice-form : InvoiceForm {
                invoice-number:       root.invoice-form-number;
                invoice-date:         root.invoice-form-date;
                invoice-notes:        root.invoice-form-notes;
                invoice-cp-index:     root.invoice-form-cp-index;
                invoice-edit-id:      root.invoice-form-edit-id;
                total-amount:         root.invoice-form-total;
                is-edit-mode:         root.invoice-form-is-edit;
                counterparty-names:   root.invoice-form-cp-names;
                counterparty-ids:     root.invoice-form-cp-ids;
                item-descriptions:    root.invoice-form-item-descriptions;
                item-quantities:      root.invoice-form-item-quantities;
                item-units:           root.invoice-form-item-units;
                item-prices:          root.invoice-form-item-prices;
                item-amounts:         root.invoice-form-item-amounts;

                save(n, d, c, notes)        => { root.invoice-form-save(n, d, c, notes); }
                update(n, d, c, notes)      => { root.invoice-form-update(n, d, c, notes); }
                cancel                      => { root.invoice-form-cancel(); }
                add-item                    => { root.invoice-form-add-item(); }
                remove-item(i)              => { root.invoice-form-remove-item(i); }
                item-changed(idx, fld, val) => { root.invoice-form-item-changed(idx, fld, val); }
            }

            if root.current-page == 3 : Rectangle {
                Text {
                    text: "💰  Платежі\nБуде реалізовано у наступній версії";
                    color: #94a3b8;
                    font-size: 16px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    wrap: word-wrap;
                }
            }

            if root.current-page == 4 : Rectangle {
                Text {
                    text: "📊  Звіти\nБуде реалізовано у наступній версії";
                    color: #94a3b8;
                    font-size: 16px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    wrap: word-wrap;
                }
            }

            if root.current-page == 7 : Rectangle {
                Text {
                    text: "📅  Календар платежів\nБуде реалізовано у наступній версії";
                    color: #94a3b8;
                    font-size: 16px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    wrap: word-wrap;
                }
            }
        }
    }

    // ── Company Picker overlay ───────────────────────────────────────────────
    // Показується при старті якщо компаній > 1 і не відомо яку обрати.
    // Rust встановлює show-company-picker=true, user обирає → callback company-select-clicked.
    if root.show-company-picker : Rectangle {
        background: Theme.overlay;

        Rectangle {
            width: 680px;
            height: 700px;
            x: (parent.width  - self.width)  / 2;
            y: 100px;
            border-radius: 16px;
            background: Theme.surface;
            border-width: 1px;
            border-color: Theme.border;
            drop-shadow-blur: 32px;
            drop-shadow-color: #00000033;

            VerticalLayout {
                padding: 32px;
                spacing: 16px;

                VerticalLayout {
                    spacing: 2px;
                    Text {
                        text: "Acta";
                        font-size: 32px;
                        font-weight: 700;
                        color: Theme.text-main;
                        horizontal-alignment: center;
                    }
                    Text {
                        text: "Управлінський облік";
                        font-size: 14px;
                        color: Theme.text-muted;
                        horizontal-alignment: center;
                    }
                }

                VerticalLayout {
                    spacing: 4px;
                    Text {
                        text: "Оберіть компанію";
                        font-size: 24px;
                        font-weight: 700;
                        color: Theme.text-main;
                        horizontal-alignment: center;
                    }
                    Text {
                        text: "для продовження роботи";
                        font-size: 14px;
                        color: Theme.text-sub;
                        horizontal-alignment: center;
                    }
                }

                Rectangle {
                    height: 44px;
                    background: Theme.surface;
                    border-width: 1px;
                    border-color: Theme.border;
                    border-radius: 10px;

                    Text {
                        x: 14px;
                        height: parent.height;
                        text: "🔍  Пошук компанії...";
                        color: Theme.text-muted;
                        font-size: 14px;
                        vertical-alignment: center;
                    }
                }

                ListView {
                    vertical-stretch: 1;

                    for c in root.company-rows : Rectangle {
                        height: 60px;
                        border-radius: 10px;
                        background: pick-touch.has-hover ? Theme.hover-bg : Theme.surface;
                        border-width: 1px;
                        border-color: Theme.border;

                        animate background { duration: 100ms; }

                        pick-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                root.show-company-picker = false;
                                root.company-select-clicked(c.id);
                            }

                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 16px;
                                spacing: 12px;
                                alignment: center;

                                Rectangle {
                                    width: 36px;
                                    height: 36px;
                                    border-radius: 18px;
                                    background: Theme.primary-light;

                                    Text {
                                        text: "ФІ";
                                        color: Theme.primary;
                                        font-size: 12px;
                                        font-weight: 600;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    alignment: center;
                                    spacing: 2px;
                                    Text {
                                        text: c.name;
                                        font-size: 14px;
                                        font-weight: 600;
                                        color: Theme.text-main;
                                    }
                                    Text {
                                        text: c.edrpou != "" ? "ЄДРПОУ: " + c.edrpou : "";
                                        font-size: 12px;
                                        color: Theme.text-sub;
                                    }
                                }

                                Text {
                                    text: "✓";
                                    font-size: 16px;
                                    color: root.active-company-id == c.id ? Theme.primary : transparent;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                Text {
                    text: "+ Додати нову компанію";
                    color: Theme.primary;
                    font-size: 14px;
                    font-weight: 600;
                    horizontal-alignment: center;
                }

                Rectangle {
                    height: 44px;
                    background: Theme.primary-light;
                    border-radius: 10px;

                    TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.show-company-picker = false;
                            root.current-page = 6;
                        }

                        Text {
                            text: "⚙️  Управління компаніями";
                            font-size: 14px;
                            font-weight: 600;
                            color: Theme.primary;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }

    // ── Toast overlay (fixed bottom-right) ───────────────────────────────────
    // Слухає toast-message: якщо не порожній — показує повідомлення.
    // Rust встановлює через set_toast_message(), очищає через таймер (~3с).
    if root.toast-message != "" : Rectangle {
        x: parent.width - self.width - 24px;
        y: parent.height - self.height - 24px;
        width: 340px;
        height: 56px;
        border-radius: 10px;
        background: root.toast-is-error ? #FEF2F2 : #ECFDF5;
        border-width: 1px;
        border-color: root.toast-is-error ? #FECACA : #A7F3D0;

        // Іконка та текст
        HorizontalLayout {
            padding-left: 16px;
            padding-right: 8px;
            spacing: 10px;

            Text {
                text: root.toast-is-error ? "✕" : "✓";
                color: root.toast-is-error ? #DC2626 : #16A34A;
                font-size: 14px;
                font-weight: 700;
                vertical-alignment: center;
                width: 18px;
            }

            Text {
                text: root.toast-message;
                color: root.toast-is-error ? #991B1B : #166534;
                font-size: 13px;
                font-weight: 500;
                vertical-alignment: center;
                horizontal-stretch: 1;
                overflow: elide;
            }

            // Кнопка ×
            Rectangle {
                width: 28px;
                height: 28px;
                border-radius: 6px;
                background: close-touch.has-hover
                    ? (root.toast-is-error ? #FECACA : #A7F3D0)
                    : transparent;
                y: (parent.height - self.height) / 2;
                animate background { duration: 100ms; easing: ease; }

                Text {
                    text: "×";
                    color: root.toast-is-error ? #DC2626 : #16A34A;
                    font-size: 16px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                close-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.toast-message = ""; }
                }
            }
        }
    }
    }
}
