    // в”Ђв”Ђ Toast-СЃРїРѕРІС–С‰РµРЅРЅСЏ в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    // Rust РІСЃС‚Р°РЅРѕРІР»СЋС” message в†’ toast Р·'СЏРІР»СЏС”С‚СЊСЃСЏ, С‡РµСЂРµР· 3СЃ Rust РѕС‡РёС‰Р°С”.
    // in-out: Slint РјРѕР¶Рµ РїСЂРёР±СЂР°С‚Рё РєРЅРѕРїРєРѕСЋ Г—, Rust РјРѕР¶Рµ С‚РµР¶.
    in-out property <string> toast-message: "";
    in property <bool>       toast-is-error: false;

    // в”Ђв”Ђ Р РѕР·РјС–С‚РєР° в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    // Rectangle-РѕР±РіРѕСЂС‚РєР° РїРѕС‚СЂС–Р±РЅР° С‰РѕР± РЅР°РєР»Р°РґР°С‚Рё toast overlay РїРѕРІРµСЂС… layout.
    Rectangle {

    HorizontalLayout {


        // в•ђв•ђ Р‘С–С‡РЅР° РїР°РЅРµР»СЊ РЅР°РІС–РіР°С†С–С— (220px) в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
        Rectangle {
            width: 220px;
            background: Theme.sidebar-bg;
            border-width: 1px;
            border-color: Theme.sidebar-border;

            VerticalLayout {
                spacing: 0;
                padding: 0;

                // в”Ђв”Ђ Р›РѕРіРѕС‚РёРї + switcher Р±Р»РѕРє в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
                Rectangle {
                    height: 56px;

                    // Логотип-марка (36×36 синій квадрат з «A»)
                    Rectangle {
                        x: 14px; y: 12px;
                        width: 32px; height: 32px;
                        border-radius: Theme.radius-md;
                        background: Theme.primary;
                        Text {
                            x: 0; y: 6px; width: 32px;
                            horizontal-alignment: center;
                            text: "A"; font-size: 16px; font-weight: 700; color: #ffffff;
                        }
                    }

                    Text {
                        x: 54px;
                        y: 18px;
                        text: "Acta";
                        font-size: Theme.font-xl;
                        font-weight: 700;
                        color: #ffffff;
                    }
                }

                // в”Ђв”Ђ РџРµСЂРµРјРёРєР°С‡ Р°РєС‚РёРІРЅРѕС— РєРѕРјРїР°РЅС–С— в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
                Rectangle {
                    height: 52px;
                    vertical-stretch: 0;

                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        alignment: center;

                        company-btn := Rectangle {
                            height: 40px;
                            border-radius: 8px;
                            background: company-touch.has-hover ? Theme.sidebar-switcher-hover : Theme.sidebar-switcher-bg;
                            horizontal-stretch: 1;
                            animate background { duration: 100ms; }

                            company-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.switch-company(); }

                                HorizontalLayout {
                                    padding-left: 8px;
                                    padding-right: 8px;
                                    spacing: 8px;
                                    alignment: center;

                                    Rectangle {
                                        width: 28px;
                                        height: 28px;
                                        border-radius: 14px;
                                        background: Theme.primary;

                                        Text {
                                            text: "Р¤Р†";
                                            color: #ffffff;
                                            font-size: 10px;
                                            font-weight: 600;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }

                                    VerticalLayout {
                                        horizontal-stretch: 1;
                                        spacing: 1px;
                                        alignment: center;

                                        Text {
                                            text: root.active-company-name;
                                            font-size: 12px;
                                            color: #F6F8FC;
                                            overflow: elide;
                                        }
                                        Text {
                                            text: root.active-company-subtitle;
                                            font-size: 10px;
                                            color: Theme.sidebar-text-muted;
                                            overflow: elide;
                                        }
                                    }

                                    Text {
                                        text: "в–ѕ";
                                        font-size: 10px;
                                        color: Theme.sidebar-text-muted;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }

                Rectangle {
                    height: 1px;
                    x: 20px;
                    width: 180px;
                    background: Theme.sidebar-divider;
                    vertical-stretch: 0;
                }

                // в”Ђв”Ђ РќР°РІС–РіР°С†С–Р№РЅС– РїСѓРЅРєС‚Рё (Р· РІС–РґСЃС‚СѓРїР°РјРё 12px Р· Р±РѕРєС–РІ, 8px РјС–Р¶) в”Ђв”Ђ
                Text {
                    x: 20px;
                    height: 22px;
                    text: "МЕНЮ";
                    font-size: Theme.font-xs;
                    font-weight: 600;
                    color: Theme.sidebar-label;
                    vertical-alignment: center;
                }

                VerticalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    spacing: 6px;
                    vertical-stretch: 0;

                    NavItem {
                        label: "Головна";
                        icon: MenuIcons.dashboard;
                        active: root.current-page == 8;
                        clicked => {
                            root.current-page = 8;
                            root.dashboard-refresh();
                        }
                    }
                    NavItem {
                        label: "Документи";
                        icon: MenuIcons.acts;
                        active: root.current-page == 1;
                        clicked => { root.current-page = 1; }
                    }
                    NavItem {
                        label: "Контрагенти";
                        icon: MenuIcons.counterparties;
                        active: root.current-page == 0;
                        clicked => { root.current-page = 0; }
                    }
                    NavItem {
                        label: "Платежі";
                        icon: MenuIcons.payments;
                        active: root.current-page == 3;
                        clicked => { root.current-page = 3; }
                    }
                    NavItem {
                        label: "Звіти";
                        icon: MenuIcons.reports;
                        active: root.current-page == 4;
                        clicked => { root.current-page = 4; }
                    }
                }

                Rectangle {
                    height: 1px;
                    x: 20px;
                    width: 180px;
                    background: Theme.sidebar-divider;
                    vertical-stretch: 0;
                }

                Text {
                    x: 20px;
                    height: 22px;
                    text: "УТИЛІТИ";
                    font-size: Theme.font-xs;
                    font-weight: 600;
                    color: Theme.sidebar-label;
                    vertical-alignment: center;
                }

                VerticalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    spacing: 6px;
                    vertical-stretch: 0;

                    NavItem {
                        label: "To-Do";
                        icon: MenuIcons.todo;
                        active: root.current-page == 5;
                        clicked => { root.current-page = 5; }
                    }
                    NavItem {
                        label: "Календар платежів";
                        icon: MenuIcons.calendar;
                        active: root.current-page == 7;
                        clicked => { root.current-page = 7; }
                    }
                }

                Rectangle { vertical-stretch: 1; }

                // в”Ђв”Ђ РќРёР¶РЅСЏ СЃРµРєС†С–СЏ: СЂРѕР·РґС–Р»СЋРІР°С‡ + РќР°Р»Р°С€С‚СѓРІР°РЅРЅСЏ в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
                // HorizontalLayout РґР»СЏ РІРёСЂС–РІРЅСЏРЅРѕРіРѕ СЂРѕР·РґС–Р»СЋРІР°С‡Р° (x=20, С€РёСЂРёРЅР° 180px)
                HorizontalLayout {
                    height: 1px;
                    padding-left: 20px;
                    padding-right: 20px;
                    vertical-stretch: 0;

                    Rectangle {
                        background: Theme.sidebar-divider;
                    }
                }

                Rectangle {
                    height: 40px;
                    vertical-stretch: 0;

                    NavItem {
                        x: 12px;
                        width: parent.width - 24px;
                        label: "Налаштування";
                        icon: MenuIcons.settings;
                        active: false;
                        disabled: true;
                    }
                }

                Rectangle { height: 12px; vertical-stretch: 0; }
            }
        }

        // в•ђв•ђ РћР±Р»Р°СЃС‚СЊ РєРѕРЅС‚РµРЅС‚Сѓ в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
        Rectangle {
            background: Theme.bg-page;

            // в”Ђв”Ђ РЎС‚РѕСЂС–РЅРєР° 0: РљРѕРЅС‚СЂР°РіРµРЅС‚Рё вЂ” СЃРїРёСЃРѕРє в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
            if root.current-page == 0 && !root.show-cp-form : CounterpartyList {
                rows:             root.counterparty-rows;
                row-ids:          root.counterparty-ids;
                row-archived:     root.counterparty-archived;
                loading:          root.counterparties-loading;
                total-count:      root.counterparty-total-count;
                active-count:     root.counterparty-active-count;
                archived-count:   root.counterparty-archived-count;
                pagination-text:  root.counterparty-pagination-text;
                show-archived:    root.counterparty-show-archived;
                current-page:     root.counterparty-current-page;
                total-pages:      root.counterparty-total-pages;

                search-changed(q)   => { root.counterparty-search-changed(q); }
                row-selected(id)    => { root.counterparty-selected(id); }
                edit-clicked(id)    => { root.counterparty-edit-clicked(id); }
                create-clicked      => { root.counterparty-create-clicked(); }
                archive-clicked(id) => { root.counterparty-archive-clicked(id); }
                filter-clicked      => { root.counterparty-filter-clicked(); }
                prev-page-clicked   => { root.counterparty-prev-page-clicked(); }
                next-page-clicked   => { root.counterparty-next-page-clicked(); }
            }

            // в”Ђв”Ђ РЎС‚РѕСЂС–РЅРєР° 0: РљРѕРЅС‚СЂР°РіРµРЅС‚Рё вЂ” С„РѕСЂРјР° в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
            if root.current-page == 0 && root.show-cp-form : CounterpartyForm {
                is-edit-mode: root.cp-form-is-edit;
                cp-edit-id:   root.cp-form-edit-id;
                cp-name:      root.cp-form-name;
                cp-edrpou:    root.cp-form-edrpou;
                cp-ipn:       root.cp-form-ipn;
                cp-iban:      root.cp-form-iban;
                cp-phone:     root.cp-form-phone;
                cp-email:     root.cp-form-email;
                cp-address:   root.cp-form-address;
                cp-notes:     root.cp-form-notes;

                save(nm, ed, ip, ib, ph, em, ad, nt)    => { root.cp-form-save(nm, ed, ip, ib, ph, em, ad, nt); }
                update(nm, ed, ip, ib, ph, em, ad, nt)  => { root.cp-form-update(nm, ed, ip, ib, ph, em, ad, nt); }
                cancel                              => { root.cp-form-cancel(); }
            }

            // ── Сторінка 1: Документи — список ────────────────────────────────
            if root.current-page == 1 && !root.show-act-form && !root.show-invoice-form : DocumentList {
                rows:                   root.document-rows;
                loading:                root.documents-loading;
                direction-index:        root.doc-direction-index;
                active-tab:             root.doc-active-tab;
                filter-counterparty-names: root.doc-filter-cp-names;
                filter-counterparty-index: root.doc-filter-cp-index;

                new-document-act        => { root.doc-new-act-clicked(); }
                new-document-invoice    => { root.doc-new-invoice-clicked(); }
                open-document(id)       => { root.doc-open-clicked(id); }
                delete-document(id)     => { root.doc-delete-clicked(id); }
                export-pdf(id)          => { root.doc-pdf-clicked(id); }
                direction-changed(i)    => { root.doc-direction-changed(i); }
                tab-changed(i)          => { root.doc-tab-changed(i); }
                search-changed(q)       => { root.doc-search-changed(q); }
                counterparty-filter-changed(i) => { root.doc-cp-filter-changed(i); }
                date-from-changed(s)    => { root.doc-date-from-changed(s); }
                date-to-changed(s)      => { root.doc-date-to-changed(s); }
            }

            // в”Ђв”Ђ РЎС‚РѕСЂС–РЅРєР° 1: РђРєС‚Рё вЂ” С„РѕСЂРјР° в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
            if root.current-page == 1 && root.show-act-form : ActForm {
                act-number:           root.act-form-number;
                act-date:             root.act-form-date;
                act-notes:            root.act-form-notes;
                act-cp-index:         root.act-form-cp-index;
                act-edit-id:          root.act-form-edit-id;
                total-amount:         root.act-form-total;
                is-edit-mode:         root.act-form-is-edit;
                counterparty-names:   root.act-form-cp-names;
                counterparty-ids:     root.act-form-cp-ids;
                item-descriptions:    root.act-form-item-descriptions;
                item-quantities:      root.act-form-item-quantities;
                item-units:           root.act-form-item-units;
                item-prices:          root.act-form-item-prices;
                item-amounts:         root.act-form-item-amounts;
                act-task-rows:        root.act-task-rows;
                act-task-row-ids:     root.act-task-row-ids;
                act-task-row-statuses: root.act-task-row-statuses;
                act-task-row-priorities: root.act-task-row-priorities;
                act-tasks-loading:    root.act-tasks-loading;
                category-names:       root.act-form-category-names;
                category-ids:         root.act-form-category-ids;
                act-category-index:   root.act-form-category-index;
                contract-names:       root.act-form-contract-names;
                contract-ids:         root.act-form-contract-ids;
                act-contract-index:   root.act-form-contract-index;
                act-expected-payment-date: root.act-form-expected-payment-date;

                save(n, d, c, notes, cat, con, exp)       => { root.act-form-save(n, d, c, notes, cat, con, exp); }
                save-draft(n, d, c, notes, cat, con, exp) => { root.act-form-save-draft(n, d, c, notes, cat, con, exp); }
                update(n, d, c, notes, cat, con, exp)     => { root.act-form-update(n, d, c, notes, cat, con, exp); }
                cancel                     => { root.act-form-cancel(); }
                add-item                   => { root.act-form-add-item(); }
                remove-item(i)             => { root.act-form-remove-item(i); }
                item-changed(idx, fld, val) => { root.act-form-item-changed(idx, fld, val); }
                act-task-create-clicked    => { root.act-task-create-clicked(); }
                act-task-edit-clicked(id)  => { root.act-task-edit-clicked(id); }
                act-task-toggle-status-clicked(id) => { root.act-task-toggle-status-clicked(id); }
                act-task-delete-clicked(id) => { root.act-task-delete-clicked(id); }
            }

            // в”Ђв”Ђ РЎС‚РѕСЂС–РЅРєР° 5: To-Do вЂ” СЃРїРёСЃРѕРє в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
            if root.current-page == 5 && !root.show-task-form : TaskList {
                rows:             root.task-rows;
                row-ids:          root.task-row-ids;
                row-statuses:     root.task-row-statuses;
                row-priorities:   root.task-row-priorities;
                loading:          root.tasks-loading;

                search-changed(q)         => { root.task-search-changed(q); }
                row-selected(id)          => { root.task-selected(id); }
                create-clicked            => { root.task-create-clicked(); }
                toggle-status-clicked(id) => { root.task-toggle-status-clicked(id); }
                delete-clicked(id)        => { root.task-delete-clicked(id); }
                edit-clicked(id)          => { root.task-edit-clicked(id); }
            }

            // в”Ђв”Ђ РЎС‚РѕСЂС–РЅРєР° 5: To-Do вЂ” С„РѕСЂРјР° в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
            if root.current-page == 5 && root.show-task-form : TaskForm {
                is-edit-mode:           root.task-form-is-edit;
                task-edit-id:           root.task-form-edit-id;
                task-title:             root.task-form-title;
                task-description:       root.task-form-description;
                task-priority-index:    root.task-form-priority-index;
                task-due-date:          root.task-form-due-date;
                task-reminder-at:       root.task-form-reminder-at;
                task-act-id:            root.task-form-act-id;

                save(t, d, p, due, rem)   => { root.task-form-save(t, d, p, due, rem); }
                update(t, d, p, due, rem) => { root.task-form-update(t, d, p, due, rem); }
                cancel                    => { root.task-form-cancel(); }
            }

            // в”Ђв”Ђ РЎС‚РѕСЂС–РЅРєР° 6: РљРѕРјРїР°РЅС–С— вЂ” СЃРїРёСЃРѕРє в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
            if root.current-page == 6 && !root.show-company-form : CompanyList {
                companies:   root.company-rows;
                loading:     root.companies-loading;

                add          => { root.company-add-clicked(); }
                edit(id)     => { root.company-edit-clicked(id); }
                archive(id)  => { root.company-archive-clicked(id); }
                select(id)   => { root.company-select-clicked(id); }
            }

            // в”Ђв”Ђ РЎС‚РѕСЂС–РЅРєР° 6: РљРѕРјРїР°РЅС–С— вЂ” С„РѕСЂРјР° в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
            if root.current-page == 6 && root.show-company-form : CompanyForm {
                is-edit:           root.company-form-is-edit;
                edit-id:           root.company-form-edit-id;
                form-name:         root.company-form-name;
                form-edrpou:       root.company-form-edrpou;
                form-iban:         root.company-form-iban;
                form-legal-address: root.company-form-legal-address;
                form-director-name: root.company-form-director;
                form-accountant-name: root.company-form-accountant;
                form-is-vat-payer: root.company-form-is-vat;

                save(nm, ed, ib, ad, dr, ac, vt)   => { root.company-form-save(nm, ed, ib, ad, dr, ac, vt); }
                update(nm, ed, ib, ad, dr, ac, vt) => { root.company-form-update(nm, ed, ib, ad, dr, ac, vt); }
                cancel                              => { root.company-form-cancel(); }
            }

            // ── Сторінка 1: Документи — форма накладної ───────────────────────
            if root.current-page == 1 && root.show-invoice-form : InvoiceForm {
                invoice-number:       root.invoice-form-number;
                invoice-date:         root.invoice-form-date;
                invoice-notes:        root.invoice-form-notes;
                invoice-cp-index:     root.invoice-form-cp-index;
                invoice-edit-id:      root.invoice-form-edit-id;
                total-amount:         root.invoice-form-total;
                is-edit-mode:         root.invoice-form-is-edit;
                counterparty-names:   root.invoice-form-cp-names;
                counterparty-ids:     root.invoice-form-cp-ids;
                item-descriptions:    root.invoice-form-item-descriptions;
                item-quantities:      root.invoice-form-item-quantities;
                item-units:           root.invoice-form-item-units;
                item-prices:          root.invoice-form-item-prices;
                item-amounts:         root.invoice-form-item-amounts;
                category-names:       root.invoice-form-category-names;
                category-ids:         root.invoice-form-category-ids;
                invoice-category-index: root.invoice-form-category-index;
                contract-names:       root.invoice-form-contract-names;
                contract-ids:         root.invoice-form-contract-ids;
                invoice-contract-index: root.invoice-form-contract-index;
                invoice-expected-payment-date: root.invoice-form-expected-payment-date;

                save(n, d, c, notes, cat, con, exp)   => { root.invoice-form-save(n, d, c, notes, cat, con, exp); }
                update(n, d, c, notes, cat, con, exp) => { root.invoice-form-update(n, d, c, notes, cat, con, exp); }
                cancel                      => { root.invoice-form-cancel(); }
                add-item                    => { root.invoice-form-add-item(); }
                remove-item(i)              => { root.invoice-form-remove-item(i); }
                item-changed(idx, fld, val) => { root.invoice-form-item-changed(idx, fld, val); }
            }

            // в”Ђв”Ђ РЎС‚РѕСЂС–РЅРєР° 8: Dashboard в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
            if root.current-page == 8 : DashboardPage {
                kpi-revenue:             root.dashboard-kpi-revenue;
                kpi-revenue-trend:       root.dashboard-kpi-revenue-trend;
                kpi-unpaid:              root.dashboard-kpi-unpaid;
                kpi-unpaid-trend:        root.dashboard-kpi-unpaid-trend;
                kpi-acts-month:          root.dashboard-kpi-acts-month;
                kpi-acts-trend:          root.dashboard-kpi-acts-trend;
                kpi-counterparties:      root.dashboard-kpi-counterparties;
                kpi-cp-trend:            root.dashboard-kpi-cp-trend;
                current-month-label:     root.dashboard-month-label;
                chart-bar-labels:        root.dashboard-chart-bar-labels;
                chart-bar-value-labels:  root.dashboard-chart-bar-value-labels;
                chart-bar-fractions:     root.dashboard-chart-bar-fractions;
                status-paid:             root.dashboard-status-paid;
                status-issued:           root.dashboard-status-issued;
                status-signed:           root.dashboard-status-signed;
                status-draft:            root.dashboard-status-draft;
                recent-acts:             root.dashboard-recent-acts;
                upcoming-payments:       root.dashboard-upcoming-payments;

                new-act-clicked  => { root.dashboard-new-act-clicked(); }
                all-acts-clicked => { root.dashboard-all-acts-clicked(); }
                add-todo-clicked => { root.dashboard-add-todo-clicked(); }
            }

            if root.current-page == 3 : PaymentList {
                row-ids:             root.payment-row-ids;
                row-dates:           root.payment-row-dates;
                row-counterparties:  root.payment-row-counterparties;
                row-descriptions:    root.payment-row-descriptions;
                row-banks:           root.payment-row-banks;
                row-amounts:         root.payment-row-amounts;
                row-directions:      root.payment-row-directions;
                row-reconciled:      root.payment-row-reconciled;
                loading:             root.payments-loading;
                total-income:        root.payment-total-income;
                total-expense:       root.payment-total-expense;

                direction-filter-changed(i) => { root.payment-direction-filter-changed(i); }
                search-changed(q)           => { root.payment-search-changed(q); }
                create-clicked              => { root.payment-create-clicked(); }
                edit-clicked(id)            => { root.payment-edit-clicked(id); }
                delete-clicked(id)          => { root.payment-delete-clicked(id); }
                reconcile-clicked(id)       => { root.payment-reconcile-clicked(id); }
            }

            if root.current-page == 3 && root.show-payment-form : PaymentForm {
                is-edit-mode: root.payment-form-is-edit;
                payment-edit-id: root.payment-form-edit-id;
                payment-date: root.payment-form-date;
                payment-amount: root.payment-form-amount;
                payment-direction-index: root.payment-form-direction-index;
                counterparty-names: root.payment-form-counterparty-names;
                counterparty-ids: root.payment-form-counterparty-ids;
                payment-counterparty-index: root.payment-form-counterparty-index;
                payment-bank-name: root.payment-form-bank-name;
                payment-bank-ref: root.payment-form-bank-ref;
                payment-description: root.payment-form-description;

                save(date, amount, direction, counterparty_id, bank_name, bank_ref, description) => {
                    root.payment-form-save(date, amount, direction, counterparty_id, bank_name, bank_ref, description);
                }
                update(date, amount, direction, counterparty_id, bank_name, bank_ref, description) => {
                    root.payment-form-update(date, amount, direction, counterparty_id, bank_name, bank_ref, description);
                }
                cancel => { root.payment-form-cancel(); }
            }

            if root.current-page == 4 : SettingsPage {
                company-name: root.settings-company-name;
                company-edrpou: root.settings-company-edrpou;
                company-iban: root.settings-company-iban;
                company-director: root.settings-company-director;
                company-address: root.settings-company-address;
                category-rows: root.settings-category-rows;
                edit-company-clicked => { root.settings-edit-company-clicked(); }
            }

            if false && root.current-page == 4 : Rectangle {
                Text {
                    text: "рџ“Љ  Р—РІС–С‚Рё\nР‘СѓРґРµ СЂРµР°Р»С–Р·РѕРІР°РЅРѕ Сѓ РЅР°СЃС‚СѓРїРЅС–Р№ РІРµСЂСЃС–С—";
                    color: Theme.text-muted;
                    font-size: 16px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    wrap: word-wrap;
                }
            }

            if root.current-page == 7 : SettingsPage {
                company-name: root.settings-company-name;
                company-edrpou: root.settings-company-edrpou;
                company-iban: root.settings-company-iban;
                company-director: root.settings-company-director;
                company-address: root.settings-company-address;
                category-rows: root.settings-category-rows;
                edit-company-clicked => { root.settings-edit-company-clicked(); }
            }

            if false && root.current-page == 7 : Rectangle {
                Text {
                    text: "рџ“…  РљР°Р»РµРЅРґР°СЂ РїР»Р°С‚РµР¶С–РІ\nР‘СѓРґРµ СЂРµР°Р»С–Р·РѕРІР°РЅРѕ Сѓ РЅР°СЃС‚СѓРїРЅС–Р№ РІРµСЂСЃС–С—";
                    color: Theme.text-muted;
                    font-size: 16px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    wrap: word-wrap;
                }
            }
        }
    }

    // в”Ђв”Ђ Company Picker overlay в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    // РџРѕРєР°Р·СѓС”С‚СЊСЃСЏ РїСЂРё СЃС‚Р°СЂС‚С– СЏРєС‰Рѕ РєРѕРјРїР°РЅС–Р№ > 1 С– РЅРµ РІС–РґРѕРјРѕ СЏРєСѓ РѕР±СЂР°С‚Рё.
    // Rust РІСЃС‚Р°РЅРѕРІР»СЋС” show-company-picker=true, user РѕР±РёСЂР°С” в†’ callback company-select-clicked.
    if root.show-counterparty-card : Rectangle {
        background: Theme.overlay;

        Rectangle {
            width: parent.width - 80px;
            height: parent.height - 80px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            border-radius: 18px;
            background: Theme.surface;
            border-width: 1px;
            border-color: Theme.border;
            clip: true;

            CounterpartyCard {
                cp-name: root.counterparty-card-name;
                cp-edrpou: root.counterparty-card-edrpou;
                cp-ipn: root.counterparty-card-ipn;
                cp-iban: root.counterparty-card-iban;
                cp-phone: root.counterparty-card-phone;
                cp-email: root.counterparty-card-email;
                cp-address: root.counterparty-card-address;
                stat-acts: root.counterparty-card-stat-acts;
                stat-invoices: root.counterparty-card-stat-invoices;
                stat-payments: root.counterparty-card-stat-payments;
                stat-contracts: root.counterparty-card-stat-contracts;
                acts: root.counterparty-card-acts;
                invoices: root.counterparty-card-invoices;
                payments: root.counterparty-card-payments;
                contracts: root.counterparty-card-contracts;
                tasks: root.counterparty-card-tasks;

                close-clicked => { root.counterparty-card-close-clicked(); }
                edit-clicked => { root.counterparty-card-edit-clicked(root.counterparty-card-id); }
            }
        }
    }

    // ── Overlay: картка акту ──────────────────────────────────────────────────
    if root.show-act-card : Rectangle {
        background: Theme.overlay;

        Rectangle {
            width: parent.width - 80px;
            height: parent.height - 80px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            border-radius: 18px;
            background: Theme.surface;
            border-width: 1px;
            border-color: Theme.border;
            clip: true;

            ActCard {
                act-number:           root.act-card-number;
                act-date:             root.act-card-date;
                act-status:           root.act-card-status;
                act-status-label:     root.act-card-status-label;
                act-counterparty:     root.act-card-counterparty;
                act-total:            root.act-card-total;
                act-expected-payment: root.act-card-expected-payment;
                act-notes:            root.act-card-notes;
                act-items:            root.act-card-items;
                act-tasks:            root.act-card-tasks;

                close-clicked           => { root.act-card-close-clicked(); }
                edit-clicked            => { root.act-card-edit-clicked(root.act-card-id); }
                pdf-clicked             => { root.act-card-pdf-clicked(root.act-card-id); }
                advance-status-clicked  => { root.act-card-advance-status-clicked(root.act-card-id); }
            }
        }
    }

    if root.show-company-picker : Rectangle {
        background: Theme.overlay;

        Rectangle {
            width: 680px;
            height: 700px;
            x: (parent.width  - self.width)  / 2;
            y: 100px;
            border-radius: 16px;
            background: Theme.surface;
            border-width: 1px;
            border-color: Theme.border;
            drop-shadow-blur: 32px;
            drop-shadow-color: #00000033;

            VerticalLayout {
                padding: 32px;
                spacing: 16px;

                VerticalLayout {
                    spacing: 2px;
                    Text {
                        text: "Acta";
                        font-size: 32px;
                        font-weight: 700;
                        color: Theme.text-main;
                        horizontal-alignment: center;
                    }
                    Text {
                        text: "РЈРїСЂР°РІР»С–РЅСЃСЊРєРёР№ РѕР±Р»С–Рє";
                        font-size: 14px;
                        color: Theme.text-muted;
                        horizontal-alignment: center;
                    }
                }

                VerticalLayout {
                    spacing: 4px;
                    Text {
                        text: "РћР±РµСЂС–С‚СЊ РєРѕРјРїР°РЅС–СЋ";
                        font-size: 24px;
                        font-weight: 700;
                        color: Theme.text-main;
                        horizontal-alignment: center;
                    }
                    Text {
                        text: "РґР»СЏ РїСЂРѕРґРѕРІР¶РµРЅРЅСЏ СЂРѕР±РѕС‚Рё";
                        font-size: 14px;
                        color: Theme.text-sub;
                        horizontal-alignment: center;
                    }
                }

                Rectangle {
                    height: 44px;
                    background: Theme.surface;
                    border-width: 1px;
                    border-color: Theme.border;
                    border-radius: 10px;

                    Text {
                        x: 14px;
                        height: parent.height;
                        text: "рџ”Ќ  РџРѕС€СѓРє РєРѕРјРїР°РЅС–С—...";
                        color: Theme.text-muted;
                        font-size: 14px;
                        vertical-alignment: center;
                    }
                }

                ListView {
                    vertical-stretch: 1;

                    for c in root.company-rows : Rectangle {
                        height: 60px;
                        border-radius: 10px;
                        background: pick-touch.has-hover ? Theme.hover-bg : Theme.surface;
                        border-width: 1px;
                        border-color: Theme.border;

                        animate background { duration: 100ms; }

                        pick-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                root.show-company-picker = false;
                                root.company-select-clicked(c.id);
                            }

                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 16px;
                                spacing: 12px;
                                alignment: center;

                                Rectangle {
                                    width: 36px;
                                    height: 36px;
                                    border-radius: 18px;
                                    background: Theme.primary-light;

                                    Text {
                                        text: c.initials;
                                        color: Theme.primary;
                                        font-size: 12px;
                                        font-weight: 600;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    alignment: center;
                                    spacing: 2px;
                                    Text {
                                        text: c.name;
                                        font-size: 14px;
                                        font-weight: 600;
                                        color: Theme.text-main;
                                    }
                                    Text {
                                        text: c.edrpou != "" ? "Р„Р”Р РџРћРЈ: " + c.edrpou : "";
                                        font-size: 12px;
                                        color: Theme.text-sub;
                                    }
                                }

                                Text {
                                    text: "вњ“";
                                    font-size: 16px;
                                    color: root.active-company-id == c.id ? Theme.primary : transparent;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                Text {
                    text: "+ Р”РѕРґР°С‚Рё РЅРѕРІСѓ РєРѕРјРїР°РЅС–СЋ";
                    color: Theme.primary;
                    font-size: 14px;
                    font-weight: 600;
                    horizontal-alignment: center;
                }

                Rectangle {
                    height: 44px;
                    background: Theme.primary-light;
                    border-radius: 10px;

                    TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.show-company-picker = false;
                            root.current-page = 6;
                        }

                        Text {
                            text: "вљ™пёЏ  РЈРїСЂР°РІР»С–РЅРЅСЏ РєРѕРјРїР°РЅС–СЏРјРё";
                            font-size: 14px;
                            font-weight: 600;
                            color: Theme.primary;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }

    // в”Ђв”Ђ Toast overlay (fixed bottom-right) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    // РЎР»СѓС…Р°С” toast-message: СЏРєС‰Рѕ РЅРµ РїРѕСЂРѕР¶РЅС–Р№ вЂ” РїРѕРєР°Р·СѓС” РїРѕРІС–РґРѕРјР»РµРЅРЅСЏ.
    // Rust РІСЃС‚Р°РЅРѕРІР»СЋС” С‡РµСЂРµР· set_toast_message(), РѕС‡РёС‰Р°С” С‡РµСЂРµР· С‚Р°Р№РјРµСЂ (~3СЃ).
    if root.toast-message != "" : Rectangle {
        x: parent.width - self.width - 24px;
        y: parent.height - self.height - 24px;
        width: 340px;
        height: 56px;
        border-radius: 10px;
        background: root.toast-is-error ? #FEF2F2 : #ECFDF5;
        border-width: 1px;
        border-color: root.toast-is-error ? #FECACA : #A7F3D0;

        // Р†РєРѕРЅРєР° С‚Р° С‚РµРєСЃС‚
        HorizontalLayout {
            padding-left: 16px;
            padding-right: 8px;
            spacing: 10px;

            Text {
                text: root.toast-is-error ? "вњ•" : "вњ“";
                color: root.toast-is-error ? #DC2626 : #16A34A;
                font-size: 14px;
                font-weight: 700;
                vertical-alignment: center;
                width: 18px;
            }

            Text {
                text: root.toast-message;
                color: root.toast-is-error ? #991B1B : #166534;
                font-size: 13px;
                font-weight: 500;
                vertical-alignment: center;
                horizontal-stretch: 1;
                overflow: elide;
            }

            // РљРЅРѕРїРєР° Г—
            Rectangle {
                width: 28px;
                height: 28px;
                border-radius: 6px;
                background: close-touch.has-hover
                    ? (root.toast-is-error ? #FECACA : #A7F3D0)
                    : transparent;
                y: (parent.height - self.height) / 2;
                animate background { duration: 100ms; easing: ease; }

                Text {
                    text: "Г—";
                    color: root.toast-is-error ? #DC2626 : #16A34A;
                    font-size: 16px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                close-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.toast-message = ""; }
                }
            }
        }
    }
    }
}

