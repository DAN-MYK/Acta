// Компонент: список видаткових накладних
//
// Аналогічна структура до ActList:
//   - Topbar 64px (заголовок + кнопка створення)
//   - Рядок пошуку + фільтр за статусом
//   - Таблиця зі status badge та панеллю дій

import { Theme } from "../theme.slint";
import { ProgressIndicator, ComboBox, ListView } from "std-widgets.slint";
import { StatusBadge } from "../components/status_badge.slint";
import { InvoiceRow } from "../structs.slint";

export component InvoiceList {

    // ── Вхідні дані ────────────────────────────────────────────────────────
    in property <[InvoiceRow]> rows;
    in property <bool>                     loading: false;

    // ── Колбеки ─────────────────────────────────────────────────────────────
    // 0=Усі, 1=Чернетка, 2=Виставлено, 3=Підписано, 4=Оплачено
    callback status-filter-changed(int);
    callback search-changed(string);
    callback row-selected(string);
    callback create-clicked();
    callback advance-status-clicked(string);
    callback edit-clicked(string);

    // ── Внутрішній стан ─────────────────────────────────────────────────────
    private property <int>    selected-row: -1;
    private property <string> selected-id: "";
    private property <string> selected-status: "";
    private property <string> selected-number: "";

    min-width: 600px;
    min-height: 400px;

    VerticalLayout {
        spacing: 0;
        padding: 0;

        // ── Topbar ─────────────────────────────────────────────────────────
        Rectangle {
            height: 64px;
            background: Theme.bg-card;

            HorizontalLayout {
                padding-left: 32px;
                padding-right: 32px;
                spacing: 16px;

                Text {
                    text: "Видаткові накладні";
                    font-size: 18px;
                    font-weight: 600;
                    color: Theme.text-primary;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                if root.rows.length > 0 : Text {
                    text: root.rows.length + " записів";
                    color: Theme.text-muted;
                    font-size: 12px;
                    vertical-alignment: center;
                }

                new-btn := Rectangle {
                    background: Theme.primary;
                    border-radius: 8px;
                    height: 36px;
                    width: 160px;
                    y: (parent.height - self.height) / 2;

                    Text {
                        text: "+ Нова накладна";
                        color: Theme.text-white;
                        font-size: 13px;
                        font-weight: 500;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.create-clicked(); }
                    }
                }
            }

            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: Theme.border;
            }
        }

        // ── Основний контент ─────────────────────────────────────────────────
        Rectangle {
            background: Theme.bg-page;
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: 24px;
                padding-left: 32px;
                padding-right: 32px;
                padding-bottom: 24px;
                spacing: 16px;

                // ── Рядок пошуку + фільтр статусу ────────────────────────────
                HorizontalLayout {
                    height: 40px;
                    spacing: 12px;
                    vertical-stretch: 0;

                    search-rect := Rectangle {
                        background: Theme.bg-card;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.border;
                        horizontal-stretch: 1;
                        clip: true;

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;

                            search-input := TextInput {
                                vertical-alignment: center;
                                font-size: 13px;
                                color: Theme.text-primary;
                                edited => { root.search-changed(search-input.text); }
                            }
                        }

                        if search-input.text == "" : Text {
                            x: 12px;
                            height: parent.height;
                            width: parent.width - 24px;
                            text: "🔎  Пошук за номером або контрагентом...";
                            color: Theme.text-muted;
                            font-size: 13px;
                            vertical-alignment: center;
                        }
                    }

                    Text {
                        text: "Статус:";
                        font-size: 13px;
                        color: Theme.text-second;
                        vertical-alignment: center;
                        width: 52px;
                    }

                    Rectangle {
                        background: Theme.bg-card;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.border;
                        width: 180px;

                        status-combo := ComboBox {
                            model: ["Усі", "Чернетка", "Виставлено", "Підписано", "Оплачено"];
                            selected => {
                                root.status-filter-changed(status-combo.current-index);
                            }
                        }
                    }
                }

                if root.loading : ProgressIndicator {
                    indeterminate: true;
                    vertical-stretch: 0;
                }

                // ── Таблиця ──────────────────────────────────────────────────
                Rectangle {
                    vertical-stretch: 1;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: Theme.border;
                    clip: true;

                    VerticalLayout {
                        spacing: 0;

                        // Заголовок
                        Rectangle {
                            height: 40px;
                            background: Theme.table-header;

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;

                                Text { text: "Номер";      color: Theme.text-second; font-size: 12px; font-weight: 500; horizontal-stretch: 2; vertical-alignment: center; }
                                Text { text: "Дата";       color: Theme.text-second; font-size: 12px; font-weight: 500; horizontal-stretch: 1; vertical-alignment: center; }
                                Text { text: "Контрагент"; color: Theme.text-second; font-size: 12px; font-weight: 500; horizontal-stretch: 3; vertical-alignment: center; }
                                Text { text: "Сума, ₴";    color: Theme.text-second; font-size: 12px; font-weight: 500; horizontal-stretch: 1; vertical-alignment: center; }
                                Text { text: "Статус";     color: Theme.text-second; font-size: 12px; font-weight: 500; width: 100px; vertical-alignment: center; }
                            }
                        }

                        // Порожній стан
                        if !root.loading && root.rows.length == 0 : Rectangle {
                            vertical-stretch: 1;
                            background: Theme.bg-card;

                            VerticalLayout {
                                alignment: center;
                                spacing: 8px;

                                Text {
                                    text: "📦";
                                    font-size: 32px;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: "Накладних ще немає";
                                    font-size: 15px;
                                    font-weight: 500;
                                    color: Theme.text-second;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: "Натисніть «+ Нова накладна» щоб створити першу";
                                    font-size: 13px;
                                    color: Theme.text-muted;
                                    horizontal-alignment: center;
                                }
                            }
                        }

                        // Рядки
                        ListView {
                            vertical-stretch: 1;

                            for row[i] in root.rows : Rectangle {
                                property <string> raw-status: row.status;
                                property <color> badge-color:
                                    raw-status == "paid"   ? Theme.success  :
                                    raw-status == "signed" ? Theme.primary  :
                                    raw-status == "issued" ? Theme.warning  :
                                    Theme.text-muted;
                                property <color> badge-bg:
                                    raw-status == "paid"   ? #1EB16E1F :
                                    raw-status == "signed" ? #3D75F41A :
                                    raw-status == "issued" ? #F4A31E1F :
                                    #ABABB71F;

                                height: 52px;
                                background: root.selected-row == i
                                    ? Theme.row-selected
                                    : (row-touch.has-hover
                                        ? Theme.row-hover
                                        : (Math.mod(i, 2) == 0 ? Theme.bg-card : Theme.row-stripe));
                                border-width: 1px;
                                border-color: Theme.border;
                                animate background { duration: 80ms; easing: ease; }

                                HorizontalLayout {
                                    padding-left: 15px;
                                    padding-right: 15px;

                                    Text {
                                        text: row.num;
                                        color: Theme.text-primary;
                                        font-size: 13px;
                                        font-weight: 500;
                                        horizontal-stretch: 2;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                    Text {
                                        text: row.date;
                                        color: Theme.text-second;
                                        font-size: 13px;
                                        horizontal-stretch: 1;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                    Text {
                                        text: row.counterparty;
                                        color: Theme.text-second;
                                        font-size: 13px;
                                        horizontal-stretch: 3;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                    Text {
                                        text: row.amount;
                                        color: Theme.text-primary;
                                        font-size: 13px;
                                        font-weight: 600;
                                        horizontal-stretch: 1;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                    Rectangle {
                                        width: 100px;
                                        StatusBadge {
                                            y: (parent.height - self.height) / 2;
                                            label: row.status-label;
                                            badge-color: badge-color;
                                            badge-bg: badge-bg;
                                        }
                                    }
                                }

                                row-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        root.selected-row    = i;
                                        root.selected-id     = row.id;
                                        root.selected-status = row.status;
                                        root.selected-number = row.num;
                                        root.row-selected(row.id);
                                    }
                                }
                            }
                        }
                    }
                }

                // ── Панель дій ──────────────────────────────────────────────
                if root.selected-row >= 0 : HorizontalLayout {
                    height: 48px;
                    spacing: 8px;
                    vertical-stretch: 0;

                    Text {
                        text: root.selected-number;
                        color: Theme.text-second;
                        font-size: 13px;
                        font-weight: 500;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        overflow: elide;
                    }

                    Rectangle {
                        background: Theme.bg-card;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.border;
                        height: 36px;
                        width: 130px;
                        y: (parent.height - self.height) / 2;

                        Text {
                            text: "✎  Редагувати";
                            color: Theme.text-primary;
                            font-size: 13px;
                            font-weight: 500;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                if root.selected-id != "" {
                                    root.edit-clicked(root.selected-id);
                                }
                            }
                        }
                    }

                    Rectangle {
                        background: root.selected-status != "paid"
                            ? Theme.primary : Theme.border;
                        border-radius: 8px;
                        height: 36px;
                        width: 180px;
                        y: (parent.height - self.height) / 2;

                        Text {
                            text: "Наступний статус ▶";
                                        color: root.selected-status != "paid" ? Theme.text-white : Theme.text-muted;
                            font-size: 13px;
                            font-weight: 500;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        TouchArea {
                            mouse-cursor: root.selected-status != "paid" ? pointer : default;
                            clicked => {
                                if root.selected-id != "" && root.selected-status != "paid" {
                                    root.advance-status-clicked(root.selected-id);
                                    root.selected-row    = -1;
                                    root.selected-id     = "";
                                    root.selected-status = "";
                                    root.selected-number = "";
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
