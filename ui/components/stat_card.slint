// Уніфікована KPI/статистична картка.
//
// Використовується:
//   - counterparties/counterparty_list.slint — 3 картки (Всього / Активних / В архіві)
//   - acts/act_list.slint — 4 KPI картки (Актів / Виручка / Неоплачено / Прострочено)
//
// Структура: 3px акцентна лінія зверху + велике число + label + опційний secondary підпис.

import { Theme } from "../theme.slint";

export component StatCard inherits Rectangle {
    in property <brush>  accent;
    in property <string> value;
    in property <string> label;
    /// Дрібний підпис під label. Якщо порожній — не відображається.
    in property <string> secondary: "";

    background: Theme.bg-card;
    border-radius: 10px; // навмисно між radius-md(8) і radius-lg(12) — не замінювати
    border-width: 1px;
    border-color: Theme.border;
    height: 84px;
    horizontal-stretch: 1;
    clip: true;

    // Кольорова акцентна лінія зверху
    Rectangle {
        x: 0; y: 0;
        width: parent.width;
        height: 3px;
        background: root.accent;
    }

    VerticalLayout {
        padding-top: Theme.space-3;
        padding-left: Theme.space-4;
        padding-right: Theme.space-4;
        padding-bottom: Theme.space-2;
        spacing: 2px;

        Text {
            text: root.value;
            font-size: 20px; // навмисно між font-xl(16) і font-2xl(18) — не замінювати
            font-weight: 700;
            color: Theme.text-primary;
            overflow: elide;
        }

        Text {
            text: root.label;
            font-size: Theme.font-sm;
            font-weight: 500;
            color: Theme.text-second;
        }

        if root.secondary != "" : Text {
            text: root.secondary;
            font-size: Theme.font-xs;
            color: Theme.text-muted;
        }
    }
}
