// Компонент: єдиний список документів (Акти + Рахунки + Накладні)
//
// Відображає всі документи компанії з типовим бейджем (АКТ/РАХ/НАК),
// фільтром по типу (таби) і текстовим пошуком.
//
// Адаптовано з Figma: DocumentsListScreen (nodes 178:2)

import { Theme } from "../theme.slint";
import { ProgressIndicator, ComboBox, ListView } from "std-widgets.slint";
import { DocTypeBadge, StatusBadge, ConfirmDeleteDialog } from "../components/shared.slint";

// ── DocRow — рядок уніфікованого списку документів ───────────────────────────
export struct DocRow {
    id:           string,   // UUID (рядок, передається назад у колбеки)
    doc-type:     string,   // "АКТ" | "РАХ" | "НАК"
    number:       string,
    counterparty: string,
    amount:       string,   // відформатована сума, напр. "78 000,00 ₴"
    date:         string,   // "ДД.ММ.РРРР"
    status:       string,   // "Чернетка" | "Виставлений" | "Підписаний" | "Оплачений"
}

export component DocumentList {

    // ── Вхідні дані ─────────────────────────────────────────────────────────
    in property <[DocRow]> rows;
    in property <bool>     loading: false;
    in property <int>      direction-index: 0; // 0=Вихідні, 1=Вхідні
    in property <int>      active-tab: 0;   // 0=Всі, 1=Акти, 2=Рахунки

    // ── Фільтри ─────────────────────────────────────────────────────────────
    in property <[string]> filter-counterparty-names: [];
    in property <int>      filter-counterparty-index: 0;

    // ── Колбеки ─────────────────────────────────────────────────────────────
    callback new-document-act();
    callback new-document-invoice();
    callback open-document(string);     // передає DocRow.id
    callback delete-document(string);   // передає DocRow.id
    callback export-pdf(string);        // передає DocRow.id
    callback direction-changed(int);
    callback tab-changed(int);
    callback search-changed(string);
    callback counterparty-filter-changed(int);
    callback date-from-changed(string);
    callback date-to-changed(string);

    // ── Внутрішній стан ─────────────────────────────────────────────────────
    private property <string> delete-target-id: "";
    private property <bool>   show-delete-dialog: false;
    private property <bool>   show-type-picker: false;
    private property <int>    hovered-row: -1;

    min-width: 600px;
    min-height: 400px;

    VerticalLayout {
        spacing: 0;
        padding: 0;

        // ── Topbar (64px, білий, з нижньою межею) ───────────────────────────
        Rectangle {
            height: Theme.topbar-height;
            vertical-stretch: 0;
            background: Theme.bg-card;

            HorizontalLayout {
                padding-left: 32px;
                padding-right: 32px;
                spacing: 16px;
                alignment: center;

                Text {
                    text: "Документи";
                    font-size: Theme.font-2xl;
                    font-weight: 600;
                    color: Theme.text-primary;
                    horizontal-stretch: 1;
                    vertical-alignment: center;
                }

                // Кнопка "+ Новий документ"
                if root.direction-index == 0 : new-rect := Rectangle {
                    width: 160px;
                    height: Theme.btn-md-height;
                    border-radius: Theme.radius-md;
                    background: new-touch.has-hover ? #2D64E3 : Theme.primary;
                    animate background { duration: 120ms; easing: ease; }
                    drop-shadow-blur: 8px;
                    drop-shadow-color: rgba(0, 0, 0, 15%);
                    drop-shadow-offset-y: 2px;

                    Text {
                        x: 0; y: 0;
                        width: parent.width; height: parent.height;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        text: "+ Новий документ";
                        font-size: Theme.font-md;
                        font-weight: 600;
                        color: Theme.text-white;
                    }

                    new-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.show-type-picker = true; }
                    }
                }
            }

            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: Theme.border;
            }
        }

        // ── Таби + пошук ─────────────────────────────────────────────────────
        Rectangle {
            height: 44px;
            vertical-stretch: 0;
            background: Theme.bg-card;
            border-width: 1px;
            border-color: Theme.border;

            HorizontalLayout {
                padding-left: 32px;
                padding-right: 32px;
                spacing: 8px;

                // Таби напрямку документів
                for dir-label[i] in ["Вихідні", "Вхідні"]: Rectangle {
                    width: 92px;
                    height: 32px;
                    border-radius: Theme.radius-md;
                    background: root.direction-index == i
                        ? Theme.primary
                        : (dir-touch.has-hover ? Theme.bg-hover : Theme.bg-gray);
                    border-width: root.direction-index == i ? 0 : 1px;
                    border-color: Theme.border;
                    animate background { duration: 100ms; easing: ease; }

                    Text {
                        text: dir-label;
                        font-size: Theme.font-md;
                        font-weight: root.direction-index == i ? 600 : 400;
                        color: root.direction-index == i ? Theme.text-white : Theme.text-second;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        animate color { duration: 100ms; easing: ease; }
                    }

                    dir-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.direction-changed(i);
                        }
                    }
                }

                Rectangle { width: 8px; }

                // Таби типу документу
                for lbl[i] in ["Всі", "Акти", "Накладні"]: Rectangle {
                    width: i == 0 ? 68px : (i == 1 ? 76px : 98px);
                    height: 32px;
                    border-radius: Theme.radius-md;
                    background: root.active-tab == i
                        ? Theme.primary
                        : (tab-touch.has-hover ? Theme.bg-hover : Theme.bg-gray);
                    border-width: root.active-tab == i ? 0 : 1px;
                    border-color: Theme.border;
                    animate background { duration: 100ms; easing: ease; }

                    Text {
                        text: lbl;
                        font-size: Theme.font-md;
                        font-weight: root.active-tab == i ? 600 : 400;
                        color: root.active-tab == i ? Theme.text-white : Theme.text-second;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        animate color { duration: 100ms; easing: ease; }
                    }

                    tab-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.tab-changed(i);
                        }
                    }
                }

                Rectangle { horizontal-stretch: 1; }

                // Пошук
                search-box := Rectangle {
                    width: 320px;
                    height: 32px;
                    border-radius: Theme.radius-md;
                    background: Theme.bg-gray;
                    border-width: 1px;
                    border-color: Theme.border;

                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 8px;
                        spacing: 6px;

                        Text {
                            text: "🔍";
                            font-size: 12px;
                            color: Theme.text-disabled;
                            vertical-alignment: center;
                        }

                        TextInput {
                            font-size: Theme.font-md;
                            color: Theme.text-primary;
                            horizontal-stretch: 1;
                            vertical-alignment: center;
                            edited => { root.search-changed(self.text); }
                        }
                    }
                }
            }
        }

        // ── Рядок фільтрів ───────────────────────────────────────────────────
        Rectangle {
            height: 44px;
            vertical-stretch: 0;
            background: Theme.bg-card;
            border-width: 1px;
            border-color: Theme.border;

            HorizontalLayout {
                padding-left: 32px;
                padding-right: 32px;
                spacing: 8px;
                alignment: center;

                Text {
                    text: "Контрагент:";
                    font-size: Theme.font-base;
                    color: Theme.text-second;
                    vertical-alignment: center;
                    width: 82px;
                }

                ComboBox {
                    width: 200px;
                    height: 28px;
                    model: root.filter-counterparty-names;
                    current-index: root.filter-counterparty-index;
                    selected(val) => { root.counterparty-filter-changed(self.current-index); }
                }

                Rectangle { width: 16px; }

                Text {
                    text: "Дата від:";
                    font-size: Theme.font-base;
                    color: Theme.text-second;
                    vertical-alignment: center;
                    width: 56px;
                }

                // Дата від
                date-from-box := Rectangle {
                    width: 110px; height: 28px;
                    border-radius: Theme.radius-md;
                    background: Theme.bg-gray;
                    border-width: 1px;
                    border-color: Theme.border;
                    clip: true;

                    if date-from-input.text == "" : Text {
                        x: 8px; y: 0;
                        width: parent.width - 8px; height: parent.height;
                        text: "дд.мм.рррр";
                        font-size: Theme.font-base;
                        color: Theme.text-disabled;
                        vertical-alignment: center;
                    }

                    date-from-input := TextInput {
                        x: 8px; y: 0;
                        width: parent.width - 16px; height: parent.height;
                        font-size: Theme.font-base;
                        color: Theme.text-primary;
                        vertical-alignment: center;
                        edited => { root.date-from-changed(self.text); }
                    }
                }

                Text {
                    text: "—";
                    font-size: Theme.font-base;
                    color: Theme.text-muted;
                    vertical-alignment: center;
                    width: 10px;
                }

                // Дата до
                date-to-box := Rectangle {
                    width: 110px; height: 28px;
                    border-radius: Theme.radius-md;
                    background: Theme.bg-gray;
                    border-width: 1px;
                    border-color: Theme.border;
                    clip: true;

                    if date-to-input.text == "" : Text {
                        x: 8px; y: 0;
                        width: parent.width - 8px; height: parent.height;
                        text: "дд.мм.рррр";
                        font-size: Theme.font-base;
                        color: Theme.text-disabled;
                        vertical-alignment: center;
                    }

                    date-to-input := TextInput {
                        x: 8px; y: 0;
                        width: parent.width - 16px; height: parent.height;
                        font-size: Theme.font-base;
                        color: Theme.text-primary;
                        vertical-alignment: center;
                        edited => { root.date-to-changed(self.text); }
                    }
                }

                Rectangle { horizontal-stretch: 1; }
            }
        }

        // ── Таблиця ──────────────────────────────────────────────────────────
        if root.loading : ProgressIndicator {
            indeterminate: true;
            vertical-stretch: 0;
        }

        Rectangle {
            vertical-stretch: 1;
            background: Theme.bg-page;

            VerticalLayout {
                padding-top: 24px;
                padding-left: 32px;
                padding-right: 32px;
                padding-bottom: 24px;
                spacing: 0;

                Rectangle {
                    vertical-stretch: 1;
                    border-radius: Theme.radius-md;
                    border-width: 1px;
                    border-color: Theme.border;
                    clip: true;

                    VerticalLayout {
                        spacing: 0;

                        // Заголовок таблиці
                        Rectangle {
                            height: 40px;
                            vertical-stretch: 0;
                            background: Theme.table-header;

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;
                                spacing: 0;

                                Text { text: "Тип";        font-size: Theme.font-base; font-weight: 500; color: Theme.text-second; vertical-alignment: center; width: 68px; }
                                Text { text: "Номер";      font-size: Theme.font-base; font-weight: 500; color: Theme.text-second; vertical-alignment: center; width: 160px; }
                                Text { text: "Контрагент"; font-size: Theme.font-base; font-weight: 500; color: Theme.text-second; vertical-alignment: center; horizontal-stretch: 1; }
                                Text { text: "Сума ₴";     font-size: Theme.font-base; font-weight: 500; color: Theme.text-second; vertical-alignment: center; width: 130px; }
                                Text { text: "Дата";       font-size: Theme.font-base; font-weight: 500; color: Theme.text-second; vertical-alignment: center; width: 100px; }
                                Text { text: "Статус";     font-size: Theme.font-base; font-weight: 500; color: Theme.text-second; vertical-alignment: center; width: 120px; }
                                Text { text: "Дії";        font-size: Theme.font-base; font-weight: 500; color: Theme.text-second; vertical-alignment: center; horizontal-alignment: center; width: 100px; }
                            }
                        }

                        // Порожній стан
                        if root.rows.length == 0 : Rectangle {
                            vertical-stretch: 1;
                            background: Theme.bg-card;

                            VerticalLayout {
                                alignment: center;
                                spacing: 8px;

                                Text {
                                    text: "📄";
                                    font-size: 32px;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: root.direction-index == 1
                                        ? "Вхідних документів не знайдено"
                                        : "Документів ще немає";
                                    font-size: 15px;
                                    font-weight: 500;
                                    color: Theme.text-second;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: root.direction-index == 1
                                        ? "Документи від контрагентів з'являться тут"
                                        : "Натисніть «+ Новий документ» щоб створити перший";
                                    font-size: Theme.font-md;
                                    color: Theme.text-muted;
                                    horizontal-alignment: center;
                                }
                            }
                        }

                        // Рядки
                        if root.rows.length > 0 : ListView {
                            vertical-stretch: 1;

                            for row[i] in root.rows: Rectangle {
                                height: Theme.row-height;
                                background: root.hovered-row == i
                                    ? Theme.row-hover
                                    : (Math.mod(i, 2) == 0 ? Theme.bg-card : Theme.row-stripe);
                                border-width: 1px;
                                border-color: Theme.border;
                                animate background { duration: 80ms; easing: ease; }
                                clip: true;

                                // Ліва акцентна смужка при ховері
                                if root.hovered-row == i : Rectangle {
                                    x: 0; y: 0; width: 3px; height: Theme.row-height;
                                    background: Theme.primary;
                                    border-radius: 1px;
                                }

                                row-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    pointer-event(e) => {
                                        if e.kind == PointerEventKind.move {
                                            root.hovered-row = i;
                                        }
                                    }
                                    clicked => { root.open-document(row.id); }
                                }

                                HorizontalLayout {
                                    padding-left: 16px;
                                    padding-right: 16px;
                                    spacing: 0;

                                    // Тип (DocTypeBadge)
                                    Rectangle {
                                        width: 68px;
                                        DocTypeBadge {
                                            doc-type: row.doc-type;
                                            y: (Theme.row-height - self.height) / 2;
                                        }
                                    }

                                    // Номер
                                    Text {
                                        text: row.number;
                                        font-size: Theme.font-md;
                                        font-weight: 600;
                                        color: Theme.primary;
                                        vertical-alignment: center;
                                        overflow: elide;
                                        width: 160px;
                                    }

                                    // Контрагент
                                    Text {
                                        text: row.counterparty;
                                        font-size: Theme.font-base;
                                        color: Theme.text-primary;
                                        vertical-alignment: center;
                                        overflow: elide;
                                        horizontal-stretch: 1;
                                    }

                                    // Сума
                                    Text {
                                        text: row.amount;
                                        font-size: Theme.font-md;
                                        font-weight: 600;
                                        color: Theme.text-primary;
                                        vertical-alignment: center;
                                        width: 130px;
                                    }

                                    // Дата
                                    Text {
                                        text: row.date;
                                        font-size: Theme.font-base;
                                        color: Theme.text-second;
                                        vertical-alignment: center;
                                        width: 100px;
                                    }

                                    // Статус
                                    Rectangle {
                                        width: 120px;
                                        StatusBadge {
                                            status: row.status;
                                            y: (Theme.row-height - self.height) / 2;
                                        }
                                    }

                                    // Кнопки дій
                                    HorizontalLayout {
                                        width: 100px;
                                        spacing: 4px;
                                        alignment: center;

                                        // PDF
                                        pdf-rect := Rectangle {
                                            width: 34px;
                                            height: 30px;
                                            border-radius: Theme.radius-sm;
                                            background: pdf-touch.has-hover ? Theme.bg-primary : transparent;
                                            animate background { duration: 80ms; easing: ease; }

                                            Text {
                                                text: "PDF";
                                                font-size: Theme.font-xs;
                                                font-weight: 600;
                                                color: pdf-touch.has-hover ? Theme.primary : Theme.text-muted;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                                animate color { duration: 80ms; easing: ease; }
                                            }

                                            pdf-touch := TouchArea {
                                                mouse-cursor: pointer;
                                                clicked => { root.export-pdf(row.id); }
                                            }
                                        }

                                        // Редагувати
                                        edit-rect := Rectangle {
                                            width: 30px;
                                            height: 30px;
                                            border-radius: Theme.radius-sm;
                                            background: edit-touch.has-hover ? Theme.btn-action-bg : transparent;
                                            animate background { duration: 80ms; easing: ease; }

                                            Text {
                                                text: "✎";
                                                font-size: 14px;
                                                color: edit-touch.has-hover ? Theme.primary : Theme.text-muted;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                                animate color { duration: 80ms; easing: ease; }
                                            }

                                            edit-touch := TouchArea {
                                                mouse-cursor: pointer;
                                                clicked => { root.open-document(row.id); }
                                            }
                                        }

                                        // Видалити
                                        del-rect := Rectangle {
                                            width: 30px;
                                            height: 30px;
                                            border-radius: Theme.radius-sm;
                                            background: del-touch.has-hover ? Theme.bg-danger : transparent;
                                            animate background { duration: 80ms; easing: ease; }

                                            Text {
                                                text: "🗑";
                                                font-size: 13px;
                                                color: del-touch.has-hover ? Theme.danger : Theme.text-muted;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                                animate color { duration: 80ms; easing: ease; }
                                            }

                                            del-touch := TouchArea {
                                                mouse-cursor: pointer;
                                                clicked => {
                                                    root.delete-target-id = row.id;
                                                    root.show-delete-dialog = true;
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // ── Тайп-пікер: вибір типу нового документу ────────────────────────────
    if root.show-type-picker : Rectangle {
        x: 0; y: 0;
        width: root.width; height: root.height;
        background: Theme.overlay;

        backdrop-touch := TouchArea {
            clicked => { root.show-type-picker = false; }
        }

        // Картка вибору типу
        picker-card := Rectangle {
            x: (parent.width - 400px) / 2;
            y: (parent.height - 220px) / 2;
            width: 400px; height: 220px;
            border-radius: Theme.radius-xl;
            background: Theme.bg-card;
            drop-shadow-blur: 40px;
            drop-shadow-color: rgba(0, 0, 0, 18%);
            drop-shadow-offset-y: 12px;

            // Поглинаємо кліки щоб не закривати через backdrop
            TouchArea { }

            // Акцентна смужка зверху
            Rectangle {
                x: 0; y: 0; width: 400px; height: 4px;
                border-top-left-radius: Theme.radius-xl;
                border-top-right-radius: Theme.radius-xl;
                background: Theme.primary;
            }

            Text {
                x: 0; y: 22px; width: 400px;
                horizontal-alignment: center;
                text: "Новий документ";
                font-size: Theme.font-2xl;
                font-weight: 700;
                color: Theme.text-primary;
            }
            Text {
                x: 0; y: 52px; width: 400px;
                horizontal-alignment: center;
                text: "Оберіть тип документу";
                font-size: Theme.font-md;
                color: Theme.text-second;
            }

            // Тайл АКТ
            act-tile := Rectangle {
                x: 20px; y: 88px;
                width: 170px; height: 76px;
                border-radius: Theme.radius-lg;
                background: act-tile-touch.has-hover ? Theme.bg-primary : Theme.bg-gray;
                border-width: 1px;
                border-color: act-tile-touch.has-hover ? Theme.primary : Theme.border;
                animate background { duration: 100ms; easing: ease; }

                Text {
                    x: 0; y: 12px; width: 170px;
                    horizontal-alignment: center;
                    text: "АКТ";
                    font-size: Theme.font-xl;
                    font-weight: 700;
                    color: act-tile-touch.has-hover ? Theme.primary : Theme.text-second;
                    animate color { duration: 100ms; easing: ease; }
                }
                Text {
                    x: 0; y: 40px; width: 170px;
                    horizontal-alignment: center;
                    text: "Акт виконаних робіт";
                    font-size: Theme.font-base;
                    color: Theme.text-muted;
                }

                act-tile-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        root.show-type-picker = false;
                        root.new-document-act();
                    }
                }
            }

            // Тайл НАК
            inv-tile := Rectangle {
                x: 210px; y: 88px;
                width: 170px; height: 76px;
                border-radius: Theme.radius-lg;
                background: inv-tile-touch.has-hover ? Theme.bg-purple : Theme.bg-gray;
                border-width: 1px;
                border-color: inv-tile-touch.has-hover ? Theme.purple : Theme.border;
                animate background { duration: 100ms; easing: ease; }

                Text {
                    x: 0; y: 12px; width: 170px;
                    horizontal-alignment: center;
                    text: "НАК";
                    font-size: Theme.font-xl;
                    font-weight: 700;
                    color: inv-tile-touch.has-hover ? Theme.purple : Theme.text-second;
                    animate color { duration: 100ms; easing: ease; }
                }
                Text {
                    x: 0; y: 40px; width: 170px;
                    horizontal-alignment: center;
                    text: "Видаткова накладна";
                    font-size: Theme.font-base;
                    color: Theme.text-muted;
                }

                inv-tile-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        root.show-type-picker = false;
                        root.new-document-invoice();
                    }
                }
            }
        }
    }

    // ── Діалог підтвердження видалення ──────────────────────────────────────
    if root.show-delete-dialog : ConfirmDeleteDialog {
        x: 0; y: 0;
        width: root.width; height: root.height;
        title: "Видалити документ?";
        message: "Документ буде видалено назавжди.\nЦю дію не можна скасувати.";
        confirm-label: "Так, видалити";
        confirmed => {
            root.delete-document(root.delete-target-id);
            root.show-delete-dialog = false;
        }
        cancelled => { root.show-delete-dialog = false; }
    }
}
