export global Theme {
    out property <color> bg: #F9F9FA;
    out property <color> surface: #FFFFFF;
    out property <color> border: #E4E4E8;
    out property <color> sidebar-bg: #2C303A;
    out property <color> sidebar-border: #3A404B;
    out property <color> sidebar-hover: #353B47;
    out property <color> sidebar-text: #CDD3DE;
    out property <color> sidebar-text-muted: #828A98;
    out property <color> sidebar-switcher-bg: #363C48;
    out property <color> sidebar-switcher-hover: #404653;
    out property <color> primary: #3D75F4;
    out property <color> primary-light: #ECF1FF;
    out property <color> text-main: #1A1A1F;
    out property <color> text-sub: #6F6F7D;
    out property <color> text-muted: #ABABB7;
    out property <color> success: #1EB16E;
    out property <color> warning: #F4A31E;
    out property <color> row-alt: #F5F5F8;
    out property <color> hover-bg: #F3F5FA;
    out property <color> overlay: #10141C73;

    // ── Таблиці / рядки ──────────────────────────────────────────────────────
    out property <color> table-header:  #F4F6FA;   // фон заголовку таблиці
    out property <color> row-stripe:    #FCFCFD;   // непарні рядки (zebra)
    out property <color> row-hover:     #EEEEF5;   // наведення на рядок
    out property <color> row-selected:  #EFF1FE;   // вибраний рядок

    // ── Кнопки дій ───────────────────────────────────────────────────────────
    out property <color> btn-action-bg: #EEF2FF;   // світло-синій фон secondary-кнопок

    // ── Небезпечні дії ───────────────────────────────────────────────────────
    out property <color> danger:        #DC2626;   // червоний текст / іконка
    out property <color> danger-light:  #FEF2F2;   // фон кнопки "Видалити"
    out property <color> danger-border: #FECACA;   // межа кнопки "Видалити"

    // ── Пріоритети ────────────────────────────────────────────────────────────
    out property <color> priority-high:     #F97316;   // помаранчевий (Високий)
    out property <color> priority-critical: #DC2626;   // червоний (Критичний)
}
