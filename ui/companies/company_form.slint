// Форма створення / редагування компанії
//
// is-edit = false → "Нова компанія"
// is-edit = true  → "Редагувати компанію" (edit-id заповнено)

import { LineEdit, CheckBox, ScrollView } from "std-widgets.slint";
import { Theme } from "../theme.slint";

export component CompanyForm inherits Rectangle {
    min-width: 400px;
    min-height: 300px;
    background: Theme.bg;

    in property <bool>   is-edit: false;
    in property <string> edit-id: "";
    in property <string> form-name: "";
    in property <string> form-edrpou: "";
    in property <string> form-iban: "";
    in property <string> form-legal-address: "";
    in property <string> form-director-name: "";
    in property <string> form-accountant-name: "";
    in property <bool>   form-is-vat-payer: false;

    // Параметри: назва, ЄДРПОУ, IBAN, юр.адреса, директор, бухгалтер, платник ПДВ
    callback save(string, string, string, string, string, string, bool);
    callback update(string /*id*/, string, string, string, string, string, string, bool);
    callback cancel();

    // Двостороннє зв'язування з полями вводу (<=> не розривається при введенні)
    private property v-name       <=> name-edit.text;
    private property v-edrpou     <=> edrpou-edit.text;
    private property v-iban       <=> iban-edit.text;
    private property v-address    <=> address-edit.text;
    private property v-director   <=> director-edit.text;
    private property v-accountant <=> accountant-edit.text;
    private property v-vat        <=> vat-check.checked;

    VerticalLayout {
        spacing: 0;

        // ── Topbar ─────────────────────────────────────────────────────────
        Rectangle {
            height: 64px;
            background: Theme.surface;

            Rectangle {
                y: 63px;
                height: 1px;
                background: Theme.border;
            }

            HorizontalLayout {
                padding-left: 32px;
                padding-right: 32px;
                spacing: 8px;
                alignment: center;

                HorizontalLayout {
                    spacing: 6px;
                    horizontal-stretch: 1;
                    alignment: start;

                    Text {
                        text: "← Компанії";
                        font-size: 14px;
                        color: Theme.primary;
                        vertical-alignment: center;
                        TouchArea {
                            width: 100%; height: 100%;
                            mouse-cursor: pointer;
                            clicked => { root.cancel(); }
                        }
                    }
                    Text {
                        text: "/";
                        font-size: 14px;
                        color: Theme.text-muted;
                        vertical-alignment: center;
                    }
                    Text {
                        text: root.is-edit ? "Редагувати компанію" : "Нова компанія";
                        font-size: 14px;
                        font-weight: 600;
                        color: Theme.text-main;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    width: 120px;
                    height: 36px;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: Theme.border;
                    background: co-cancel-touch.has-hover ? Theme.hover-bg : Theme.bg;
                    animate background { duration: 80ms; }

                    Text {
                        text: "Скасувати";
                        font-size: 14px;
                        color: Theme.text-sub;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    co-cancel-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.cancel(); }
                    }
                }

                Rectangle {
                    width: 112px;
                    height: 36px;
                    border-radius: 8px;
                    background: co-save-touch.has-hover ? #2D64E3 : Theme.primary;
                    animate background { duration: 80ms; }

                    Text {
                        text: root.is-edit ? "Зберегти" : "Створити";
                        font-size: 14px;
                        font-weight: 600;
                        color: #ffffff;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    co-save-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            if root.is-edit {
                                root.update(
                                    root.edit-id,
                                    root.v-name, root.v-edrpou, root.v-iban,
                                    root.v-address, root.v-director, root.v-accountant,
                                    root.v-vat
                                );
                            } else {
                                root.save(
                                    root.v-name, root.v-edrpou, root.v-iban,
                                    root.v-address, root.v-director, root.v-accountant,
                                    root.v-vat
                                );
                            }
                        }
                    }
                }
            }
        }

        // ── Контент ────────────────────────────────────────────────────────
        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding: 32px;
                spacing: 12px;

                // Назва (обов'язково)
                VerticalLayout {
                    spacing: 4px;
                    Text { text: "Назва *"; font-size: 12px; color: Theme.text-sub; }
                    name-edit := LineEdit {
                        text: root.form-name;
                        placeholder-text: "ТОВ «Назва компанії»";
                    }
                }

                // ЄДРПОУ
                VerticalLayout {
                    spacing: 4px;
                    Text { text: "ЄДРПОУ"; font-size: 12px; color: Theme.text-sub; }
                    edrpou-edit := LineEdit {
                        text: root.form-edrpou;
                        placeholder-text: "12345678";
                    }
                }

                // IBAN
                VerticalLayout {
                    spacing: 4px;
                    Text { text: "IBAN"; font-size: 12px; color: Theme.text-sub; }
                    iban-edit := LineEdit {
                        text: root.form-iban;
                        placeholder-text: "UA123456789012345678901234567";
                    }
                }

                // Юридична адреса
                VerticalLayout {
                    spacing: 4px;
                    Text { text: "Юридична адреса"; font-size: 12px; color: Theme.text-sub; }
                    address-edit := LineEdit {
                        text: root.form-legal-address;
                        placeholder-text: "м. Київ, вул. Хрещатик, 1";
                    }
                }

                // Директор
                VerticalLayout {
                    spacing: 4px;
                    Text { text: "Директор (ПІБ)"; font-size: 12px; color: Theme.text-sub; }
                    director-edit := LineEdit {
                        text: root.form-director-name;
                        placeholder-text: "Іванов Іван Іванович";
                    }
                }

                // Бухгалтер
                VerticalLayout {
                    spacing: 4px;
                    Text { text: "Бухгалтер (ПІБ)"; font-size: 12px; color: Theme.text-sub; }
                    accountant-edit := LineEdit {
                        text: root.form-accountant-name;
                        placeholder-text: "Петренко Петро Петрович";
                    }
                }

                // Платник ПДВ
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    vat-check := CheckBox {
                        text: "Платник ПДВ";
                        checked: root.form-is-vat-payer;
                    }
                }
            }
        }
    }
}
