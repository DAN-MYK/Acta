// Список компаній — управління, вибір активної та швидкий перехід.

import { Button, ScrollView } from "std-widgets.slint";
import { Theme } from "../theme.slint";

export struct CompanyItem {
    id:           string,
    name:         string,
    short_name:   string,
    edrpou:       string,
    is_vat:       bool,
    act_count:    int,
    total_amount: string,
    is_current:   bool,
    initials:     string,
}

component MetricPill inherits Rectangle {
    in property <string> label;
    in property <string> value;

    height: 54px;
    border-radius: 12px;
    background: Theme.hover-bg;
    border-width: 1px;
    border-color: #E5E9F2;

    VerticalLayout {
        padding: 10px;
        spacing: 2px;

        Text {
            text: root.label;
            font-size: 11px;
            color: Theme.text-muted;
        }

        Text {
            text: root.value;
            font-size: 15px;
            font-weight: 700;
            color: Theme.text-main;
        }
    }
}

export component CompanyList {
    in property <[CompanyItem]> companies;
    in property <bool>          loading: false;

    callback add();
    callback edit(string /*id*/);
    callback archive(string /*id*/);
    callback select(string /*id*/);

    VerticalLayout {
        padding: 32px;
        spacing: 20px;

        HorizontalLayout {
            spacing: 12px;

            VerticalLayout {
                horizontal-stretch: 1;
                spacing: 6px;

                Text {
                    text: "Управління компаніями";
                    font-size: 28px;
                    font-weight: 700;
                    color: Theme.text-main;
                }

                Text {
                    text: "Оберіть активну компанію для роботи або відредагуйте дані в каталозі.";
                    font-size: 14px;
                    color: Theme.text-sub;
                }
            }

            Button {
                text: "+ Додати компанію";
                primary: true;
                clicked => { root.add(); }
            }
        }

        Rectangle {
            height: 48px;
            border-radius: 14px;
            background: Theme.surface;
            border-width: 1px;
            border-color: Theme.border;

            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;
                spacing: 10px;
                alignment: center;

                Text {
                    text: "Пошук";
                    font-size: 13px;
                    color: Theme.text-muted;
                }

                Rectangle {
                    horizontal-stretch: 1;
                    background: transparent;
                    Text {
                        text: "Назва компанії або ЄДРПОУ";
                        font-size: 14px;
                        color: #A1A8B3;
                        vertical-alignment: center;
                    }
                }
            }
        }

        if root.companies.length == 0 && !root.loading : Rectangle {
            vertical-stretch: 1;
            border-radius: 20px;
            background: Theme.surface;
            border-width: 1px;
            border-color: Theme.border;

            VerticalLayout {
                alignment: center;
                spacing: 14px;

                Rectangle {
                    width: 72px;
                    height: 72px;
                    border-radius: 20px;
                    background: Theme.primary-light;

                    Text {
                        text: "КО";
                        font-size: 26px;
                        font-weight: 700;
                        color: Theme.primary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Text {
                    text: "Ще немає жодної компанії";
                    font-size: 18px;
                    font-weight: 600;
                    color: Theme.text-main;
                    horizontal-alignment: center;
                }

                Text {
                    text: "Створіть першу компанію, щоб почати вести управлінський облік.";
                    font-size: 13px;
                    color: Theme.text-sub;
                    horizontal-alignment: center;
                }

                Button {
                    text: "+ Додати першу компанію";
                    primary: true;
                    clicked => { root.add(); }
                }
            }
        }

        if root.companies.length > 0 : ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                spacing: 16px;

                for c in root.companies : Rectangle {
                    height: 196px;
                    border-radius: 24px;
                    border-width: 1px;
                    border-color: c.is_current ? Theme.primary : Theme.border;
                    background: card-touch.has-hover ? Theme.hover-bg : Theme.surface;

                    animate background { duration: 120ms; }

                    card-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.select(c.id); }

                        VerticalLayout {
                            padding: 20px;
                            spacing: 16px;

                            HorizontalLayout {
                                spacing: 14px;
                                alignment: center;

                                Rectangle {
                                    width: 56px;
                                    height: 56px;
                                    border-radius: 18px;
                                    background: c.is_current ? Theme.primary : Theme.primary-light;

                                    Text {
                                        text: c.initials;
                                        font-size: 18px;
                                        font-weight: 700;
                                        color: c.is_current ? white : Theme.primary;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 4px;

                                    Text {
                                        text: c.short_name != "" ? c.short_name : c.name;
                                        font-size: 18px;
                                        font-weight: 700;
                                        color: Theme.text-main;
                                    }

                                    Text {
                                        text: c.edrpou != "" ? "ЄДРПОУ: " + c.edrpou : "ЄДРПОУ не вказано";
                                        font-size: 13px;
                                        color: Theme.text-sub;
                                    }
                                }

                                if c.is_current : Rectangle {
                                    height: 28px;
                                    border-radius: 14px;
                                    background: Theme.primary-light;
                                    border-width: 1px;
                                    border-color: #C8D8FF;

                                    Text {
                                        text: "Поточна";
                                        color: Theme.primary;
                                        font-size: 12px;
                                        font-weight: 700;
                                        vertical-alignment: center;
                                        horizontal-alignment: center;
                                    }
                                }

                                if c.is_vat : Rectangle {
                                    height: 28px;
                                    border-radius: 14px;
                                    background: #EAF7EE;
                                    border-width: 1px;
                                    border-color: #C6E7D1;

                                    Text {
                                        text: "ПДВ";
                                        color: #1F7A42;
                                        font-size: 12px;
                                        font-weight: 700;
                                        vertical-alignment: center;
                                        horizontal-alignment: center;
                                    }
                                }
                            }

                            HorizontalLayout {
                                spacing: 12px;

                                MetricPill {
                                    horizontal-stretch: 1;
                                    label: "Актів";
                                    value: c.act_count + "";
                                }

                                MetricPill {
                                    horizontal-stretch: 1;
                                    label: "Сума актів";
                                    value: c.total_amount;
                                }
                            }

                            HorizontalLayout {
                                spacing: 10px;

                                Button {
                                    text: c.is_current ? "Відкрита зараз" : "Перейти";
                                    primary: !c.is_current;
                                    enabled: true;
                                    clicked => { root.select(c.id); }
                                }

                                Button {
                                    text: "Редагувати";
                                    clicked => { root.edit(c.id); }
                                }

                                Button {
                                    text: "Архівувати";
                                    clicked => { root.archive(c.id); }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
