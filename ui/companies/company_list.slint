// Список компаній — управління (додавання, редагування, архівування).
// Структура ідентична іншим спискам проєкту (counterparty_list, act_list, invoice_list):
//   - Topbar 64px (заголовок + кнопка)
//   - Таблиця 40px header + 52px рядки + hover
//   - Пуста-стан по центру (тільки для порожнього списку)

import { ListView, ProgressIndicator } from "std-widgets.slint";
import { Theme } from "../theme.slint";

export struct CompanyItem {
    id:           string,
    name:         string,
    short-name:   string,
    edrpou:       string,
    is-vat:       bool,
    act-count:    int,
    total-amount: string,
    is-current:   bool,
    initials:     string,
}

export component CompanyList {
    in property <[CompanyItem]> companies;
    in property <bool>          loading: false;

    callback add();
    callback edit(string /*id*/);
    callback archive(string /*id*/);
    callback select(string /*id*/);

    min-width: 600px;
    min-height: 400px;

    VerticalLayout {
        spacing: 0;
        padding: 0;

        // ── Topbar (64px, білий, з нижньою межею) ───────────────────────────
        Rectangle {
            height: 64px;
            background: Theme.surface;

            HorizontalLayout {
                padding-left: 32px;
                padding-right: 32px;

                Text {
                    text: "Компанії";
                    font-size: 18px;
                    font-weight: 600;
                    color: Theme.text-main;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                new-btn := Rectangle {
                    background: Theme.primary;
                    border-radius: 8px;
                    height: 36px;
                    width: 180px;
                    y: (parent.height - self.height) / 2;

                    Text {
                        text: "+ Нова компанія";
                        color: #ffffff;
                        font-size: 13px;
                        font-weight: 500;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.add(); }
                    }
                }
            }

            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: Theme.border;
            }
        }

        // ── Основний контент ─────────────────────────────────────────────────
        Rectangle {
            background: Theme.bg;
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: 24px;
                padding-left: 32px;
                padding-right: 32px;
                padding-bottom: 24px;
                spacing: 16px;

                if root.loading : ProgressIndicator {
                    indeterminate: true;
                    vertical-stretch: 0;
                }

                // ── Таблиця ──────────────────────────────────────────────────
                Rectangle {
                    vertical-stretch: 1;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: Theme.border;
                    clip: true;

                    VerticalLayout {
                        spacing: 0;

                        // Заголовок таблиці
                        Rectangle {
                            height: 40px;
                            background: #F1F1F4;

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;
                                spacing: 12px;

                                Text { text: "Компанія";   color: Theme.text-sub; font-size: 12px; font-weight: 500; horizontal-stretch: 3; vertical-alignment: center; }
                                Text { text: "ЄДРПОУ";     color: Theme.text-sub; font-size: 12px; font-weight: 500; horizontal-stretch: 1; vertical-alignment: center; }
                                Text { text: "Актів";      color: Theme.text-sub; font-size: 12px; font-weight: 500; width: 60px;           vertical-alignment: center; }
                                Text { text: "Оборот, ₴"; color: Theme.text-sub; font-size: 12px; font-weight: 500; horizontal-stretch: 2; vertical-alignment: center; }
                                Text { text: "Дії";        color: Theme.text-sub; font-size: 12px; font-weight: 500; width: 172px;          vertical-alignment: center; }
                            }
                        }

                        // Порожній стан
                        if !root.loading && root.companies.length == 0 : Rectangle {
                            vertical-stretch: 1;
                            background: Theme.surface;

                            VerticalLayout {
                                alignment: center;
                                spacing: 8px;

                                Text {
                                    text: "🏢";
                                    font-size: 32px;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: "Компаній ще немає";
                                    font-size: 15px;
                                    font-weight: 500;
                                    color: Theme.text-sub;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: "Натисніть «+ Нова компанія» щоб додати першу";
                                    font-size: 13px;
                                    color: Theme.text-muted;
                                    horizontal-alignment: center;
                                }
                            }
                        }

                        // Рядки даних
                        ListView {
                            vertical-stretch: 1;

                            for c[i] in root.companies : Rectangle {
                                height: 52px;
                                background: c.is-current
                                    ? #EFF1FE
                                    : (row-touch.has-hover
                                        ? Theme.hover-bg
                                        : (Math.mod(i, 2) == 0 ? Theme.surface : #FCFCFD));
                                border-width: 1px;
                                border-color: Theme.border;
                                animate background { duration: 80ms; easing: ease; }

                                HorizontalLayout {
                                    padding-left: 16px;
                                    padding-right: 16px;
                                    spacing: 12px;

                                    // Ініціали + назва
                                    HorizontalLayout {
                                        horizontal-stretch: 3;
                                        spacing: 10px;

                                        Rectangle {
                                            width: 28px;
                                            height: 28px;
                                            border-radius: 14px;
                                            background: c.is-current ? Theme.primary : #EEF2FF;
                                            y: (parent.height - self.height) / 2;

                                            Text {
                                                text: c.initials;
                                                color: c.is-current ? #ffffff : Theme.primary;
                                                font-size: 10px;
                                                font-weight: 600;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }

                                        Text {
                                            text: c.name;
                                            color: Theme.text-main;
                                            font-size: 13px;
                                            font-weight: 500;
                                            horizontal-stretch: 1;
                                            vertical-alignment: center;
                                            overflow: elide;
                                        }
                                    }

                                    // ЄДРПОУ
                                    Text {
                                        text: c.edrpou;
                                        color: Theme.text-sub;
                                        font-size: 13px;
                                        horizontal-stretch: 1;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }

                                    // Кількість актів
                                    Text {
                                        text: c.act-count + "";
                                        color: Theme.text-sub;
                                        font-size: 13px;
                                        width: 60px;
                                        vertical-alignment: center;
                                    }

                                    // Оборот
                                    Text {
                                        text: c.total-amount;
                                        color: Theme.text-main;
                                        font-size: 13px;
                                        font-weight: 600;
                                        horizontal-stretch: 2;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }

                                    // Дії
                                    Rectangle {
                                        width: 172px;

                                        HorizontalLayout {
                                            spacing: 6px;

                                            // Обрати / Активна
                                            Rectangle {
                                                width: 80px;
                                                height: 26px;
                                                y: (parent.height - self.height) / 2;
                                                border-radius: 6px;
                                                background: c.is-current ? #EEF2FF : Theme.primary;

                                                Text {
                                                    text: c.is-current ? "✓ Активна" : "Обрати";
                                                    color: c.is-current ? Theme.primary : #ffffff;
                                                    font-size: 10px;
                                                    font-weight: 500;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }

                                                TouchArea {
                                                    enabled: !c.is-current;
                                                    mouse-cursor: self.enabled ? pointer : default;
                                                    clicked => { root.select(c.id); }
                                                }
                                            }

                                            Rectangle {
                                                width: 38px;
                                                height: 26px;
                                                y: (parent.height - self.height) / 2;
                                                border-radius: 6px;
                                                background: #EEF2FF;

                                                Text {
                                                    text: "✎";
                                                    color: Theme.primary;
                                                    font-size: 12px;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }

                                                TouchArea {
                                                    mouse-cursor: pointer;
                                                    clicked => { root.edit(c.id); }
                                                }
                                            }

                                            Rectangle {
                                                width: 38px;
                                                height: 26px;
                                                y: (parent.height - self.height) / 2;
                                                border-radius: 6px;
                                                background: #FEF2F2;

                                                Text {
                                                    text: "🗄";
                                                    font-size: 12px;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }

                                                TouchArea {
                                                    mouse-cursor: pointer;
                                                    clicked => { root.archive(c.id); }
                                                }
                                            }
                                        }
                                    }
                                }

                                row-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.select(c.id); }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
