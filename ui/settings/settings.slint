import { Button, LineEdit, ComboBox, TextEdit } from "std-widgets.slint";
import { Theme } from "../theme.slint";

export struct SettingsCategoryRow {
    name: string,
    kind: string,
    depth: int,
}

export struct SettingsTemplateRow {
    id: string,
    name: string,
    description: string,
    template_type: string,  // "act" | "invoice"
    is_default: bool,
}

export component SettingsPage {
    in property <string> company-name: "";
    in property <string> company-edrpou: "";
    in property <string> company-iban: "";
    in property <string> company-director: "";
    in property <string> company-address: "";
    in property <[SettingsCategoryRow]> category-rows: [];
    in property <[SettingsTemplateRow]> template-rows: [];

    // Template form overlay
    in-out property <bool>    show-template-form: false;
    in-out property <string> template-form-id: "";
    in-out property <string> template-form-name: "";
    in-out property <string> template-form-description: "";
    in-out property <string> template-form-type: "act";  // "act" | "invoice"
    in-out property <string> template-form-path: "";
    in-out property <bool>    template-form-is-default: false;

    callback edit-company-clicked();
    callback template-create-clicked();
    callback template-edit-clicked(string);
    callback template-delete-clicked(string);
    callback template-set-default-clicked(string);
    callback template-form-save(string, string, string, string, bool, string);
    callback template-form-cancel();

    private property <int> active-tab: 0;

    min-width: 600px;
    min-height: 400px;

    VerticalLayout {
        spacing: 0;

        // ── Topbar (64px, білий, з нижньою межею) ───────────────────────────
        Rectangle {
            height: Theme.topbar-height;
            vertical-stretch: 0;
            background: Theme.bg-card;

            HorizontalLayout {
                padding-left: 32px;
                padding-right: 32px;
                spacing: 16px;
                alignment: center;

                Text {
                    text: "Налаштування";
                    font-size: Theme.font-2xl;
                    font-weight: 600;
                    color: Theme.text-primary;
                    horizontal-stretch: 1;
                    vertical-alignment: center;
                }
            }

            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: Theme.border;
            }
        }

        // ── Основний контент ─────────────────────────────────────────────────
        Rectangle {
            background: Theme.bg-page;
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: 24px;
                padding-left: 32px;
                padding-right: 32px;
                padding-bottom: 24px;
                spacing: 16px;

                // ── Вкладки ───────────────────────────────────────────────────
                HorizontalLayout {
                    spacing: 8px;
                    vertical-stretch: 0;

                    for label[i] in ["Компанія", "Категорії", "Шаблони"]: Rectangle {
                        height: Theme.btn-sm-height;
                        width: i == 0 ? 110px : 100px;
                        border-radius: Theme.radius-md;
                        background: root.active-tab == i ? Theme.primary : Theme.bg-gray;
                        animate background { duration: 120ms; easing: ease; }

                        Text {
                            text: label;
                            color: root.active-tab == i ? Theme.text-white : Theme.text-second;
                            font-size: Theme.font-md;
                            font-weight: root.active-tab == i ? 600 : 400;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            animate color { duration: 120ms; easing: ease; }
                        }

                        TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.active-tab = i; }
                        }
                    }
                }

                // ── Вкладка «Компанія» ────────────────────────────────────────
                if root.active-tab == 0 : Rectangle {
                    background: Theme.bg-card;
                    border-width: 1px;
                    border-color: Theme.border;
                    border-radius: Theme.radius-xl;
                    vertical-stretch: 1;

                    VerticalLayout {
                        padding: 24px;
                        spacing: 12px;

                        HorizontalLayout {
                            Text {
                                text: "Реквізити активної компанії";
                                font-size: Theme.font-2xl;
                                font-weight: 700;
                                color: Theme.text-primary;
                                horizontal-stretch: 1;
                                vertical-alignment: center;
                            }

                            Button {
                                text: "Редагувати";
                                primary: true;
                                height: Theme.btn-md-height;
                                clicked => { root.edit-company-clicked(); }
                            }
                        }

                        for item in [
                            { label: "Назва",     value: root.company-name     },
                            { label: "ЄДРПОУ",    value: root.company-edrpou   },
                            { label: "IBAN",      value: root.company-iban     },
                            { label: "Директор",  value: root.company-director },
                            { label: "Адреса",    value: root.company-address  }
                        ]: Rectangle {
                            height: 40px;
                            border-radius: Theme.radius-md;
                            background: Theme.bg-gray;

                            HorizontalLayout {
                                padding-left: 14px;
                                padding-right: 14px;

                                Text {
                                    text: item.label;
                                    width: 120px;
                                    font-size: Theme.font-base;
                                    color: Theme.text-muted;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: item.value == "" ? "—" : item.value;
                                    font-size: Theme.font-md;
                                    color: Theme.text-primary;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                // ── Вкладка «Категорії» ───────────────────────────────────────
                if root.active-tab == 1 : Rectangle {
                    background: Theme.bg-card;
                    border-width: 1px;
                    border-color: Theme.border;
                    border-radius: Theme.radius-xl;
                    vertical-stretch: 1;

                    VerticalLayout {
                        padding: 24px;
                        spacing: 10px;

                        Text {
                            text: "Категорії доходів і витрат";
                            font-size: Theme.font-2xl;
                            font-weight: 700;
                            color: Theme.text-primary;
                        }

                        for row in root.category-rows: Rectangle {
                            height: 40px;
                            border-radius: Theme.radius-md;
                            background: Theme.bg-gray;

                            HorizontalLayout {
                                padding-left: 14px + (row.depth * 18px);
                                padding-right: 14px;
                                spacing: 12px;

                                Text {
                                    text: row.kind == "income" ? "Дохід" : "Витрата";
                                    width: 70px;
                                    font-size: Theme.font-sm;
                                    color: row.kind == "income" ? Theme.success : Theme.danger;
                                    vertical-alignment: center;
                                }

                                Text {
                                    text: row.depth > 0 ? "↳ " + row.name : row.name;
                                    font-size: Theme.font-md;
                                    color: Theme.text-primary;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                // ── Вкладка «Шаблони» ────────────────────────────────────────
                if root.active-tab == 2 : VerticalLayout {
                    spacing: 12px;

                    // Заголовок + кнопка
                    HorizontalLayout {
                        Text {
                            text: "Шаблони документів";
                            font-size: Theme.font-2xl;
                            font-weight: 700;
                            color: Theme.text-primary;
                            vertical-alignment: center;
                        }
                        Rectangle { horizontal-stretch: 1; }
                        Button {
                            text: "+ Створити";
                            primary: true;
                            height: Theme.btn-md-height;
                            clicked => { root.template-create-clicked(); }
                        }
                    }

                    // Список шаблонів
                    VerticalLayout {
                        spacing: 6px;

                        for row in root.template-rows : Rectangle {
                            height: 52px;
                            border-radius: Theme.radius-md;
                            background: row.is_default ? Theme.bg-success : Theme.bg-gray;
                            border-width: row.is_default ? 1px : 0px;
                            border-color: row.is_default ? Theme.success : Theme.border;

                            HorizontalLayout {
                                padding-left: 14px;
                                padding-right: 10px;
                                spacing: 10px;
                                alignment: center;

                                // Радіо-індикатор дефолтного
                                Rectangle {
                                    width: 16px;
                                    height: 16px;
                                    border-radius: 8px;
                                    border-width: 2px;
                                    border-color: row.is_default ? Theme.success : Theme.border;
                                    background: row.is_default ? Theme.success : transparent;
                                    TouchArea {
                                        clicked => { root.template-set-default-clicked(row.id); }
                                    }
                                }

                                // Бейдж типу
                                Rectangle {
                                    width: 60px;
                                    height: 22px;
                                    border-radius: Theme.radius-sm;
                                    background: row.template_type == "act" ? Theme.bg-primary : Theme.bg-purple;

                                    Text {
                                        text: row.template_type == "act" ? "Акт" : "Накл.";
                                        color: row.template_type == "act" ? Theme.primary : Theme.purple;
                                        font-size: Theme.font-sm;
                                        font-weight: 600;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 2px;
                                    alignment: center;

                                    Text {
                                        text: row.name;
                                        font-size: Theme.font-md;
                                        font-weight: 600;
                                        color: Theme.text-primary;
                                    }
                                    Text {
                                        text: row.description == "" ? row.template_type : row.description;
                                        font-size: Theme.font-sm;
                                        color: Theme.text-muted;
                                    }
                                }

                                Button {
                                    text: "✎";
                                    width: 32px;
                                    height: Theme.btn-sm-height;
                                    clicked => { root.template-edit-clicked(row.id); }
                                }
                                Button {
                                    text: "✕";
                                    width: 32px;
                                    height: Theme.btn-sm-height;
                                    clicked => { root.template-delete-clicked(row.id); }
                                }
                            }
                        }
                    }

                    // Порожній стан
                    if root.template-rows.length == 0 : Rectangle {
                        height: 80px;
                        border-radius: Theme.radius-md;
                        background: Theme.bg-gray;

                        Text {
                            text: "Немає шаблонів. Натисніть «Створити».";
                            font-size: Theme.font-md;
                            color: Theme.text-muted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }

    // ── Modal overlay: Template Form ─────────────────────────────────────────
    if root.show-template-form : Rectangle {
        background: Theme.overlay;

        Rectangle {
            x: (parent.width - 480px) / 2;
            y: (parent.height - 400px) / 2;
            width: 480px;
            background: Theme.bg-card;
            border-radius: Theme.radius-xl;
            drop-shadow-blur: 40px;
            drop-shadow-color: rgba(0, 0, 0, 18%);
            drop-shadow-offset-y: 12px;

            // Акцентна смужка зверху
            Rectangle {
                x: 0; y: 0; width: 480px; height: 4px;
                border-top-left-radius: Theme.radius-xl;
                border-top-right-radius: Theme.radius-xl;
                background: Theme.primary;
            }

            VerticalLayout {
                padding: 24px;
                spacing: 14px;

                Text {
                    text: root.template-form-id == "" ? "Новий шаблон" : "Редагувати шаблон";
                    font-size: Theme.font-2xl;
                    font-weight: 700;
                    color: Theme.text-primary;
                }

                // Назва
                VerticalLayout {
                    spacing: 4px;
                    Text { text: "Назва"; font-size: Theme.font-base; font-weight: 600; color: Theme.text-second; }
                    Rectangle {
                        height: 40px;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border;
                        LineEdit {
                            text: root.template-form-name;
                            placeholder-text: "Мій шаблон акту";
                        }
                    }
                }

                // Тип
                VerticalLayout {
                    spacing: 4px;
                    Text { text: "Тип документа"; font-size: Theme.font-base; font-weight: 600; color: Theme.text-second; }
                    HorizontalLayout {
                        spacing: 8px;
                        for label[idx] in ["Акт", "Накладна"]: Rectangle {
                            width: 100px;
                            height: Theme.btn-md-height;
                            border-radius: Theme.radius-md;
                            border-width: 2px;
                            border-color: (root.template-form-type == "act" ? idx == 0 : idx == 1) ? Theme.primary : Theme.border;
                            background: (root.template-form-type == "act" ? idx == 0 : idx == 1) ? Theme.bg-primary : Theme.bg-card;
                            animate background { duration: 100ms; easing: ease; }

                            TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    root.template-form-type = (idx == 0) ? "act" : "invoice";
                                    root.template-form-path = (idx == 0) ? "templates/act.typ" : "templates/invoice.typ";
                                }
                            }
                            Text {
                                text: label;
                                color: (root.template-form-type == "act" ? idx == 0 : idx == 1) ? Theme.primary : Theme.text-muted;
                                font-size: Theme.font-md;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // Шлях до файлу
                VerticalLayout {
                    spacing: 4px;
                    Text { text: "Шлях до .typ файлу"; font-size: Theme.font-base; font-weight: 600; color: Theme.text-second; }
                    Rectangle {
                        height: 40px;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border;
                        LineEdit {
                            text: root.template-form-path;
                            placeholder-text: "templates/act.typ";
                        }
                    }
                }

                // Опис
                VerticalLayout {
                    spacing: 4px;
                    Text { text: "Опис (необов'язково)"; font-size: Theme.font-base; font-weight: 600; color: Theme.text-second; }
                    Rectangle {
                        height: 60px;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border;
                        TextEdit {
                            text: root.template-form-description;
                            placeholder-text: "Опис шаблону...";
                        }
                    }
                }

                // Дефолтний
                HorizontalLayout {
                    spacing: 8px;
                    alignment: center;

                    Rectangle {
                        width: 20px;
                        height: 20px;
                        border-radius: Theme.radius-sm;
                        border-width: 2px;
                        border-color: Theme.primary;
                        background: root.template-form-is-default ? Theme.primary : transparent;

                        TouchArea {
                            clicked => { root.template-form-is-default = !root.template-form-is-default; }
                        }
                    }
                    Text {
                        text: "Використовувати як дефолтний для цього типу";
                        font-size: Theme.font-md;
                        color: Theme.text-primary;
                        vertical-alignment: center;
                    }
                }

                // Кнопки
                HorizontalLayout {
                    spacing: 10px;
                    Rectangle { horizontal-stretch: 1; }
                    Button {
                        text: "Скасувати";
                        height: Theme.btn-md-height;
                        clicked => { root.template-form-cancel(); }
                    }
                    Button {
                        text: "Зберегти";
                        primary: true;
                        height: Theme.btn-md-height;
                        clicked => { root.template-form-save(root.template-form-name, root.template-form-description, root.template-form-type, root.template-form-path, root.template-form-is-default, root.template-form-id); }
                    }
                }
            }
        }
    }
}
