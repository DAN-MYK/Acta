// Компонент: список контрагентів, наближений до макета Figma.

import { Theme } from "../theme.slint";
import { ProgressIndicator, ListView } from "std-widgets.slint";

component StatCard inherits Rectangle {
    in property <brush> accent;
    in property <string> value;
    in property <string> label;

    width: 156px;
    height: 78px;
    background: Theme.surface;
    border-radius: 12px;
    border-width: 1px;
    border-color: Theme.border;
    clip: true;

    Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: 3px;
        background: root.accent;
    }

    Text {
        x: 16px;
        y: 10px;
        text: root.value;
        font-size: 24px;
        font-weight: 700;
        color: Theme.text-main;
    }

    Text {
        x: 16px;
        y: 42px;
        text: root.label;
        font-size: 11px;
        color: Theme.text-sub;
    }
}

export component CounterpartyList {
    in property <[[StandardListViewItem]]> rows;
    in property <[string]>                 row-ids;
    in property <[bool]>                   row-archived;
    in property <bool>                     loading: false;
    in property <int>                      total-count: 0;
    in property <int>                      active-count: 0;
    in property <int>                      archived-count: 0;
    in property <bool>                     show-archived: false;
    in property <string>                   pagination-text: "";
    in property <int>                      current-page: 1;
    in property <int>                      total-pages: 1;

    callback search-changed(string);
    callback row-selected(string);
    callback edit-clicked(string);
    callback create-clicked();
    callback archive-clicked(string);
    callback filter-clicked();
    callback prev-page-clicked();
    callback next-page-clicked();

    private property <int>    selected-row: -1;
    private property <string> selected-id: "";

    min-width: 600px;
    min-height: 400px;

    VerticalLayout {
        spacing: 0;
        padding: 0;

        Rectangle {
            height: 64px;
            background: Theme.surface;

            HorizontalLayout {
                padding-left: 32px;
                padding-right: 32px;

                Text {
                    text: "Контрагенти";
                    font-size: 18px;
                    font-weight: 600;
                    color: Theme.text-main;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                Rectangle {
                    background: Theme.primary;
                    border-radius: 8px;
                    height: 36px;
                    width: 188px;
                    y: (parent.height - self.height) / 2;

                    Text {
                        text: "+ Новий контрагент";
                        color: #ffffff;
                        font-size: 13px;
                        font-weight: 500;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.create-clicked(); }
                    }
                }
            }

            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: Theme.border;
            }
        }

        Rectangle {
            background: Theme.bg;
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: 24px;
                padding-left: 32px;
                padding-right: 32px;
                padding-bottom: 24px;
                spacing: 16px;

                HorizontalLayout {
                    height: 40px;
                    spacing: 12px;
                    vertical-stretch: 0;

                    Rectangle {
                        background: Theme.surface;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.border;
                        horizontal-stretch: 1;
                        clip: true;

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;

                            search-input := TextInput {
                                vertical-alignment: center;
                                font-size: 13px;
                                color: Theme.text-main;
                                edited => { root.search-changed(search-input.text); }
                            }
                        }

                        if search-input.text == "" : Text {
                            x: 12px;
                            height: parent.height;
                            width: parent.width - 24px;
                            text: "Пошук за назвою або ЄДРПОУ";
                            color: Theme.text-muted;
                            font-size: 13px;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        background: Theme.surface;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.border;
                        width: 112px;
                        clip: true;

                        Text {
                            text: root.show-archived ? "Усі" : "Архів";
                            color: Theme.text-sub;
                            font-size: 13px;
                            font-weight: 500;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.filter-clicked(); }
                        }
                    }
                }

                HorizontalLayout {
                    height: 78px;
                    spacing: 16px;
                    vertical-stretch: 0;

                    StatCard {
                        accent: Theme.primary;
                        value: root.total-count + "";
                        label: "Всього";
                    }

                    StatCard {
                        accent: Theme.success;
                        value: root.active-count + "";
                        label: "Активних";
                    }

                    StatCard {
                        accent: Theme.text-muted;
                        value: root.archived-count + "";
                        label: "В архіві";
                    }
                }

                Rectangle {
                    vertical-stretch: 1;
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: Theme.border;
                    clip: true;

                    VerticalLayout {
                        spacing: 0;

                        Rectangle {
                            height: 40px;
                            background: #F4F6FA;

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;
                                spacing: 12px;

                                Text { text: "Назва"; color: Theme.text-sub; font-size: 12px; font-weight: 500; horizontal-stretch: 3; vertical-alignment: center; }
                                Text { text: "ЄДРПОУ"; color: Theme.text-sub; font-size: 12px; font-weight: 500; horizontal-stretch: 1; vertical-alignment: center; }
                                Text { text: "IBAN"; color: Theme.text-sub; font-size: 12px; font-weight: 500; horizontal-stretch: 2; vertical-alignment: center; }
                                Text { text: "Телефон"; color: Theme.text-sub; font-size: 12px; font-weight: 500; horizontal-stretch: 1; vertical-alignment: center; }
                                Text { text: "Статус"; color: Theme.text-sub; font-size: 12px; font-weight: 500; width: 88px; vertical-alignment: center; }
                                Text { text: "Дії"; color: Theme.text-sub; font-size: 12px; font-weight: 500; width: 120px; vertical-alignment: center; }
                            }
                        }

                        if root.loading : ProgressIndicator {
                            indeterminate: true;
                            vertical-stretch: 0;
                        }

                        if !root.loading && root.rows.length == 0 : Rectangle {
                            vertical-stretch: 1;
                            background: Theme.surface;

                            VerticalLayout {
                                alignment: center;
                                spacing: 8px;

                                Text {
                                    text: "Контрагентів ще немає";
                                    font-size: 15px;
                                    font-weight: 600;
                                    color: Theme.text-main;
                                    horizontal-alignment: center;
                                }

                                Text {
                                    text: "Додайте першого контрагента, щоб з’явився список.";
                                    font-size: 13px;
                                    color: Theme.text-muted;
                                    horizontal-alignment: center;
                                }
                            }
                        }

                        ListView {
                            vertical-stretch: 1;

                            for row[i] in root.rows : Rectangle {
                                property <bool> is-archived: i < root.row-archived.length && root.row-archived[i];

                                height: 52px;
                                background: root.selected-row == i
                                    ? #EFF3FF
                                    : (row-touch.has-hover ? #F7F9FC : (Math.mod(i, 2) == 0 ? Theme.surface : #FCFCFD));
                                border-width: 1px;
                                border-color: Theme.border;
                                animate background { duration: 100ms; easing: ease; }

                                HorizontalLayout {
                                    padding-left: 16px;
                                    padding-right: 16px;
                                    spacing: 12px;

                                    Text {
                                        text: row[0].text;
                                        color: Theme.text-main;
                                        font-size: 13px;
                                        font-weight: 500;
                                        horizontal-stretch: 3;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }

                                    Text {
                                        text: row[1].text;
                                        color: Theme.text-sub;
                                        font-size: 13px;
                                        horizontal-stretch: 1;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }

                                    Text {
                                        text: row[2].text;
                                        color: Theme.text-sub;
                                        font-size: 13px;
                                        horizontal-stretch: 2;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }

                                    Text {
                                        text: row[3].text;
                                        color: Theme.text-sub;
                                        font-size: 13px;
                                        horizontal-stretch: 1;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }

                                    Rectangle {
                                        width: 88px;

                                        Rectangle {
                                            width: 72px;
                                            height: 24px;
                                            y: (parent.height - self.height) / 2;
                                            border-radius: 12px;
                                            background: is-archived ? #ABABB71F : #1EB16E1F;

                                            Text {
                                                text: is-archived ? "Архів" : "Активний";
                                                color: is-archived ? Theme.text-muted : Theme.success;
                                                font-size: 11px;
                                                font-weight: 500;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    Rectangle {
                                        width: 120px;

                                        if !is-archived : HorizontalLayout {
                                            spacing: 6px;

                                            Rectangle {
                                                width: 54px;
                                                height: 24px;
                                                y: (parent.height - self.height) / 2;
                                                border-radius: 6px;
                                                background: #EEF2FF;

                                                Text {
                                                    text: "Відкрити";
                                                    color: Theme.primary;
                                                    font-size: 10px;
                                                    font-weight: 500;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }

                                                TouchArea {
                                                    mouse-cursor: pointer;
                                                    clicked => {
                                                        root.selected-row = i;
                                                        if i < root.row-ids.length {
                                                            root.selected-id = root.row-ids[i];
                                                            root.edit-clicked(root.row-ids[i]);
                                                        }
                                                    }
                                                }
                                            }

                                            Rectangle {
                                                width: 54px;
                                                height: 24px;
                                                y: (parent.height - self.height) / 2;
                                                border-radius: 6px;
                                                background: #FEF2F2;

                                                Text {
                                                    text: "Архів";
                                                    color: #DC2626;
                                                    font-size: 10px;
                                                    font-weight: 500;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }

                                                TouchArea {
                                                    mouse-cursor: pointer;
                                                    clicked => {
                                                        root.selected-row = i;
                                                        if i < root.row-ids.length {
                                                            root.selected-id = root.row-ids[i];
                                                            root.archive-clicked(root.row-ids[i]);
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }

                                row-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        root.selected-row = i;
                                        if i < root.row-ids.length {
                                            root.selected-id = root.row-ids[i];
                                            root.row-selected(root.row-ids[i]);
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                HorizontalLayout {
                    height: 48px;
                    spacing: 10px;
                    vertical-stretch: 0;

                    Text {
                        text: root.pagination-text;
                        color: Theme.text-muted;
                        font-size: 13px;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }

                    Rectangle {
                        background: root.current-page > 1 ? Theme.surface : Theme.hover-bg;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.border;
                        width: 104px;
                        height: 36px;
                        y: (parent.height - self.height) / 2;

                        Text {
                            text: "← Назад";
                            color: root.current-page > 1 ? Theme.text-main : Theme.text-muted;
                            font-size: 12px;
                            font-weight: 500;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        TouchArea {
                            enabled: root.current-page > 1;
                            mouse-cursor: self.enabled ? pointer : default;
                            clicked => { root.prev-page-clicked(); }
                        }
                    }

                    Rectangle {
                        background: Theme.surface;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.border;
                        width: 108px;
                        height: 36px;
                        y: (parent.height - self.height) / 2;

                        Text {
                            text: root.current-page + " / " + root.total-pages;
                            color: Theme.text-sub;
                            font-size: 12px;
                            font-weight: 500;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        background: root.current-page < root.total-pages ? Theme.surface : Theme.hover-bg;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.border;
                        width: 104px;
                        height: 36px;
                        y: (parent.height - self.height) / 2;

                        Text {
                            text: "Далі →";
                            color: root.current-page < root.total-pages ? Theme.text-main : Theme.text-muted;
                            font-size: 12px;
                            font-weight: 500;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        TouchArea {
                            enabled: root.current-page < root.total-pages;
                            mouse-cursor: self.enabled ? pointer : default;
                            clicked => { root.next-page-clicked(); }
                        }
                    }
                }
            }
        }
    }
}
