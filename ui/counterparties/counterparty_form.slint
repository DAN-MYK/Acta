// Форма створення / редагування контрагента в card-layout стилі Figma.

import { Theme } from "../theme.slint";
import { LineEdit } from "std-widgets.slint";

component FormField inherits Rectangle {
    in property <string> label;
    in property <string> placeholder;
    in-out property <string> value;

    background: transparent;
    min-height: 70px;

    VerticalLayout {
        spacing: 6px;

        Text {
            text: root.label;
            font-size: 12px;
            color: Theme.text-sub;
        }

        Rectangle {
            height: 40px;
            background: Theme.surface;
            border-width: 1px;
            border-color: Theme.border;
            border-radius: 8px;

            field := LineEdit {
                text <=> root.value;
                placeholder-text: root.placeholder;
            }
        }
    }
}

export component CounterpartyForm inherits Rectangle {
    background: Theme.bg;

    in property <bool>   is-edit-mode: false;
    in property <string> cp-edit-id: "";
    in property <string> cp-name: "";
    in property <string> cp-edrpou: "";
    in property <string> cp-ipn: "";
    in property <string> cp-iban: "";
    in property <string> cp-phone: "";
    in property <string> cp-email: "";
    in property <string> cp-address: "";
    in property <string> cp-notes: "";

    callback save(string, string, string, string, string, string, string, string);
    callback update(string, string, string, string, string, string, string, string);
    callback cancel();

    min-width: 700px;
    min-height: 480px;

    private property <string> name-value: root.cp-name;
    private property <string> edrpou-value: root.cp-edrpou;
    private property <string> ipn-value: root.cp-ipn;
    private property <string> iban-value: root.cp-iban;
    private property <string> phone-value: root.cp-phone;
    private property <string> email-value: root.cp-email;
    private property <string> address-value: root.cp-address;
    private property <string> notes-value: root.cp-notes;

    focus-scope := FocusScope {
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                root.cancel();
                return accept;
            }
            return reject;
        }

        VerticalLayout {
            spacing: 0;
            padding: 0;

            Rectangle {
                height: 64px;
                background: Theme.surface;

                Rectangle {
                    y: 63px;
                    height: 1px;
                    background: Theme.border;
                }

                HorizontalLayout {
                    padding-left: 32px;
                    padding-right: 32px;
                    spacing: 8px;

                    HorizontalLayout {
                        spacing: 6px;
                        horizontal-stretch: 1;
                        alignment: start;

                        Text {
                            text: "← Контрагенти";
                            font-size: 14px;
                            color: Theme.primary;
                            vertical-alignment: center;
                            TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.cancel(); }
                            }
                        }
                        Text {
                            text: "/";
                            font-size: 14px;
                            color: Theme.text-muted;
                            vertical-alignment: center;
                        }
                        Text {
                            text: root.is-edit-mode ? "Редагування контрагента" : "Новий контрагент";
                            font-size: 14px;
                            font-weight: 600;
                            color: Theme.text-main;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        width: 120px;
                        height: 36px;
                        y: (parent.height - self.height) / 2;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.border;
                        background: cp-cancel-touch.has-hover ? Theme.hover-bg : Theme.bg;
                        animate background { duration: 80ms; }

                        Text {
                            text: "Скасувати";
                            font-size: 14px;
                            color: Theme.text-sub;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        cp-cancel-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.cancel(); }
                        }
                    }

                    Rectangle {
                        width: 112px;
                        height: 36px;
                        y: (parent.height - self.height) / 2;
                        border-radius: 8px;
                        background: cp-save-touch.has-hover ? #2D64E3 : Theme.primary;
                        animate background { duration: 80ms; }

                        Text {
                            text: "Зберегти";
                            font-size: 14px;
                            font-weight: 600;
                            color: #ffffff;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        cp-save-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                if (root.is-edit-mode) {
                                    root.update(
                                        root.name-value,
                                        root.edrpou-value,
                                        root.ipn-value,
                                        root.iban-value,
                                        root.phone-value,
                                        root.email-value,
                                        root.address-value,
                                        root.notes-value
                                    );
                                } else {
                                    root.save(
                                        root.name-value,
                                        root.edrpou-value,
                                        root.ipn-value,
                                        root.iban-value,
                                        root.phone-value,
                                        root.email-value,
                                        root.address-value,
                                        root.notes-value
                                    );
                                }
                            }
                        }
                    }
                }
            }

            Rectangle {
                background: Theme.bg;
                vertical-stretch: 1;

                HorizontalLayout {
                    padding-top: 20px;
                    padding-left: 20px;
                    padding-right: 20px;
                    padding-bottom: 20px;
                    spacing: 16px;
                    alignment: start;

                    Rectangle {
                        horizontal-stretch: 1;
                        vertical-stretch: 1;
                        background: Theme.surface;
                        border-radius: 14px;
                        border-width: 1px;
                        border-color: Theme.border;

                        VerticalLayout {
                            padding: 18px;
                            spacing: 18px;

                            Text {
                                text: "Основна інформація";
                                font-size: 16px;
                                font-weight: 600;
                                color: Theme.text-main;
                            }

                            FormField {
                                label: "Назва компанії *";
                                placeholder: "Введіть назву...";
                                value <=> root.name-value;
                            }

                            HorizontalLayout {
                                spacing: 16px;

                                FormField {
                                    horizontal-stretch: 1;
                                    label: "ЄДРПОУ";
                                    placeholder: "12345678";
                                    value <=> root.edrpou-value;
                                }

                                FormField {
                                    horizontal-stretch: 1;
                                    label: "ІПН / РНОКПП";
                                    placeholder: "1234567890";
                                    value <=> root.ipn-value;
                                }
                            }

                            FormField {
                                label: "IBAN";
                                placeholder: "UA12345678901234567890123456";
                                value <=> root.iban-value;
                            }

                            Rectangle {
                                height: 1px;
                                background: Theme.border;
                            }

                            Text {
                                text: "Контактна інформація";
                                font-size: 16px;
                                font-weight: 600;
                                color: Theme.text-main;
                            }

                            HorizontalLayout {
                                spacing: 16px;

                                FormField {
                                    horizontal-stretch: 1;
                                    label: "Телефон";
                                    placeholder: "+380 44 123-45-67";
                                    value <=> root.phone-value;
                                }

                                FormField {
                                    horizontal-stretch: 1;
                                    label: "Email";
                                    placeholder: "info@company.ua";
                                    value <=> root.email-value;
                                }
                            }

                            FormField {
                                label: "Адреса";
                                placeholder: "м. Київ, вул. Хрещатик, 1";
                                value <=> root.address-value;
                            }

                        }
                    }

                    Rectangle {
                        width: 260px;
                        background: Theme.surface;
                        border-radius: 14px;
                        border-width: 1px;
                        border-color: Theme.border;
                        vertical-stretch: 0;

                        VerticalLayout {
                            padding: 18px;
                            spacing: 10px;

                            Text {
                                text: "Підказка";
                                font-size: 16px;
                                font-weight: 600;
                                color: Theme.text-main;
                            }

                            Text {
                                text: "ЄДРПОУ — 8-значний код для юридичних осіб або ФОП.";
                                font-size: 12px;
                                color: Theme.text-sub;
                                wrap: word-wrap;
                            }

                            Text {
                                text: "IBAN — 29 символів, починається з UA та 6-значного МФО.";
                                font-size: 12px;
                                color: Theme.text-sub;
                                wrap: word-wrap;
                            }

                            Text {
                                text: "Телефон, email та адреса є необов'язковими. ІПН / РНОКПП заповнюйте для ФОП або фізичних осіб.";
                                font-size: 12px;
                                color: Theme.text-sub;
                                wrap: word-wrap;
                            }
                        }
                    }
                }
            }
        }
    }
}
